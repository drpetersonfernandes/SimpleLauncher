<Window x:Class="XmlToBinaryConverter.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="About XML to Binary Converter" Height="300" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0" Text="XML to Binary Converter" 
                   FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
        
        <TextBlock x:Name="AppVersionTextBlock" Grid.Row="1" 
                   FontSize="14" Margin="0,10,0,20" HorizontalAlignment="Center"/>
        
        <TextBlock x:Name="AppDescriptionTextBlock" Grid.Row="2" 
                   TextWrapping="Wrap" TextAlignment="Center" VerticalAlignment="Center"/>
        
        <Button Grid.Row="3" Content="Close" Click="Close_Click"
                Width="100" Margin="0,20,0,0" HorizontalAlignment="Center"/>
    </Grid>
</Window>