<controls:MetroWindow x:Class="SimpleLauncher.InjectSegaModel2ConfigWindow"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
                      Title="{DynamicResource SegaModel2Config_Title}"
                      Height="700" Width="700"
                      ResizeMode="CanResize"
                      WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Renderer Section -->
                <GroupBox Header="{DynamicResource SegaModel2Config_Renderer_Header}" Margin="0,0,0,10">
                    <StackPanel Margin="5">
                        <Label Content="{DynamicResource SegaModel2Config_Resolution_Label}" Margin="0,5,0,0" ToolTip="{DynamicResource SegaModel2Config_Resolution_Tooltip}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <controls:NumericUpDown Value="{Binding ResX}" Grid.Column="0" Minimum="640" Maximum="7680" Interval="1" ToolTip="{DynamicResource SegaModel2Config_ResolutionX_Tooltip}" />
                            <TextBlock Text="x" Grid.Column="1" VerticalAlignment="Center" Margin="10,0" />
                            <controls:NumericUpDown Value="{Binding ResY}" Grid.Column="2" Minimum="480" Maximum="4320" Interval="1" ToolTip="{DynamicResource SegaModel2Config_ResolutionY_Tooltip}" />
                        </Grid>

                        <Grid Margin="0,5,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Label Content="{DynamicResource SegaModel2Config_Widescreen_Label}" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding WideScreenOptions}"
                                      SelectedItem="{Binding WideScreen}"
                                      ToolTip="{DynamicResource SegaModel2Config_Widescreen_Tooltip}" />
                        </Grid>

                        <Grid Margin="0,5,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Label Content="{DynamicResource SegaModel2Config_FSAA_Label}" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding FsaaOptions}"
                                      SelectedItem="{Binding Fsaa}"
                                      ToolTip="{DynamicResource SegaModel2Config_FSAA_Tooltip}" />
                        </Grid>

                        <CheckBox IsChecked="{Binding Bilinear}" Content="{DynamicResource SegaModel2Config_Bilinear_Checkbox}" Margin="0,5" ToolTip="{DynamicResource SegaModel2Config_Bilinear_Tooltip}" />
                        <CheckBox IsChecked="{Binding Trilinear}" Content="{DynamicResource SegaModel2Config_Trilinear_Checkbox}" Margin="0,5" ToolTip="{DynamicResource SegaModel2Config_Trilinear_Tooltip}" />
                        <CheckBox IsChecked="{Binding FilterTilemaps}" Content="{DynamicResource SegaModel2Config_FilterTilemaps_Checkbox}" Margin="0,5" ToolTip="{DynamicResource SegaModel2Config_FilterTilemaps_Tooltip}" />
                        <CheckBox IsChecked="{Binding DrawCross}" Content="{DynamicResource SegaModel2Config_DrawCross_Checkbox}" Margin="0,5" ToolTip="{DynamicResource SegaModel2Config_DrawCross_Tooltip}" />
                    </StackPanel>
                </GroupBox>

                <!-- Input Section -->
                <GroupBox Header="{DynamicResource SegaModel2Config_Input_Header}" Margin="0,0,0,10">
                    <StackPanel Margin="5">
                        <CheckBox IsChecked="{Binding XInput}" Content="{DynamicResource SegaModel2Config_XInput_Checkbox}" Margin="0,5" ToolTip="{DynamicResource SegaModel2Config_XInput_Tooltip}" />
                        <CheckBox IsChecked="{Binding EnableFf}" Content="{DynamicResource SegaModel2Config_EnableFF_Checkbox}" Margin="0,5" ToolTip="{DynamicResource SegaModel2Config_EnableFF_Tooltip}" />
                        <CheckBox IsChecked="{Binding HoldGears}" Content="{DynamicResource SegaModel2Config_HoldGears_Checkbox}" Margin="0,5" ToolTip="{DynamicResource SegaModel2Config_HoldGears_Tooltip}" />
                        <CheckBox IsChecked="{Binding UseRawInput}" Content="{DynamicResource SegaModel2Config_UseRawInput_Checkbox}" Margin="0,5" ToolTip="{DynamicResource SegaModel2Config_UseRawInput_Tooltip}" />
                    </StackPanel>
                </GroupBox>

                <!-- CRITICAL SETTING -->
                <Border Style="{StaticResource ImportantSettingBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource IMPORTANTSETTING}" Style="{StaticResource ImportantSettingHeaderStyle}" />
                        <CheckBox IsChecked="{Binding ShowBeforeLaunch}" Content="{DynamicResource SegaModel2Config_ShowBeforeLaunch_Checkbox}" Style="{StaticResource ImportantSettingCheckBoxStyle}" ToolTip="{DynamicResource SegaModel2Config_ShowBeforeLaunch_Tooltip}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="BtnSave" Content="{DynamicResource SegaModel2Config_Save_Button}"
                    Style="{DynamicResource DialogSecondaryButtonStyle}"
                    Command="{Binding SaveCommand}"
                    ToolTip="{DynamicResource SegaModel2Config_Save_Tooltip}" />
            <Button x:Name="BtnRun" Content="{DynamicResource SegaModel2Config_Run_Button2}"
                    Style="{DynamicResource DialogPrimaryButtonStyle}"
                    Command="{Binding RunCommand}" IsDefault="True"
                    Visibility="{Binding IsLauncherMode, Converter={StaticResource BooleanToVisibilityConverter}}"
                    ToolTip="{DynamicResource SegaModel2Config_Run_Tooltip}" />
            <Button Content="{DynamicResource SegaModel2Config_Cancel_Button}"
                    Style="{DynamicResource DialogCancelButtonStyle}"
                    ToolTip="{DynamicResource SegaModel2Config_Cancel_Tooltip}" />
        </StackPanel>
    </Grid>
</controls:MetroWindow>
