<controls:MetroWindow x:Class="SimpleLauncher.InjectDolphinConfigWindow"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
                      Title="{DynamicResource DolphinConfig_Title}"
                      Height="500" Width="700"
                      ResizeMode="CanResize"
                      WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Core Section -->
                <GroupBox Header="{DynamicResource DolphinConfig_Core_Header}" Margin="0,0,0,10">
                    <StackPanel Margin="5">
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Label Content="{DynamicResource DolphinConfig_GfxBackend_Label}" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding GfxBackendOptions}"
                                      SelectedItem="{Binding GfxBackend}"
                                      ToolTip="{DynamicResource DolphinConfig_GfxBackend_Tooltip}" />
                        </Grid>
                        <CheckBox IsChecked="{Binding DspThread}" Content="{DynamicResource DolphinConfig_DspThread_Checkbox}" Margin="0,5" ToolTip="{DynamicResource DolphinConfig_DspThread_Tooltip}" />
                    </StackPanel>
                </GroupBox>

                <!-- Wiimote Section -->
                <GroupBox Header="{DynamicResource DolphinConfig_Wiimote_Header}" Margin="0,0,0,10">
                    <StackPanel Margin="5">
                        <CheckBox IsChecked="{Binding WiimoteContinuousScanning}" Content="{DynamicResource DolphinConfig_WiimoteContinuousScanning_Checkbox}" Margin="0,5" ToolTip="{DynamicResource DolphinConfig_WiimoteContinuousScanning_Tooltip}" />
                        <CheckBox IsChecked="{Binding WiimoteEnableSpeaker}" Content="{DynamicResource DolphinConfig_WiimoteEnableSpeaker_Checkbox}" Margin="0,5" ToolTip="{DynamicResource DolphinConfig_WiimoteEnableSpeaker_Tooltip}" />
                    </StackPanel>
                </GroupBox>

                <!-- CRITICAL SETTING -->
                <Border Style="{StaticResource ImportantSettingBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource IMPORTANTSETTING}" Style="{StaticResource ImportantSettingHeaderStyle}" />
                        <CheckBox IsChecked="{Binding ShowBeforeLaunch}" Content="{DynamicResource DolphinConfig_ShowBeforeLaunch_Checkbox}" Style="{StaticResource ImportantSettingCheckBoxStyle}" ToolTip="{DynamicResource DolphinConfig_ShowBeforeLaunch_Tooltip}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="BtnSave" Content="{DynamicResource DolphinConfig_Save_Button}"
                    Style="{DynamicResource DialogSecondaryButtonStyle}"
                    Command="{Binding SaveCommand}"
                    ToolTip="{DynamicResource DolphinConfig_Save_Tooltip}" />
            <Button x:Name="BtnRun" Content="{DynamicResource DolphinConfig_Run_Button2}"
                    Style="{DynamicResource DialogPrimaryButtonStyle}"
                    Command="{Binding RunCommand}" IsDefault="True"
                    Visibility="{Binding IsLauncherMode, Converter={StaticResource BooleanToVisibilityConverter}}"
                    ToolTip="{DynamicResource DolphinConfig_Run_Tooltip}" />
            <Button Content="{DynamicResource DolphinConfig_Cancel_Button}"
                    Style="{DynamicResource DialogCancelButtonStyle}"
                    Command="{Binding CancelCommand}"
                    ToolTip="{DynamicResource DolphinConfig_Cancel_Tooltip}" />
        </StackPanel>
    </Grid>
</controls:MetroWindow>
