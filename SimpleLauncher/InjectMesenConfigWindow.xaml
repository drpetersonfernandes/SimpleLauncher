<controls:MetroWindow x:Class="SimpleLauncher.InjectMesenConfigWindow"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
                      Title="{DynamicResource MesenConfig_Title}"
                      Height="700" Width="700"
                      ResizeMode="CanResize"
                      WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Video Section -->
                <GroupBox Header="{DynamicResource MesenConfig_Video_Header}" Margin="0,0,0,10">
                    <StackPanel Margin="5">
                        <CheckBox IsChecked="{Binding Fullscreen}" Content="{DynamicResource MesenConfig_Fullscreen_Checkbox}" Margin="0,5" ToolTip="{DynamicResource MesenConfig_Fullscreen_Tooltip}" />
                        <CheckBox IsChecked="{Binding Vsync}" Content="{DynamicResource MesenConfig_Vsync_Checkbox}" Margin="0,5" ToolTip="{DynamicResource MesenConfig_Vsync_Tooltip}" />
                        <CheckBox IsChecked="{Binding Bilinear}" Content="{DynamicResource MesenConfig_Bilinear_Checkbox}" Margin="0,5" ToolTip="{DynamicResource MesenConfig_Bilinear_Tooltip}" />
                        <Grid Margin="0,5,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Label Content="{DynamicResource MesenConfig_AspectRatio_Label}" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AspectRatioOptions}"
                                      SelectedItem="{Binding AspectRatio}"
                                      ToolTip="{DynamicResource MesenConfig_AspectRatio_Tooltip}" />
                        </Grid>
                        <Grid Margin="0,5,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Label Content="{DynamicResource MesenConfig_VideoFilter_Label}" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding VideoFilterOptions}"
                                      SelectedItem="{Binding VideoFilter}"
                                      ToolTip="{DynamicResource MesenConfig_VideoFilter_Tooltip}" />
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <!-- Audio Section -->
                <GroupBox Header="{DynamicResource MesenConfig_Audio_Header}" Margin="0,0,0,10">
                    <StackPanel Margin="5">
                        <CheckBox IsChecked="{Binding EnableAudio}" Content="{DynamicResource MesenConfig_EnableAudio_Checkbox}" Margin="0,5" ToolTip="{DynamicResource MesenConfig_EnableAudio_Tooltip}" />
                        <Label Content="{DynamicResource MesenConfig_MasterVolume_Label}" VerticalAlignment="Center" />
                        <Slider Value="{Binding MasterVolume}" Minimum="0" Maximum="100" IsSnapToTickEnabled="True" TickFrequency="1" ToolTip="{DynamicResource MesenConfig_MasterVolume_Tooltip}" />
                    </StackPanel>
                </GroupBox>

                <!-- Performance & Features Section -->
                <GroupBox Header="{DynamicResource MesenConfig_Performance_Header}" Margin="0,0,0,10">
                    <StackPanel Margin="5">
                        <CheckBox IsChecked="{Binding Rewind}" Content="{DynamicResource MesenConfig_Rewind_Checkbox}" Margin="0,5" ToolTip="{DynamicResource MesenConfig_Rewind_Tooltip}" />
                        <CheckBox IsChecked="{Binding PauseInBackground}" Content="{DynamicResource MesenConfig_PauseInBackground_Checkbox}" Margin="0,5" ToolTip="{DynamicResource MesenConfig_PauseInBackground_Tooltip}" />
                        <Label Content="{DynamicResource MesenConfig_RunAhead_Label}" VerticalAlignment="Center" />
                        <Slider Value="{Binding RunAhead}" Minimum="0" Maximum="8" IsSnapToTickEnabled="True" TickFrequency="1" ToolTip="{DynamicResource MesenConfig_RunAhead_Tooltip}" />
                    </StackPanel>
                </GroupBox>

                <!-- CRITICAL SETTING -->
                <Border Style="{StaticResource ImportantSettingBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource IMPORTANTSETTING}" Style="{StaticResource ImportantSettingHeaderStyle}" />
                        <CheckBox IsChecked="{Binding ShowBeforeLaunch}" Content="{DynamicResource MesenConfig_ShowBeforeLaunch_Checkbox}" Style="{StaticResource ImportantSettingCheckBoxStyle}" ToolTip="{DynamicResource MesenConfig_ShowBeforeLaunch_Tooltip}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="BtnSave" Content="{DynamicResource MesenConfig_Save_Button}"
                    Style="{DynamicResource DialogSecondaryButtonStyle}"
                    Command="{Binding SaveCommand}"
                    ToolTip="{DynamicResource MesenConfig_Save_Tooltip}" />
            <Button x:Name="BtnRun" Content="{DynamicResource MesenConfig_Run_Button2}"
                    Style="{DynamicResource DialogPrimaryButtonStyle}"
                    Command="{Binding RunCommand}" IsDefault="True"
                    Visibility="{Binding IsLauncherMode, Converter={StaticResource BooleanToVisibilityConverter}}"
                    ToolTip="{DynamicResource MesenConfig_Run_Tooltip}" />
            <Button Content="{DynamicResource MesenConfig_Cancel_Button}"
                    Style="{DynamicResource DialogCancelButtonStyle}"
                    ToolTip="{DynamicResource MesenConfig_Cancel_Tooltip}" />
        </StackPanel>
    </Grid>
</controls:MetroWindow>
