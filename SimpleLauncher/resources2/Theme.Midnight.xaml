<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                    xmlns:options="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options"
                    mc:Ignorable="options">

    <!-- Midnight Base Theme (Derived from Dark) -->
    <!-- We merge the Dark theme first, then override specific brushes -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Themes/Dark.Blue.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!-- Backgrounds -->
    <Color x:Key="MahApps.Colors.ThemeBackground">#FF000B1A</Color>
    <Color x:Key="MahApps.Colors.Control.Background">#FF00142E</Color>
    <Color x:Key="MahApps.Colors.Control.MouseOver">#FF00224D</Color>
    <Color x:Key="MahApps.Colors.Control.Selected">#FF00316E</Color>

    <!-- Flyouts / Overlays -->
    <Color x:Key="MahApps.Colors.Flyout.Background">#FF00142E</Color>
    
    <!-- Brushes -->
    <SolidColorBrush x:Key="MahApps.Brushes.ThemeBackground" Color="{StaticResource MahApps.Colors.ThemeBackground}" options:Freeze="True" />
    <SolidColorBrush x:Key="MahApps.Brushes.Control.Background" Color="{StaticResource MahApps.Colors.Control.Background}" options:Freeze="True" />
    <SolidColorBrush x:Key="MahApps.Brushes.Control.MouseOver" Color="{StaticResource MahApps.Colors.Control.MouseOver}" options:Freeze="True" />
    <SolidColorBrush x:Key="MahApps.Brushes.Control.Selected" Color="{StaticResource MahApps.Colors.Control.Selected}" options:Freeze="True" />
<SolidColorBrush x:Key="MahApps.Brushes.Flyout.Background" Color="{StaticResource MahApps.Colors.Flyout.Background}" options:Freeze="True" />
    
    <!-- TextBox specific brushes for proper theming -->
    <SolidColorBrush x:Key="MahApps.Brushes.TextBox.Background" Color="{StaticResource MahApps.Colors.Control.Background}" options:Freeze="True" />
    <SolidColorBrush x:Key="MahApps.Brushes.TextBox.Foreground" Color="#FFFFFFFF" options:Freeze="True" />
    <SolidColorBrush x:Key="MahApps.Brushes.TextBox.BorderBrush" Color="#FF0066CC" options:Freeze="True" />
    
    <!-- Disabled TextBox brushes - must use light text on dark background -->
    <SolidColorBrush x:Key="MahApps.Brushes.TextBox.Background.Disabled" Color="#FF00224D" options:Freeze="True" />
    <SolidColorBrush x:Key="MahApps.Brushes.TextBox.Foreground.Disabled" Color="#FFFFFFFF" options:Freeze="True" />
    <SolidColorBrush x:Key="MahApps.Brushes.TextBox.BorderBrush.Disabled" Color="#FF004080" options:Freeze="True" />
    
    <!-- ComboBox specific brushes for proper theming -->
    <SolidColorBrush x:Key="MahApps.Brushes.ComboBox.Background" Color="{StaticResource MahApps.Colors.Control.Background}" options:Freeze="True" />
    <SolidColorBrush x:Key="MahApps.Brushes.ComboBox.Foreground" Color="#FFFFFFFF" options:Freeze="True" />
    <SolidColorBrush x:Key="MahApps.Brushes.ComboBox.BorderBrush" Color="#FF0066CC" options:Freeze="True" />
    <SolidColorBrush x:Key="MahApps.Brushes.ComboBox.Background.Disabled" Color="#FF00224D" options:Freeze="True" />
    <SolidColorBrush x:Key="MahApps.Brushes.ComboBox.Foreground.Disabled" Color="#FFFFFFFF" options:Freeze="True" />
    <SolidColorBrush x:Key="MahApps.Brushes.ComboBox.BorderBrush.Disabled" Color="#FF004080" options:Freeze="True" />
    <SolidColorBrush x:Key="MahApps.Brushes.ComboBoxPopup.Background" Color="#FF00142E" options:Freeze="True" />
    <SolidColorBrush x:Key="MahApps.Brushes.ComboBoxPopup.Foreground" Color="#FFFFFFFF" options:Freeze="True" />

</ResourceDictionary>