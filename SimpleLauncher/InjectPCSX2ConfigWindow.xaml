<controls:MetroWindow x:Class="SimpleLauncher.InjectPcsx2ConfigWindow"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
                      Title="{DynamicResource Pcsx2Config_Title}"
                      Height="700" Width="700"
                      ResizeMode="CanResize"
                      WindowStartupLocation="CenterScreen">
    <controls:MetroWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </controls:MetroWindow.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Video Section -->
                <GroupBox Header="{DynamicResource Pcsx2Config_Video_Header}" Margin="0,0,0,10">
                    <StackPanel Margin="5">
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Label Content="{DynamicResource Pcsx2Config_Renderer_Label}" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding RendererDisplayNames}"
                                      SelectedItem="{Binding Pcsx2Renderer}"
                                      ToolTip="{DynamicResource Pcsx2Config_Renderer_Tooltip}" />
                        </Grid>
                        <Grid Margin="0,5,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Label Content="{DynamicResource Pcsx2Config_Upscale_Label}" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding UpscaleDisplayNames}"
                                      SelectedItem="{Binding Pcsx2UpscaleMultiplier}"
                                      ToolTip="{DynamicResource Pcsx2Config_Upscale_Tooltip}" />
                        </Grid>
                        <Grid Margin="0,5,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Label Content="{DynamicResource Pcsx2Config_Aspect_Label}" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AspectOptions}"
                                      SelectedItem="{Binding Pcsx2AspectRatio}"
                                      ToolTip="{DynamicResource Pcsx2Config_Aspect_Tooltip}" />
                        </Grid>
                        <CheckBox IsChecked="{Binding Pcsx2Vsync}" Content="{DynamicResource Pcsx2Config_Vsync_Checkbox}" Margin="0,5" ToolTip="{DynamicResource Pcsx2Config_Vsync_Tooltip}" />
                        <CheckBox IsChecked="{Binding Pcsx2EnableWidescreenPatches}" Content="{DynamicResource Pcsx2Config_WidescreenPatches_Checkbox}" Margin="0,5" ToolTip="{DynamicResource Pcsx2Config_WidescreenPatches_Tooltip}" />
                    </StackPanel>
                </GroupBox>

                <!-- General Section -->
                <GroupBox Header="{DynamicResource Pcsx2Config_General_Header}" Margin="0,0,0,10">
                    <StackPanel Margin="5">
                        <CheckBox IsChecked="{Binding Pcsx2StartFullscreen}" Content="{DynamicResource Pcsx2Config_Fullscreen_Checkbox}" Margin="0,5" ToolTip="{DynamicResource Pcsx2Config_Fullscreen_Tooltip}" />
                        <CheckBox IsChecked="{Binding Pcsx2EnableCheats}" Content="{DynamicResource Pcsx2Config_Cheats_Checkbox}" Margin="0,5" ToolTip="{DynamicResource Pcsx2Config_Cheats_Tooltip}" />
                        <Label Content="{DynamicResource Pcsx2Config_Volume_Label}" VerticalAlignment="Center" />
                        <Slider Value="{Binding Pcsx2Volume}" Minimum="0" Maximum="100" IsSnapToTickEnabled="True" TickFrequency="1" ToolTip="{DynamicResource Pcsx2Config_Volume_Tooltip}" />
                    </StackPanel>
                </GroupBox>

                <!-- Achievements Section -->
                <GroupBox Header="{DynamicResource Pcsx2Config_Achievements_Header}" Margin="0,0,0,10">
                    <StackPanel Margin="5">
                        <CheckBox IsChecked="{Binding Pcsx2AchievementsEnabled}" Content="{DynamicResource Pcsx2Config_AchEnabled_Checkbox}" Margin="0,5" ToolTip="{DynamicResource Pcsx2Config_AchEnabled_Tooltip}" />
                        <CheckBox IsChecked="{Binding Pcsx2AchievementsHardcore}" Content="{DynamicResource Pcsx2Config_AchHardcore_Checkbox}" Margin="0,5" ToolTip="{DynamicResource Pcsx2Config_AchHardcore_Tooltip}" />
                    </StackPanel>
                </GroupBox>

                <!-- CRITICAL SETTING -->
                <Border Style="{StaticResource ImportantSettingBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource IMPORTANTSETTING}" Style="{StaticResource ImportantSettingHeaderStyle}" />
                        <CheckBox IsChecked="{Binding Pcsx2ShowSettingsBeforeLaunch}" Content="{DynamicResource Pcsx2Config_ShowBeforeLaunch_Checkbox}" Style="{StaticResource ImportantSettingCheckBoxStyle}" ToolTip="{DynamicResource Pcsx2Config_ShowBeforeLaunch_Tooltip}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="BtnSave" Content="{DynamicResource Pcsx2Config_Save_Button}"
                    Style="{DynamicResource DialogSecondaryButtonStyle}"
                    Command="{Binding SaveCommand}"
                    ToolTip="{DynamicResource Pcsx2Config_Save_Tooltip}" />
            <Button x:Name="BtnRun" Content="{DynamicResource Pcsx2Config_Run_Button2}"
                    Style="{DynamicResource DialogPrimaryButtonStyle}"
                    Command="{Binding RunCommand}" IsDefault="True"
                    Visibility="{Binding IsLauncherMode, Converter={StaticResource BooleanToVisibilityConverter}}"
                    ToolTip="{DynamicResource Pcsx2Config_Run_Tooltip}" />
            <Button Content="{DynamicResource Pcsx2Config_Cancel_Button}"
                    Style="{DynamicResource DialogCancelButtonStyle}"
                    ToolTip="{DynamicResource Pcsx2Config_Cancel_Tooltip}" />
        </StackPanel>
    </Grid>
</controls:MetroWindow>
