<controls:MetroWindow x:Class="SimpleLauncher.FavoritesWindow"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
                      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d"
                      Title="{DynamicResource Favorites}"
                      Width="1200"
                      MinWidth="800"
                      Height="600"
                      MinHeight="550"
                      WindowStartupLocation="CenterScreen" x:ClassModifier="internal">
    <Window.Resources>

    </Window.Resources>

    <!-- Main container Grid that holds both the content and overlay -->
    <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4.5*" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Label Grid.Row="0" Grid.Column="0"
                   Margin="10"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Left"
                   Content="{DynamicResource ListofFavorites}" />
            <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left" Margin="10">
        <Button Content="{DynamicResource RemovefromFavorites}" Click="RemoveFavoriteButton_Click"
                Style="{DynamicResource MahApps.Styles.Button.Square}"
                Padding="5"
                Margin="0,0,10,0"
                ToolTip="{DynamicResource TooltipRemoveFromFavorites}" />
            <Button Content="{DynamicResource LaunchSelectedGame}" Click="LaunchGameClickAsync"
                    Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"
                    Padding="5"
                    IsDefault="True"
                    ToolTip="{DynamicResource TooltipLaunchFavorite}" />
            </StackPanel>
            <DataGrid Name="FavoritesDataGrid"
                      CanUserAddRows="False"
                      GridLinesVisibility="All"
                      BorderThickness="1"
                      BorderBrush="Gray"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      ScrollViewer.CanContentScroll="True"
                      Grid.Row="2"
                      Grid.Column="0"
                      Margin="10"
                      MouseRightButtonUp="FavoritesPrepareForRightClickContextMenu"
                      MouseDoubleClick="LaunchGameWithDoubleClickAsync"
                      SelectionChanged="SetPreviewImageOnSelectionChangedAsync"
                      PreviewKeyDown="FavoritesDataGrid_PreviewKeyDown">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{DynamicResource FileNameColumnHeader}" Binding="{Binding FileName}" Width="*" />
                    <DataGridTextColumn Header="{DynamicResource MachineDescriptionMameHeader}" Binding="{Binding MachineDescription}" Width="*" />
                    <DataGridTextColumn Header="{DynamicResource DefaultEmulatorHeader}" Binding="{Binding DefaultEmulator}" Width="180" />
                    <DataGridTextColumn Header="{DynamicResource SystemNameHeader}" Binding="{Binding SystemName}" Width="200" />
                </DataGrid.Columns>
            </DataGrid>

            <!-- GridSplitter between columns 0 and 2 -->
            <GridSplitter Grid.Row="0" Grid.RowSpan="3" Grid.Column="1"
                          ResizeDirection="Columns"
                          Style="{StaticResource EnhancedGridSplitterStyle}"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          ShowsPreview="True"
                          ResizeBehavior="PreviousAndNext"
                          Cursor="SizeWE" />

            <Grid Grid.Row="0" Grid.RowSpan="3" Grid.Column="2" Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Label Grid.Row="0"
                       Content="{DynamicResource PreviewImage}"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10" />
                <Border Grid.Row="1"
                        BorderBrush="Gray"
                        BorderThickness="1"
                        Padding="5">
                    <Image Name="PreviewImage"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
                </Border>
            </Grid>
        </Grid>

        <!-- Loading Overlay -->
        <ContentControl x:Name="LoadingOverlay" 
                        Template="{StaticResource LoadingOverlayTemplate}" 
                        Visibility="Collapsed" 
                        Grid.Row="0" Grid.ColumnSpan="3" />
    </Grid>
</controls:MetroWindow>