<controls:MetroWindow x:Class="SimpleLauncher.InjectCemuConfigWindow"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
                      Title="{DynamicResource CemuConfig_Title}"
                      Height="600" Width="700"
                      ResizeMode="CanResize"
                      WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Video Section -->
                <GroupBox Header="{DynamicResource CemuConfig_Video_Header}" Margin="0,0,0,10">
                    <StackPanel Margin="5">
                        <CheckBox IsChecked="{Binding Fullscreen}" Content="{DynamicResource CemuConfig_Fullscreen_Checkbox}" Margin="0,5" ToolTip="{DynamicResource CemuConfig_Fullscreen_Tooltip}" />

                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Label Content="{DynamicResource CemuConfig_Api_Label}" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      SelectedValue="{Binding GraphicApi}"
                                      SelectedValuePath="Tag"
                                      ToolTip="{DynamicResource CemuConfig_Api_Tooltip}">
                                <ComboBoxItem Content="OpenGL" Tag="0" />
                                <ComboBoxItem Content="Vulkan" Tag="1" />
                            </ComboBox>
                        </Grid>

                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Label Content="{DynamicResource CemuConfig_Vsync_Label}" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      SelectedValue="{Binding Vsync}"
                                      SelectedValuePath="Tag"
                                      ToolTip="{DynamicResource CemuConfig_Vsync_Tooltip}">
                                <ComboBoxItem Content="{DynamicResource CemuConfig_Vsync_Off}" Tag="0" />
                                <ComboBoxItem Content="{DynamicResource CemuConfig_Vsync_On}" Tag="1" />
                            </ComboBox>
                        </Grid>

                        <CheckBox IsChecked="{Binding AsyncCompile}" Content="{DynamicResource CemuConfig_AsyncCompile_Checkbox}" Margin="0,5" ToolTip="{DynamicResource CemuConfig_AsyncCompile_Tooltip}" />
                    </StackPanel>
                </GroupBox>

                <!-- Audio Section -->
                <GroupBox Header="{DynamicResource CemuConfig_Audio_Header}" Margin="0,0,0,10">
                    <StackPanel Margin="5">
                        <Label Content="{DynamicResource CemuConfig_Volume_Label}" VerticalAlignment="Center" />
                        <Slider Value="{Binding Volume}" Minimum="0" Maximum="100" IsSnapToTickEnabled="True" TickFrequency="1" ToolTip="{DynamicResource CemuConfig_Volume_Tooltip}" />
                    </StackPanel>
                </GroupBox>

                <!-- General Section -->
                <GroupBox Header="{DynamicResource CemuConfig_General_Header}" Margin="0,0,0,10">
                    <StackPanel Margin="5">
                        <CheckBox IsChecked="{Binding Discord}" Content="{DynamicResource CemuConfig_Discord_Checkbox}" Margin="0,5" ToolTip="{DynamicResource CemuConfig_Discord_Tooltip}" />
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Label Content="{DynamicResource CemuConfig_Language_Label}" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      SelectedValue="{Binding Language}"
                                      SelectedValuePath="Tag"
                                      ToolTip="{DynamicResource CemuConfig_Language_Tooltip}">
                                <ComboBoxItem Content="Japanese" Tag="0" />
                                <ComboBoxItem Content="English" Tag="1" />
                                <ComboBoxItem Content="French" Tag="2" />
                                <ComboBoxItem Content="German" Tag="3" />
                                <ComboBoxItem Content="Italian" Tag="4" />
                                <ComboBoxItem Content="Spanish" Tag="5" />
                            </ComboBox>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <!-- CRITICAL SETTING -->
                <Border Style="{StaticResource ImportantSettingBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource IMPORTANTSETTING}" Style="{StaticResource ImportantSettingHeaderStyle}" />
                        <CheckBox IsChecked="{Binding ShowBeforeLaunch}" Content="{DynamicResource CemuConfig_ShowBeforeLaunch_Checkbox}" Style="{StaticResource ImportantSettingCheckBoxStyle}" ToolTip="{DynamicResource CemuConfig_ShowBeforeLaunch_Tooltip}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="BtnSave" Content="{DynamicResource CemuConfig_Save_Button}"
                    Style="{DynamicResource DialogSecondaryButtonStyle}" Command="{Binding SaveCommand}"
                    ToolTip="{DynamicResource CemuConfig_Save_Tooltip}" />
            <Button x:Name="BtnRun" Content="{DynamicResource CemuConfig_Run_Button2}"
                    Style="{DynamicResource DialogPrimaryButtonStyle}" Command="{Binding RunCommand}" IsDefault="True"
                    Visibility="{Binding IsLauncherMode, Converter={StaticResource BooleanToVisibilityConverter}}"
                    ToolTip="{DynamicResource CemuConfig_Run_Tooltip}" />
            <Button Content="{DynamicResource CemuConfig_Cancel_Button}"
                    Style="{DynamicResource DialogCancelButtonStyle}"
                    ToolTip="{DynamicResource CemuConfig_Cancel_Tooltip}" />
        </StackPanel>
    </Grid>
</controls:MetroWindow>
