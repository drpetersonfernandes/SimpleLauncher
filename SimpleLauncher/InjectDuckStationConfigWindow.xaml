<controls:MetroWindow x:Class="SimpleLauncher.InjectDuckStationConfigWindow"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
                      Title="{DynamicResource DuckStationConfig_Title}"
                      Height="800" Width="700"
                      ResizeMode="CanResize"
                      WindowStartupLocation="CenterScreen">
    <controls:MetroWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </controls:MetroWindow.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- General Section -->
                <GroupBox Header="{DynamicResource DuckStationConfig_General_Header}" Margin="0,0,0,10">
                    <StackPanel Margin="5">
                        <CheckBox IsChecked="{Binding DuckStationStartFullscreen}" Content="{DynamicResource DuckStationConfig_Fullscreen_Checkbox}" Margin="0,5" ToolTip="{DynamicResource DuckStationConfig_Fullscreen_Tooltip}" />
                        <CheckBox IsChecked="{Binding DuckStationPauseOnFocusLoss}" Content="{DynamicResource DuckStationConfig_PauseOnFocusLoss_Checkbox}" Margin="0,5" ToolTip="{DynamicResource DuckStationConfig_PauseOnFocusLoss_Tooltip}" />
                        <CheckBox IsChecked="{Binding DuckStationSaveStateOnExit}" Content="{DynamicResource DuckStationConfig_SaveStateOnExit_Checkbox}" Margin="0,5" ToolTip="{DynamicResource DuckStationConfig_SaveStateOnExit_Tooltip}" />
                        <CheckBox IsChecked="{Binding DuckStationRewindEnable}" Content="{DynamicResource DuckStationConfig_RewindEnable_Checkbox}" Margin="0,5" ToolTip="{DynamicResource DuckStationConfig_RewindEnable_Tooltip}" />
                        <Label Content="{DynamicResource DuckStationConfig_Runahead_Label}" VerticalAlignment="Center" ToolTip="{DynamicResource DuckStationConfig_Runahead_Tooltip}" />
                        <Slider Value="{Binding DuckStationRunaheadFrameCount}" Minimum="0" Maximum="8" IsSnapToTickEnabled="True" TickFrequency="1" ToolTip="{DynamicResource DuckStationConfig_Runahead_Tooltip}" />
                    </StackPanel>
                </GroupBox>

                <!-- Video/GPU Section -->
                <GroupBox Header="{DynamicResource DuckStationConfig_Video_Header}" Margin="0,0,0,10">
                    <StackPanel Margin="5">
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Label Content="{DynamicResource DuckStationConfig_Renderer_Label}" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding RendererOptions}"
                                      SelectedItem="{Binding DuckStationRenderer}"
                                      ToolTip="{DynamicResource DuckStationConfig_Renderer_Tooltip}" />
                        </Grid>
                        <Grid Margin="0,5,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Label Content="{DynamicResource DuckStationConfig_ResolutionScale_Label}" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding ResolutionScaleOptions}"
                                      SelectedValue="{Binding DuckStationResolutionScale}"
                                      SelectedValuePath="Tag"
                                      DisplayMemberPath="Display"
                                      ToolTip="{DynamicResource DuckStationConfig_ResolutionScale_Tooltip}" />
                        </Grid>
                        <Grid Margin="0,5,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Label Content="{DynamicResource DuckStationConfig_TextureFilter_Label}" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding TextureFilterOptions}"
                                      SelectedItem="{Binding DuckStationTextureFilter}"
                                      ToolTip="{DynamicResource DuckStationConfig_TextureFilter_Tooltip}" />
                        </Grid>
                        <Grid Margin="0,5,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Label Content="{DynamicResource DuckStationConfig_AspectRatio_Label}" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AspectRatioOptions}"
                                      SelectedItem="{Binding DuckStationAspectRatio}"
                                      ToolTip="{DynamicResource DuckStationConfig_AspectRatio_Tooltip}" />
                        </Grid>
                        <CheckBox IsChecked="{Binding DuckStationWidescreenHack}" Content="{DynamicResource DuckStationConfig_WidescreenHack_Checkbox}" Margin="0,5" ToolTip="{DynamicResource DuckStationConfig_WidescreenHack_Tooltip}" />
                        <CheckBox IsChecked="{Binding DuckStationPgxpEnable}" Content="{DynamicResource DuckStationConfig_PgxpEnable_Checkbox}" Margin="0,5" ToolTip="{DynamicResource DuckStationConfig_PgxpEnable_Tooltip}" />
                        <CheckBox IsChecked="{Binding DuckStationVsync}" Content="{DynamicResource DuckStationConfig_Vsync_Checkbox}" Margin="0,5" ToolTip="{DynamicResource DuckStationConfig_Vsync_Tooltip}" />
                    </StackPanel>
                </GroupBox>

                <!-- Audio Section -->
                <GroupBox Header="{DynamicResource DuckStationConfig_Audio_Header}" Margin="0,0,0,10">
                    <StackPanel Margin="5">
                        <CheckBox IsChecked="{Binding DuckStationOutputMuted}" Content="{DynamicResource DuckStationConfig_Mute_Checkbox}" Margin="0,5" ToolTip="{DynamicResource DuckStationConfig_Mute_Tooltip}" />
                        <Label Content="{DynamicResource DuckStationConfig_Volume_Label}" VerticalAlignment="Center" ToolTip="{DynamicResource DuckStationConfig_Volume_Tooltip}" />
                        <Slider Value="{Binding DuckStationOutputVolume}" Minimum="0" Maximum="100" IsSnapToTickEnabled="True" TickFrequency="1" ToolTip="{DynamicResource DuckStationConfig_Volume_Tooltip}" />
                    </StackPanel>
                </GroupBox>

                <!-- CRITICAL SETTING -->
                <Border Style="{StaticResource ImportantSettingBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource IMPORTANTSETTING}" Style="{StaticResource ImportantSettingHeaderStyle}" />
                        <CheckBox IsChecked="{Binding DuckStationShowSettingsBeforeLaunch}" Content="{DynamicResource DuckStationConfig_ShowBeforeLaunch_Checkbox}" Style="{StaticResource ImportantSettingCheckBoxStyle}" ToolTip="{DynamicResource DuckStationConfig_ShowBeforeLaunch_Tooltip}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="BtnSave" Content="{DynamicResource DuckStationConfig_Save_Button}"
                    Style="{DynamicResource DialogSecondaryButtonStyle}"
                    Command="{Binding SaveCommand}"
                    ToolTip="{DynamicResource DuckStationConfig_Save_Tooltip}" />
            <Button x:Name="BtnRun" Content="{DynamicResource DuckStationConfig_Run_Button2}"
                    Style="{DynamicResource DialogPrimaryButtonStyle}"
                    Command="{Binding RunCommand}" IsDefault="True"
                    Visibility="{Binding IsLauncherMode, Converter={StaticResource BooleanToVisibilityConverter}}"
                    ToolTip="{DynamicResource DuckStationConfig_Run_Tooltip}" />
            <Button Content="{DynamicResource DuckStationConfig_Cancel_Button}"
                    Style="{DynamicResource DialogCancelButtonStyle}"
                    ToolTip="{DynamicResource DuckStationConfig_Cancel_Tooltip}" />
        </StackPanel>
    </Grid>
</controls:MetroWindow>
