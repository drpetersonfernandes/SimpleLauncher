                        <Image Source="pack://application:,,,/images/playhistory.png" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,5,0" />
                        <Label Content="{DynamicResource Playtime}" VerticalAlignment="Center" Padding="0" />
                        <Label Content="{Binding PlayTime}" VerticalAlignment="Center" Padding="5,0,0,0" />
                    </StackPanel>
                    <!-- Dummy usage to suppress "Resource 'SystemButtonStyle' is never used" warning -->
                    <Button Style="{StaticResource SystemButtonStyle}" Visibility="Collapsed" Width="0" Height="0" />
                </StackPanel>

            </Grid>
        </Grid>

        <!-- Loading Overlay stays OUTSIDE MainContentGrid so it remains active -->
        <ContentControl x:Name="LoadingOverlay"
                        Grid.Row="0"
                        Panel.ZIndex="9999"
                        Template="{StaticResource LoadingOverlayTemplate}"
                        Visibility="Collapsed" />
    </Grid>
</controls:MetroWindow>