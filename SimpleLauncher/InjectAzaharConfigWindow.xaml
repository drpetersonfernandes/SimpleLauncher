<controls:MetroWindow x:Class="SimpleLauncher.InjectAzaharConfigWindow"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
                      Title="{DynamicResource AzaharConfig_Title}"
                      Height="650" Width="700"
                      WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <GroupBox Header="{DynamicResource AzaharConfig_Video_Header}" Margin="0,0,0,10">
                    <StackPanel Margin="5">
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Label Content="{DynamicResource AzaharConfig_GraphicsApi_Label}" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      SelectedValue="{Binding GraphicsApi}"
                                      SelectedValuePath="Tag"
                                      ToolTip="{DynamicResource AzaharConfig_GraphicsApi_Tooltip}">
                                <ComboBoxItem Content="OpenGL" Tag="0" />
                                <ComboBoxItem Content="Vulkan" Tag="2" />
                            </ComboBox>
                        </Grid>

                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Label Content="{DynamicResource AzaharConfig_Resolution_Label}" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      SelectedValue="{Binding Resolution}"
                                      SelectedValuePath="Tag"
                                      ToolTip="{DynamicResource AzaharConfig_Resolution_Tooltip}">
                                <ComboBoxItem Content="Auto" Tag="0" />
                                <ComboBoxItem Content="1x Native" Tag="1" />
                                <ComboBoxItem Content="2x (800x480)" Tag="2" />
                                <ComboBoxItem Content="3x (1200x720)" Tag="3" />
                                <ComboBoxItem Content="4x (1600x960)" Tag="4" />
                            </ComboBox>
                        </Grid>

                        <CheckBox IsChecked="{Binding Fullscreen}" Content="{DynamicResource AzaharConfig_Fullscreen_Checkbox}" Margin="0,5" ToolTip="{DynamicResource AzaharConfig_Fullscreen_Tooltip}" />
                        <CheckBox IsChecked="{Binding Vsync}" Content="{DynamicResource AzaharConfig_Vsync_Checkbox}" Margin="0,5" ToolTip="{DynamicResource AzaharConfig_Vsync_Tooltip}" />
                        <CheckBox IsChecked="{Binding AsyncShader}" Content="{DynamicResource AzaharConfig_AsyncShader_Checkbox}" Margin="0,5" ToolTip="{DynamicResource AzaharConfig_AsyncShader_Tooltip}" />
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="{DynamicResource AzaharConfig_System_Header}" Margin="0,0,0,10">
                    <StackPanel Margin="5">
                        <CheckBox IsChecked="{Binding IsNew3Ds}" Content="{DynamicResource AzaharConfig_New3DS_Checkbox}" Margin="0,5" ToolTip="{DynamicResource AzaharConfig_New3DS_Tooltip}" />
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Label Content="{DynamicResource AzaharConfig_Layout_Label}" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      SelectedValue="{Binding Layout}"
                                      SelectedValuePath="Tag"
                                      ToolTip="{DynamicResource AzaharConfig_Layout_Tooltip}">
                                <ComboBoxItem Content="Default" Tag="0" />
                                <ComboBoxItem Content="Single Screen" Tag="1" />
                                <ComboBoxItem Content="Large Screen" Tag="2" />
                                <ComboBoxItem Content="Side by Side" Tag="3" />
                            </ComboBox>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="{DynamicResource AzaharConfig_Audio_Header}" Margin="0,0,0,10">
                    <StackPanel Margin="5">
                        <Label Content="{DynamicResource AzaharConfig_Volume_Label}" VerticalAlignment="Center" />
                        <Slider Value="{Binding Volume}" Minimum="0" Maximum="100" IsSnapToTickEnabled="True" TickFrequency="1" ToolTip="{DynamicResource AzaharConfig_Volume_Tooltip}" />
                        <CheckBox IsChecked="{Binding AudioStretching}" Content="{DynamicResource AzaharConfig_AudioStretching_Checkbox}" Margin="0,5" ToolTip="{DynamicResource AzaharConfig_AudioStretching_Tooltip}" />
                    </StackPanel>
                </GroupBox>

                <!-- CRITICAL SETTING -->
                <Border Style="{StaticResource ImportantSettingBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource IMPORTANTSETTING}" Style="{StaticResource ImportantSettingHeaderStyle}" />
                        <CheckBox IsChecked="{Binding ShowBeforeLaunch}" Content="{DynamicResource AzaharConfig_ShowBeforeLaunch_Checkbox}" Style="{StaticResource ImportantSettingCheckBoxStyle}" ToolTip="{DynamicResource AzaharConfig_ShowBeforeLaunch_Tooltip}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="BtnSave" Content="{DynamicResource AzaharConfig_Save_Button}"
                    Style="{DynamicResource DialogSecondaryButtonStyle}" Command="{Binding SaveCommand}"
                    ToolTip="{DynamicResource AzaharConfig_Save_Tooltip}" />
            <Button x:Name="BtnRun" Content="{DynamicResource AzaharConfig_Run_Button2}"
                    Style="{DynamicResource DialogPrimaryButtonStyle}" Command="{Binding RunCommand}" IsDefault="True"
                    Visibility="{Binding IsLauncherMode, Converter={StaticResource BooleanToVisibilityConverter}}"
                    ToolTip="{DynamicResource AzaharConfig_Run_Tooltip}" />
            <Button Content="{DynamicResource AzaharConfig_Cancel_Button}"
                    Style="{DynamicResource DialogCancelButtonStyle}"
                    ToolTip="{DynamicResource AzaharConfig_Cancel_Tooltip}" />
        </StackPanel>
    </Grid>
</controls:MetroWindow>
