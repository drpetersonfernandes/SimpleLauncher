<controls:MetroWindow x:Class="SimpleLauncher.SetLinksWindow"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
                      Title="{DynamicResource EditLinks}"
                      Width="600"
                      MinWidth="600"
                      Height="270"
                      ResizeMode="NoResize"
                      WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Explanation -->
        <TextBlock
            Grid.Row="0"
            Grid.Column="0"
            Grid.ColumnSpan="3"
            Margin="10,20,10,10"
            Text="{DynamicResource YoucandefinecustomURL}"
            TextWrapping="Wrap"
            HorizontalAlignment="Left"
            TextAlignment="Justify" />

        <!-- Video Link -->
        <Label
            Margin="10"
            Grid.Row="1"
            Grid.Column="0"
            VerticalAlignment="Center"
            Content="{DynamicResource VideoLinkButton}" />
        <Image
            Grid.Row="1"
            Grid.Column="1"
            Width="22"
            Height="22"
            VerticalAlignment="Center"
            HorizontalAlignment="Left"
            Source="pack://application:,,,/images/video.png" />
        <TextBox
            Margin="10"
            Grid.Row="1"
            Grid.Column="2"
            HorizontalAlignment="Stretch"
            Text="{Binding VideoUrl, UpdateSourceTrigger=PropertyChanged}"
            ToolTip="{DynamicResource TooltipVideoLink}" />

        <!-- Info Link -->
        <Label
            Margin="10"
            Grid.Row="2"
            Grid.Column="0"
            VerticalAlignment="Center"
            Content="{DynamicResource InfoLinkButton}" />
        <Image
            Grid.Row="2"
            Grid.Column="1"
            Width="22"
            Height="22"
            VerticalAlignment="Center"
            HorizontalAlignment="Left"
            Source="pack://application:,,,/images/info.png" />
        <TextBox
            Margin="10"
            Grid.Row="2"
            Grid.Column="2"
            Text="{Binding InfoUrl, UpdateSourceTrigger=PropertyChanged}"
            ToolTip="{DynamicResource TooltipInfoLink}" />

        <Grid Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Save Button -->
            <Button
                Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"
                Grid.Column="0"
                Margin="10"
                Padding="10"
                HorizontalAlignment="Right"
                IsDefault="True"
                Command="{Binding SaveCommand}"
                Content="{DynamicResource SaveorUpdateLinks}"
                ToolTip="{DynamicResource TooltipSaveLinks}" />

            <!-- Revert Button -->
            <Button
                Style="{DynamicResource MahApps.Styles.Button.Square}"
                Grid.Column="1"
                Margin="10"
                Padding="10"
                HorizontalAlignment="Center"
                Command="{Binding RevertCommand}"
                Content="{DynamicResource ReverttoDefaultValues}"
                ToolTip="{DynamicResource TooltipRevertLinks}" />

            <!-- Cancel Button -->
            <Button
                Style="{DynamicResource DialogCancelButtonStyle}"
                Grid.Column="2"
                Margin="10"
                HorizontalAlignment="Left"
                Command="{Binding CancelCommand}"
                Content="{DynamicResource Cancel}"
                ToolTip="{DynamicResource TooltipClose}" />
        </Grid>

    </Grid>
</controls:MetroWindow>