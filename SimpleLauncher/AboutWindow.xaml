<controls:MetroWindow x:Class="SimpleLauncher.AboutWindow"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
                      Title="{DynamicResource About}"
                      Width="450"
                      Height="420"
                      ResizeMode="NoResize"
                      WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel
            Grid.Row="0"
            Margin="10"
            HorizontalAlignment="Center"
            Orientation="Horizontal">
            <Image
                Width="150"
                Height="150"
                Source="pack://application:,,,/images/logo2.png" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="10">
            <TextBlock FontWeight="Bold" Text="Simple Launcher" />
            <TextBlock Text="{DynamicResource Anopensourceemulatorfrontend}" />
            <TextBlock Margin="0,10,0,0" Text="{Binding AppVersion}" />
            <TextBlock Margin="0,10,0,0">
                <Hyperlink Command="{Binding OpenWebsiteCommand}" CommandParameter="https://www.purelogiccode.com" ToolTip="{DynamicResource TooltipNavigateToWebsite}">https://www.purelogiccode.com</Hyperlink>
            </TextBlock>
            <TextBlock Margin="0,10,0,10">
                <Hyperlink Command="{Binding OpenWebsiteCommand}" CommandParameter="https://github.com/drpetersonfernandes/SimpleLauncher" ToolTip="{DynamicResource TooltipNavigateToGithub}">
                    https://github.com/drpetersonfernandes/SimpleLauncher
                </Hyperlink>
            </TextBlock>
        </StackPanel>

        <StackPanel
            Grid.Row="2"
            Margin="10"
            HorizontalAlignment="Center"
            Orientation="Horizontal">
            <Button
                Style="{DynamicResource MahApps.Styles.Button.Square}"
                Command="{Binding CheckForUpdatesCommand}"
                Content="{DynamicResource CheckForUpdate}"
                ToolTip="{DynamicResource TooltipCheckForUpdate}" />
            <Button
                Style="{DynamicResource MahApps.Styles.Button.Square}"
                Margin="10,0,0,0"
                Command="{Binding OpenUpdateHistoryCommand}"
                Content="{DynamicResource UpdateHistory}"
                ToolTip="{DynamicResource TooltipUpdateHistory}" />
            <Button
                Style="{DynamicResource MahApps.Styles.Button.Square}"
                Margin="10,0,0,0"
                Command="{Binding CloseCommand}"
                Content="{DynamicResource Close}"
                ToolTip="{DynamicResource TooltipClose}" />
        </StackPanel>
    </Grid>
</controls:MetroWindow>
