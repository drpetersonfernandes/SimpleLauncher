<Page x:Class="SimpleLauncher.Pages.PlayHistoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="{DynamicResource PlayHistory}">
    <Grid>
        <!-- Main Content Grid -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4.5*" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Label Grid.Row="0" Grid.Column="0"
                   Margin="10"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Left"
                   Content="{DynamicResource PlayHistory}"
                   FontSize="22" FontWeight="Bold" Foreground="{DynamicResource MahApps.Brushes.Text}"/>
            <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left" Margin="10">
                <Button Content="{DynamicResource RemovefromHistory}" Click="RemoveHistoryItemButton_Click"
                        Style="{DynamicResource SecondaryActionButtonStyle}"
                        ToolTip="{DynamicResource TooltipRemoveFromHistory}"
                        AutomationProperties.Name="{DynamicResource RemovefromHistory}" />
                <Button Content="{DynamicResource RemoveAllfromHistory}" Click="RemoveAllHistoryItemButton_Click"
                        Style="{DynamicResource SecondaryActionButtonStyle}"
                        ToolTip="{DynamicResource TooltipRemoveAllFromHistory}"
                        AutomationProperties.Name="{DynamicResource RemoveAllfromHistory}" />
                <Button Content="{DynamicResource LaunchSelectedGame}" Click="LaunchGameClickAsync"
                        Style="{DynamicResource PrimaryActionButtonStyle}"
                        IsDefault="True"
                        ToolTip="{DynamicResource TooltipLaunchFromHistory}"
                        AutomationProperties.Name="{DynamicResource LaunchSelectedGame}" />
                <Button Content="{DynamicResource SortByDate}" Click="SortByDate_Click"
                        Style="{DynamicResource SecondaryActionButtonStyle}"
                        ToolTip="{DynamicResource TooltipSortByDate}"
                        AutomationProperties.Name="{DynamicResource SortByDate}" />
                <Button Content="{DynamicResource SortByPlayTime}" Click="SortByTotalPlayTime_Click"
                        Style="{DynamicResource SecondaryActionButtonStyle}"
                        ToolTip="{DynamicResource TooltipSortByPlayTime}"
                        AutomationProperties.Name="{DynamicResource SortByPlayTime}" />
                <Button Content="{DynamicResource SortByTimesPlayed}" Click="SortByTimesPlayed_Click"
                        Style="{DynamicResource SecondaryActionButtonStyle}"
                        ToolTip="{DynamicResource TooltipSortByTimesPlayed}"
                        AutomationProperties.Name="{DynamicResource SortByTimesPlayed}" />
            </StackPanel>
            <DataGrid Name="PlayHistoryDataGrid"
                      CanUserAddRows="False"
                      GridLinesVisibility="All"
                      BorderThickness="1"
                      BorderBrush="{DynamicResource MahApps.Brushes.Gray7}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      ScrollViewer.CanContentScroll="True"
                      Grid.Row="2"
                      Grid.Column="0"
                      Margin="10"
                      MouseRightButtonUp="PlayHistoryPrepareForRightClickContext"
                      MouseDoubleClick="LaunchGameWithDoubleClickAsync"
                      SelectionChanged="SetPreviewImageOnSelectionChangedAsync"
                      PreviewKeyDown="DeleteHistoryItemWithDelButton">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{DynamicResource FileNameColumnHeader}" Binding="{Binding DisplayName}" Width="*" />
                    <DataGridTextColumn Header="{DynamicResource MachineDescriptionMameHeader}" Binding="{Binding MachineDescription}" Width="*" />
                    <DataGridTextColumn Header="{DynamicResource SystemNameHeader}" Binding="{Binding SystemName}" Width="160" />
                    <DataGridTextColumn Header="{DynamicResource DefaultEmulatorHeader}" Binding="{Binding DefaultEmulator}" Width="180" />
                    <DataGridTextColumn Header="{DynamicResource TimesPlayedColumnHeader}" Binding="{Binding TimesPlayed}" Width="110" />
                    <DataGridTextColumn Header="{DynamicResource PlayTimeColumnHeader}" Binding="{Binding FormattedPlayTime}" Width="110" />
                    <DataGridTextColumn Header="{DynamicResource LastPlayedDateColumnHeader}" Binding="{Binding LastPlayDate}" Width="130" />
                    <DataGridTextColumn Header="{DynamicResource LastPlayedTimeColumnHeader}" Binding="{Binding LastPlayTime}" Width="130" />
                </DataGrid.Columns>
            </DataGrid>

            <!-- GridSplitter between columns 0 and 2 -->
            <GridSplitter Grid.Row="0" Grid.RowSpan="3" Grid.Column="1"
                          ResizeDirection="Columns"
                          Style="{StaticResource EnhancedGridSplitterStyle}"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          ShowsPreview="True"
                          ResizeBehavior="PreviousAndNext"
                          Cursor="SizeWE" />

            <Grid Grid.Row="0" Grid.RowSpan="3" Grid.Column="2" Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Label Grid.Row="0"
                       Content="{DynamicResource PreviewImage}"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10" />
                <Border Grid.Row="1"
                        BorderBrush="{DynamicResource MahApps.Brushes.Gray7}"
                        BorderThickness="1"
                        Padding="5">
                    <Image Name="PreviewImage"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
                </Border>
            </Grid>
        </Grid>

        <!-- Loading Overlay -->
        <ContentControl x:Name="LoadingOverlay"
                        Template="{StaticResource LoadingOverlayTemplate}"
                        Visibility="Collapsed"
                        Button.Click="EmergencyOverlayRelease_Click"
                        Grid.Row="0" Grid.ColumnSpan="3" />
    </Grid>

</Page>
