<controls:MetroWindow x:Class="SimpleLauncher.InjectMameConfigWindow"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
                      Title="{DynamicResource MameConfig_Title}"
                      Height="600" Width="700"
                      ResizeMode="CanResize"
                      WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Video Section -->
                <GroupBox Header="{DynamicResource MameConfig_VideoDisplay_Header}" Margin="0,0,0,10">
                    <StackPanel Margin="5">
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Label Content="{DynamicResource MameConfig_VideoMode_Label}" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding VideoOptions}"
                                      SelectedItem="{Binding MameVideo}"
                                      ToolTip="{DynamicResource MameConfig_VideoMode_Tooltip}" />
                        </Grid>
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Label Content="{DynamicResource MameConfig_BgfxBackend_Label}" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding BgfxBackendOptions}"
                                      SelectedItem="{Binding MameBgfxBackend}"
                                      ToolTip="{DynamicResource MameConfig_BgfxBackend_Tooltip}" />
                        </Grid>
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Label Content="{DynamicResource MameConfig_BgfxShader_Label}" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1" IsEditable="True"
                                      ItemsSource="{Binding BgfxChainsOptions}"
                                      Text="{Binding MameBgfxScreenChains}"
                                      ToolTip="{DynamicResource MameConfig_BgfxShader_Tooltip}" />
                        </Grid>
                        <CheckBox IsChecked="{Binding MameFilter}" Content="{DynamicResource MameConfig_BilinearFiltering_Checkbox}" Margin="0,5" ToolTip="{DynamicResource MameConfig_BilinearFiltering_Tooltip}" />
                        <CheckBox IsChecked="{Binding MameWindow}" Content="{DynamicResource MameConfig_RunInWindow_Checkbox}" Margin="0,5" ToolTip="{DynamicResource MameConfig_RunInWindow_Tooltip}" />
                        <CheckBox IsChecked="{Binding MameMaximize}" Content="{DynamicResource MameConfig_Maximize_Checkbox}" Margin="0,5" ToolTip="{DynamicResource MameConfig_Maximize_Tooltip}" />
                        <CheckBox IsChecked="{Binding MameKeepAspect}" Content="{DynamicResource MameConfig_EnforceAspectRatio_Checkbox}" Margin="0,5" ToolTip="{DynamicResource MameConfig_EnforceAspectRatio_Tooltip}" />
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="{DynamicResource MameConfig_PerformanceAdvanced_Header}" Margin="0,0,0,10">
                    <StackPanel Margin="5">
                        <CheckBox IsChecked="{Binding MameAutoframeskip}" Content="{DynamicResource MameConfig_AutoFrameskip_Checkbox}" Margin="0,5" ToolTip="{DynamicResource MameConfig_AutoFrameskip_Tooltip}" />
                        <CheckBox IsChecked="{Binding MameCheat}" Content="{DynamicResource MameConfig_EnableCheats_Checkbox}" Margin="0,5" ToolTip="{DynamicResource MameConfig_EnableCheats_Tooltip}" />
                        <CheckBox IsChecked="{Binding MameRewind}" Content="{DynamicResource MameConfig_EnableRewind_Checkbox}" Margin="0,5" ToolTip="{DynamicResource MameConfig_EnableRewind_Tooltip}" />
                        <CheckBox IsChecked="{Binding MameNvramSave}" Content="{DynamicResource MameConfig_SaveNvram_Checkbox}" Margin="0,5" ToolTip="{DynamicResource MameConfig_SaveNvram_Tooltip}" />
                    </StackPanel>
                </GroupBox>

                <!-- UX Section -->
                <GroupBox Header="{DynamicResource MameConfig_UserExperience_Header}" Margin="0,0,0,10">
                    <StackPanel Margin="5">
                        <CheckBox IsChecked="{Binding MameSkipGameInfo}" Content="{DynamicResource MameConfig_SkipGameInfo_Checkbox}" Margin="0,5"
                                  ToolTip="{DynamicResource MameConfig_SkipGameInfo_Tooltip}" />
                        <CheckBox IsChecked="{Binding MameAutosave}" Content="{DynamicResource MameConfig_AutosaveState_Checkbox}" Margin="0,5"
                                  ToolTip="{DynamicResource MameConfig_AutosaveState_Tooltip}" />
                        <CheckBox IsChecked="{Binding MameConfirmQuit}" Content="{DynamicResource MameConfig_ConfirmQuit_Checkbox}" Margin="0,5"
                                  ToolTip="{DynamicResource MameConfig_ConfirmQuit_Tooltip}" />
                    </StackPanel>
                </GroupBox>

                <!-- Input Section -->
                <GroupBox Header="{DynamicResource MameConfig_Input_Header}" Margin="0,0,0,10">
                    <StackPanel Margin="5">
                        <CheckBox IsChecked="{Binding MameJoystick}" Content="{DynamicResource MameConfig_EnableJoystick_Checkbox}" Margin="0,5" ToolTip="{DynamicResource MameConfig_EnableJoystick_Tooltip}" />
                    </StackPanel>
                </GroupBox>

                <!-- CRITICAL SETTING -->
                <Border Style="{StaticResource ImportantSettingBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource IMPORTANTSETTING}" Style="{StaticResource ImportantSettingHeaderStyle}" />
                        <CheckBox IsChecked="{Binding MameShowSettingsBeforeLaunch}" Content="{DynamicResource MameConfig_ShowBeforeLaunch_Checkbox}" Style="{StaticResource ImportantSettingCheckBoxStyle}" ToolTip="{DynamicResource MameConfig_ShowBeforeLaunch_Tooltip}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="BtnSave" Content="{DynamicResource MameConfig_Save_Button}"
                    Style="{DynamicResource DialogSecondaryButtonStyle}"
                    Command="{Binding SaveCommand}"
                    ToolTip="{DynamicResource MameConfig_Save_Tooltip}" />
            <Button x:Name="BtnRun" Content="{DynamicResource MameConfig_Run_Button2}"
                    Style="{DynamicResource DialogPrimaryButtonStyle}"
                    Command="{Binding RunCommand}" IsDefault="True"
                    Visibility="{Binding IsLauncherMode, Converter={StaticResource BooleanToVisibilityConverter}}"
                    ToolTip="{DynamicResource MameConfig_Run_Tooltip}" />
            <Button Content="{DynamicResource MameConfig_Cancel_Button}"
                    Style="{DynamicResource DialogCancelButtonStyle}"
                    Command="{Binding CancelCommand}"
                    ToolTip="{DynamicResource MameConfig_Cancel_Tooltip}" />
        </StackPanel>
    </Grid>
</controls:MetroWindow>
