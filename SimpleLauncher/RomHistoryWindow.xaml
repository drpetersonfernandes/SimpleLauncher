<controls:MetroWindow x:Class="SimpleLauncher.RomHistoryWindow"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
                      xmlns:md="clr-namespace:MdXaml;assembly=MdXaml"
                      Title="{DynamicResource RomHistory}"
                      Width="1000"
                      Height="600"
                      WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBox Grid.Row="0"
                 IsReadOnly="True"
                 FontWeight="Bold"
                 FontSize="16"
                 Margin="0"
                 HorizontalAlignment="Center"
                 HorizontalScrollBarVisibility="Disabled"
                 Text="{Binding RomNameText}"
                 ToolTip="{DynamicResource RomName}" />
        <TextBox Grid.Row="1"
                 IsReadOnly="True"
                 FontWeight="Bold"
                 FontSize="16"
                 Margin="0"
                 HorizontalAlignment="Center"
                 HorizontalScrollBarVisibility="Disabled"
                 Text="{Binding RomDescriptionText}"
                 Visibility="{Binding DescriptionVisibility}"
                 ToolTip="{DynamicResource RomDescription}" />
        <md:MarkdownScrollViewer x:Name="HistoryMarkdownViewer"
                                 Grid.Row="2"
                                 Margin="0,20,0,0"
                                 VerticalAlignment="Top"
                                 Markdown="{Binding HistoryMarkdown}"
                                 MarkdownStyle="{StaticResource ThemeAwareMarkdownStyle}"
                                 ToolTip="{DynamicResource TooltipRomHistoryViewer}" />
    </Grid>
</controls:MetroWindow>