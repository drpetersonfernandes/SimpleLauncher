<controls:MetroWindow x:Class="SimpleLauncher.RomHistoryWindow"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
                      xmlns:md="clr-namespace:MdXaml;assembly=MdXaml"
                      Title="{DynamicResource RomHistory}"
                      Width="1000"
                      Height="600"
                      WindowStartupLocation="CenterScreen">
    <controls:MetroWindow.Resources>
        <Style x:Key="ThemeAwareMarkdownStyle" TargetType="FlowDocument">
            <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.ThemeForeground}" />
            <Setter Property="Background" Value="{DynamicResource MahApps.Brushes.ThemeBackground}" />
            <Style.Resources>
                <Style TargetType="Paragraph">
                    <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.ThemeForeground}" />
                </Style>
                <Style TargetType="Run">
                    <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.ThemeForeground}" />
                </Style>
                <Style TargetType="Hyperlink">
                    <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.AccentBase}" />
                </Style>
                <Style TargetType="List">
                    <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.ThemeForeground}" />
                </Style>
                <Style TargetType="ListItem">
                    <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.ThemeForeground}" />
                </Style>
                <Style TargetType="Table">
                    <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.ThemeForeground}" />
                </Style>
                <Style TargetType="TableCell">
                    <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.ThemeForeground}" />
                </Style>
                <Style TargetType="Section">
                    <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.ThemeForeground}" />
                </Style>
            </Style.Resources>
        </Style>
    </controls:MetroWindow.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBox Name="RomNameTextBox"
                 Grid.Row="0"
                 IsReadOnly="True"
                 FontWeight="Bold"
                 FontSize="16"
                 Margin="0"
                 HorizontalAlignment="Center"
                 HorizontalScrollBarVisibility="Disabled"
                 ToolTip="{DynamicResource RomName}" />
        <TextBox Name="RomDescriptionTextBox"
                 Grid.Row="1"
                 IsReadOnly="True"
                 FontWeight="Bold"
                 FontSize="16"
                 Margin="0"
                 HorizontalAlignment="Center"
                 HorizontalScrollBarVisibility="Disabled"
                 ToolTip="{DynamicResource RomDescription}" />
        <md:MarkdownScrollViewer x:Name="HistoryMarkdownViewer"
                                 Grid.Row="2"
                                 Margin="0,20,0,0"
                                 VerticalAlignment="Top"
                                 MarkdownStyle="{StaticResource ThemeAwareMarkdownStyle}" />
    </Grid>
</controls:MetroWindow>
