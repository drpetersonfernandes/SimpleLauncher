<controls:MetroWindow x:Class="SimpleLauncher.InjectYumirConfigWindow"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
                      Title="{DynamicResource YumirConfig_Title}"
                      Height="650" Width="700"
                      ResizeMode="CanResize"
                      WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Video Section -->
                <GroupBox Header="{DynamicResource YumirConfig_Video_Header}" Margin="0,0,0,10">
                    <StackPanel Margin="5">
                        <CheckBox IsChecked="{Binding YumirFullscreen}" Content="{DynamicResource YumirConfig_Fullscreen_Checkbox}" Margin="0,5" ToolTip="{DynamicResource YumirConfig_Fullscreen_Tooltip}" />
                        <CheckBox IsChecked="{Binding YumirForceAspectRatio}" Content="{DynamicResource YumirConfig_ForceAspect_Checkbox}" Margin="0,5" ToolTip="{DynamicResource YumirConfig_ForceAspect_Tooltip}" />
                        <CheckBox IsChecked="{Binding YumirReduceLatency}" Content="{DynamicResource YumirConfig_ReduceLatency_Checkbox}" Margin="0,5" ToolTip="{DynamicResource YumirConfig_ReduceLatency_Tooltip}" />

                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Label Content="{DynamicResource YumirConfig_ForcedAspect_Label}" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding ForcedAspectOptions}"
                                      SelectedItem="{Binding YumirForcedAspect}"
                                      ToolTip="{DynamicResource YumirConfig_ForcedAspect_Tooltip}" />
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <!-- Audio Section -->
                <GroupBox Header="{DynamicResource YumirConfig_Audio_Header}" Margin="0,0,0,10">
                    <StackPanel Margin="5">
                        <CheckBox IsChecked="{Binding YumirMute}" Content="{DynamicResource YumirConfig_Mute_Checkbox}" Margin="0,5" ToolTip="{DynamicResource YumirConfig_Mute_Tooltip}" />
                        <Label Content="{DynamicResource YumirConfig_Volume_Label}" VerticalAlignment="Center" />
                        <Slider Value="{Binding YumirVolume}" Minimum="0.0" Maximum="1.0" IsSnapToTickEnabled="True" TickFrequency="0.05" ToolTip="{DynamicResource YumirConfig_Volume_Tooltip}" />
                    </StackPanel>
                </GroupBox>

                <!-- System Section -->
                <GroupBox Header="{DynamicResource YumirConfig_System_Header}" Margin="0,0,0,10">
                    <StackPanel Margin="5">
                        <CheckBox IsChecked="{Binding YumirAutoDetectRegion}" Content="{DynamicResource YumirConfig_AutoRegion_Checkbox}" Margin="0,5" ToolTip="{DynamicResource YumirConfig_AutoRegion_Tooltip}" />
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Label Content="{DynamicResource YumirConfig_VideoStandard_Label}" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding VideoStandardOptions}"
                                      SelectedItem="{Binding YumirVideoStandard}"
                                      ToolTip="{DynamicResource YumirConfig_VideoStandard_Tooltip}" />
                        </Grid>
                        <CheckBox IsChecked="{Binding YumirPauseWhenUnfocused}" Content="{DynamicResource YumirConfig_PauseUnfocused_Checkbox}" Margin="0,5" ToolTip="{DynamicResource YumirConfig_PauseUnfocused_Tooltip}" />
                    </StackPanel>
                </GroupBox>

                <!-- CRITICAL SETTING -->
                <Border Style="{StaticResource ImportantSettingBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource IMPORTANTSETTING}" Style="{StaticResource ImportantSettingHeaderStyle}" />
                        <CheckBox IsChecked="{Binding YumirShowSettingsBeforeLaunch}" Content="{DynamicResource YumirConfig_ShowBeforeLaunch_Checkbox}" Style="{StaticResource ImportantSettingCheckBoxStyle}" ToolTip="{DynamicResource YumirConfig_ShowBeforeLaunch_Tooltip}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="BtnSave" Content="{DynamicResource YumirConfig_Save_Button}"
                    Style="{DynamicResource DialogSecondaryButtonStyle}"
                    Command="{Binding SaveCommand}"
                    ToolTip="{DynamicResource YumirConfig_Save_Tooltip}" />
            <Button x:Name="BtnRun" Content="{DynamicResource YumirConfig_Run_Button2}"
                    Style="{DynamicResource DialogPrimaryButtonStyle}"
                    Command="{Binding RunCommand}" IsDefault="True"
                    Visibility="{Binding IsLauncherMode, Converter={StaticResource BooleanToVisibilityConverter}}"
                    ToolTip="{DynamicResource YumirConfig_Run_Tooltip}" />
            <Button Content="{DynamicResource YumirConfig_Cancel_Button}"
                    Style="{DynamicResource DialogCancelButtonStyle}"
                    ToolTip="{DynamicResource YumirConfig_Cancel_Tooltip}" />
        </StackPanel>
    </Grid>
</controls:MetroWindow>
