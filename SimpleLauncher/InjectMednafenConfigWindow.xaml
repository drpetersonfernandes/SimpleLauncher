<controls:MetroWindow x:Class="SimpleLauncher.InjectMednafenConfigWindow"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
                      Title="{DynamicResource MednafenConfig_Title}"
                      Height="750" Width="700"
                      ResizeMode="CanResize"
                      WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Video Section -->
                <GroupBox Header="{DynamicResource MednafenConfig_Video_Header}" Margin="0,0,0,10">
                    <StackPanel Margin="5">
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Label Content="{DynamicResource MednafenConfig_VideoDriver_Label}" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding VideoDriverOptions}"
                                      SelectedItem="{Binding MednafenVideoDriver}"
                                      ToolTip="{DynamicResource MednafenConfig_VideoDriver_Tooltip}" />
                        </Grid>
                        <CheckBox IsChecked="{Binding MednafenFullscreen}" Content="{DynamicResource MednafenConfig_Fullscreen_Checkbox}" Margin="0,5" ToolTip="{DynamicResource MednafenConfig_Fullscreen_Tooltip}" />
                        <CheckBox IsChecked="{Binding MednafenVsync}" Content="{DynamicResource MednafenConfig_Vsync_Checkbox}" Margin="0,5" ToolTip="{DynamicResource MednafenConfig_Vsync_Tooltip}" />
                        <Grid Margin="0,5,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Label Content="{DynamicResource MednafenConfig_Stretch_Label}" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding StretchOptions}"
                                      SelectedItem="{Binding MednafenStretch}"
                                      ToolTip="{DynamicResource MednafenConfig_Stretch_Tooltip}" />
                        </Grid>
                        <CheckBox IsChecked="{Binding MednafenBilinear}" Content="{DynamicResource MednafenConfig_Bilinear_Checkbox}" Margin="0,5" ToolTip="{DynamicResource MednafenConfig_Bilinear_Tooltip}" />
                    </StackPanel>
                </GroupBox>

                <!-- Effects Section -->
                <GroupBox Header="{DynamicResource MednafenConfig_Effects_Header}" Margin="0,0,0,10">
                    <StackPanel Margin="5">
                        <Label Content="{DynamicResource MednafenConfig_Scanlines_Label}" VerticalAlignment="Center" />
                        <Slider Value="{Binding MednafenScanlines}" Minimum="0" Maximum="100" IsSnapToTickEnabled="True" TickFrequency="1" ToolTip="{DynamicResource MednafenConfig_Scanlines_Tooltip}" />
                        <Grid Margin="0,5,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Label Content="{DynamicResource MednafenConfig_Shader_Label}" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding ShaderOptions}"
                                      SelectedItem="{Binding MednafenShader}"
                                      ToolTip="{DynamicResource MednafenConfig_Shader_Tooltip}" />
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <!-- Sound Section -->
                <GroupBox Header="{DynamicResource MednafenConfig_Sound_Header}" Margin="0,0,0,10">
                    <StackPanel Margin="5">
                        <Label Content="{DynamicResource MednafenConfig_Volume_Label}" VerticalAlignment="Center" />
                        <Slider Value="{Binding MednafenVolume}" Minimum="0" Maximum="100" IsSnapToTickEnabled="True" TickFrequency="1" ToolTip="{DynamicResource MednafenConfig_Volume_Tooltip}" />
                    </StackPanel>
                </GroupBox>

                <!-- Features Section -->
                <GroupBox Header="{DynamicResource MednafenConfig_Features_Header}" Margin="0,0,0,10">
                    <StackPanel Margin="5">
                        <CheckBox IsChecked="{Binding MednafenCheats}" Content="{DynamicResource MednafenConfig_Cheats_Checkbox}" Margin="0,5" ToolTip="{DynamicResource MednafenConfig_Cheats_Tooltip}" />
                        <CheckBox IsChecked="{Binding MednafenRewind}" Content="{DynamicResource MednafenConfig_Rewind_Checkbox}" Margin="0,5" ToolTip="{DynamicResource MednafenConfig_Rewind_Tooltip}" />
                    </StackPanel>
                </GroupBox>

                <!-- CRITICAL SETTING -->
                <Border Style="{StaticResource ImportantSettingBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource IMPORTANTSETTING}" Style="{StaticResource ImportantSettingHeaderStyle}" />
                        <CheckBox IsChecked="{Binding MednafenShowSettingsBeforeLaunch}" Content="{DynamicResource MednafenConfig_ShowBeforeLaunch_Checkbox}" Style="{StaticResource ImportantSettingCheckBoxStyle}" ToolTip="{DynamicResource MednafenConfig_ShowBeforeLaunch_Tooltip}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="BtnSave" Content="{DynamicResource MednafenConfig_Save_Button}"
                    Style="{DynamicResource DialogSecondaryButtonStyle}"
                    Command="{Binding SaveCommand}"
                    ToolTip="{DynamicResource MednafenConfig_Save_Tooltip}" />
            <Button x:Name="BtnRun" Content="{DynamicResource MednafenConfig_Run_Button2}"
                    Style="{DynamicResource DialogPrimaryButtonStyle}"
                    Command="{Binding RunCommand}" IsDefault="True"
                    Visibility="{Binding IsLauncherMode, Converter={StaticResource BooleanToVisibilityConverter}}"
                    ToolTip="{DynamicResource MednafenConfig_Run_Tooltip}" />
            <Button Content="{DynamicResource MednafenConfig_Cancel_Button}"
                    Style="{DynamicResource DialogCancelButtonStyle}"
                    ToolTip="{DynamicResource MednafenConfig_Cancel_Tooltip}" />
        </StackPanel>
    </Grid>
</controls:MetroWindow>
