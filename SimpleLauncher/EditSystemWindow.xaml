<controls:MetroWindow x:Class="SimpleLauncher.EditSystemWindow"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
                      Title="{DynamicResource EditSystem}"
                      Width="1200"
                      MinWidth="1000"
                      Height="600"
                      MinHeight="550"
                      WindowStartupLocation="CenterScreen"
                      WindowState="Maximized" x:ClassModifier="internal">

    <Grid>
        <Grid x:Name="MainContentGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left Column -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- System Name -->
                    <Label
                        Margin="10,20,10,10"
                        Grid.Row="0"
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Content="{DynamicResource Chooseasystem}" ToolTip="{DynamicResource TooltipChooseSystemLabel}" />
                    <ComboBox
                        x:Name="SystemNameDropdown"
                        Grid.Row="0"
                        Grid.Column="1"
                        Margin="0,20,10,10"
                        HorizontalAlignment="Stretch"
                        SelectionChanged="SystemNameDropdown_SelectionChanged"
                        ToolTip="{DynamicResource TooltipChooseSystem2}" />
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Add New System -->
                    <Button
                        Grid.Column="0"
                        Style="{DynamicResource MahApps.Styles.Button.Square}"
                        Margin="10"
                        Padding="10"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Click="AddSystemButton_ClickAsync"
                        Content="{DynamicResource AddNewSystem}"
                        ToolTip="{DynamicResource TooltipAddNewSystem2}"
                        AutomationProperties.Name="{DynamicResource AddNewSystem}" />

                    <!-- Save New System -->
                    <Button
                        x:Name="SaveSystemButton"
                        Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"
                        Grid.Column="1"
                        Margin="10"
                        Padding="10"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Click="SaveSystemButtonClickAsync"
                        Content="{DynamicResource SaveorUpdateSystem}"
                        ToolTip="{DynamicResource TooltipSaveSystem2}"
                        AutomationProperties.Name="{DynamicResource SaveorUpdateSystem}" />

                    <!-- Delete System -->
                    <Button
                        x:Name="DeleteSystemButton"
                        Style="{DynamicResource MahApps.Styles.Button.Square}"
                        Grid.Column="2"
                        Margin="10"
                        Padding="10"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Click="DeleteSystemButton_ClickAsync"
                        Content="{DynamicResource DeleteSelectedSystem}"
                        ToolTip="{DynamicResource TooltipDeleteSystem2}"
                        AutomationProperties.Name="{DynamicResource DeleteSelectedSystem}" />

                    <Button
                        Margin="0,0,25,0"
                        Grid.Column="3"
                        Style="{StaticResource NavImageButton3DStyle}"
                        Click="HelpLink_ClickAsync"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Width="80"
                        Height="80"
                        ToolTip="{DynamicResource TooltipEditSystem}"
                        AutomationProperties.Name="{DynamicResource Help}">
                        <Image
                            Source="images/help-desk.png"
                            Width="60"
                            Height="60"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            AutomationProperties.Name="{DynamicResource Help}" ToolTip="{DynamicResource TooltipHelpDeskImage}" />
                    </Button>
                </Grid>

                <ScrollViewer
                    Grid.Row="3"
                    Grid.Column="0"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto"
                    Margin="0,0,10,0">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- System Image Preview -->
                        <Label
                            Grid.Column="0" Grid.Row="0"
                            Margin="10,20,10,10"
                            VerticalAlignment="Center"
                            Content="{DynamicResource SystemImageLabel}" ToolTip="{DynamicResource TooltipSystemImageLabel}" />
                        <Border Grid.Column="1" Grid.Row="0"
                                VerticalAlignment="Stretch"
                                HorizontalAlignment="Left"
                                x:Name="TopSystemImage"
                                BorderThickness="1"
                                Margin="0,20,10,10"
                                Padding="5"
                                BorderBrush="{DynamicResource MahApps.Brushes.Gray7}"
                                Background="{DynamicResource MahApps.Brushes.Gray9}"
                                CornerRadius="5" ToolTip="{DynamicResource TooltipSystemImagePreviewBorder}">
                            <Image
                                x:Name="SystemImagePreview"
                                Width="120"
                                Height="120"
                                VerticalAlignment="Center" ToolTip="{DynamicResource TooltipSystemImagePreview}" />
                        </Border>
                        <Button
                            x:Name="ChooseSystemImageButton"
                            Grid.Column="2" Grid.Row="0"
                            Margin="0,0,10,10"
                            Padding="10"
                            HorizontalAlignment="Left"
                            HorizontalContentAlignment="Left"
                            VerticalAlignment="Center"
                            VerticalContentAlignment="Center"
                            Click="ChooseSystemImageButton_ClickAsync"
                            Content="{DynamicResource ChooseSystemImage}"
                            IsEnabled="False"
                            ToolTip="{DynamicResource TooltipChooseSystemImage}" />

                        <!-- System Name -->
                        <Label
                            Margin="10,20,10,10"
                            Grid.Row="1"
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Content="{DynamicResource SystemNameRequired}" ToolTip="{DynamicResource TooltipSystemNameRequiredLabel}">
                        </Label>
                        <TextBox
                            Margin="0,20,10,10"
                            x:Name="SystemNameTextBox"
                            Grid.Row="1"
                            Grid.Column="1"
                            HorizontalAlignment="Stretch"
                            IsReadOnly="True"
                            IsEnabled="False"
                            LostFocus="SystemNameTextBox_LostFocus"
                            ToolTip="{DynamicResource TooltipSystemName}" />

                        <!-- System Folder -->
                        <Label
                            Margin="10,0,10,10"
                            Grid.Row="2"
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Content="{DynamicResource SystemFolderRequired}" ToolTip="{DynamicResource TooltipSystemFolderRequiredLabel}">
                        </Label>
                        <TextBox
                            Margin="0,0,10,10"
                            x:Name="SystemFolderTextBox"
                            Grid.Row="2"
                            Grid.Column="1"
                            IsReadOnly="True"
                            IsEnabled="False"
                            ToolTip="{DynamicResource TooltipChooseSystemFolder2}" />
                        <Button
                            x:Name="ChooseSystemFolderButton"
                            Margin="0,0,10,10"
                            Grid.Row="2"
                            Grid.Column="2"
                            Click="ChooseSystemFolder"
                            Content="{DynamicResource SetSystemFolder}"
                            IsEnabled="False"
                            HorizontalAlignment="Left"
                            ToolTip="{DynamicResource TooltipChooseSystemFolder}" />

                        <!-- Additional System Folders -->
                        <Expander x:Name="AdditionalFoldersExpander" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" Header="{DynamicResource AdditionalSystemFoldersOptional}" Margin="10" IsExpanded="True" ToolTip="{DynamicResource TooltipAdditionalFoldersExpander}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ListBox x:Name="AdditionalFoldersListBox" Margin="5" IsEnabled="False" ToolTip="{DynamicResource TooltipAddAdditionalFolder2}" />
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <Button x:Name="AddFolderButton" Content="{DynamicResource Add}" Margin="5" Click="AddFolderButton_Click" IsEnabled="False" ToolTip="{DynamicResource TooltipAddAdditionalFolder2}" />
                                    <Button x:Name="RemoveFolderButton" Content="{DynamicResource Remove}" Margin="5" Click="RemoveFolderButton_Click" IsEnabled="False" ToolTip="{DynamicResource TooltipRemoveAdditionalFolder2}" />
                                </StackPanel>
                            </Grid>
                        </Expander>

                        <!-- System Image Folder -->
                        <Label
                            Margin="10,0,10,10"
                            Grid.Row="4"
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Content="{DynamicResource SystemImageFolderOptional}" ToolTip="{DynamicResource TooltipSystemImageFolderOptionalLabel}">
                        </Label>
                        <TextBox
                            Margin="0,0,10,10"
                            x:Name="SystemImageFolderTextBox"
                            Grid.Row="4"
                            Grid.Column="1"
                            IsReadOnly="True"
                            IsEnabled="False"
                            ToolTip="{DynamicResource TooltipChooseSystemImageFolder2}" />
                        <Button
                            Margin="0,0,10,10"
                            x:Name="ChooseSystemImageFolderButton"
                            Grid.Row="4"
                            Grid.Column="2"
                            Click="ChooseSystemImageFolder"
                            Content="{DynamicResource SetSystemImageFolder}"
                            IsEnabled="False"
                            HorizontalAlignment="Left"
                            ToolTip="{DynamicResource TooltipChooseSystemImageFolder2}" />

                        <!-- Format To Search Inside System Folder -->
                        <Label
                            Margin="10,0,10,10"
                            Grid.Row="5"
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Content="{DynamicResource ExtensiontoSearchintheSystemFolderRequired}" ToolTip="{DynamicResource TooltipExtensionSearchRequiredLabel}">
                        </Label>
                        <TextBox
                            Margin="0,0,10,10"
                            x:Name="FormatToSearchTextBox"
                            Grid.Row="5"
                            Grid.Column="1"
                            IsReadOnly="True"
                            IsEnabled="False"
                            ToolTip="{DynamicResource TooltipExtensions}" />
                        <Label
                            Margin="0,0,10,10"
                            Grid.Row="5"
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Content="{DynamicResource Useacommatoaddmultipleextensions}" ToolTip="{DynamicResource TooltipMultipleExtensionsLabel}">
                        </Label>

                        <!-- Extract File Before Launch -->
                        <Label
                            Margin="10,0,10,10"
                            Grid.Row="6"
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Content="{DynamicResource ExtractFileBeforeLaunch}" ToolTip="{DynamicResource TooltipExtractFileBeforeLaunchLabel}" />
                        <ComboBox
                            Margin="0,0,10,10"
                            x:Name="ExtractFileBeforeLaunchComboBox"
                            Grid.Row="6"
                            Grid.Column="1"
                            IsReadOnly="True"
                            IsEnabled="False"
                            ToolTip="{DynamicResource TooltipExtractBeforeLaunch2}">
                            <ComboBoxItem>true</ComboBoxItem>
                            <ComboBoxItem>false</ComboBoxItem>
                        </ComboBox>

                        <!-- Format To Launch After Extraction -->
                        <Label
                            Margin="10,0,10,10"
                            Grid.Row="7"
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Content="{DynamicResource ExtensiontoLaunchAfterExtractionMaybeRequired}" ToolTip="{DynamicResource TooltipExtensionLaunchLabel}">
                        </Label>
                        <TextBox
                            Margin="0,0,10,10"
                            x:Name="FormatToLaunchTextBox"
                            Grid.Row="7"
                            Grid.Column="1"
                            IsReadOnly="True"
                            IsEnabled="False"
                            ToolTip="{DynamicResource TooltipExtensions}" />
                        <Label
                            Margin="0,0,10,10"
                            Grid.Row="7"
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Content="{DynamicResource Useacommatoaddmultipleextensions}" ToolTip="{DynamicResource TooltipMultipleExtensionsLabel}">
                        </Label>

                        <!-- Group Files by Folder -->
                        <Label
                            Margin="10,0,10,10"
                            Grid.Row="8"
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Content="{DynamicResource GroupFilesByFolder}" ToolTip="{DynamicResource TooltipGroupFilesByFolderLabel}">
                        </Label>
                        <ComboBox
                            Margin="0,0,10,10"
                            x:Name="GroupByFolderComboBox"
                            Grid.Row="8"
                            Grid.Column="1"
                            IsReadOnly="True"
                            IsEnabled="False"
                            ToolTip="{DynamicResource TooltipGroupByFolder2}">
                            <ComboBoxItem>false</ComboBoxItem>
                            <ComboBoxItem>true</ComboBoxItem>
                        </ComboBox>

                        <!-- Disable Recursive Search -->
                        <Label
                            Margin="10,0,10,10"
                            Grid.Row="9"
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Content="{DynamicResource DisableRecursiveSearch}" ToolTip="{DynamicResource TooltipDisableRecursiveSearchLabel}" />
                        <ComboBox
                            Margin="0,0,10,10"
                            x:Name="DisableRecursiveSearchComboBox"
                            Grid.Row="9"
                            Grid.Column="1"
                            IsReadOnly="True"
                            IsEnabled="False"
                            ToolTip="{DynamicResource TooltipDisableRecursiveSearch2}">
                            <ComboBoxItem>false</ComboBoxItem>
                            <ComboBoxItem>true</ComboBoxItem>
                        </ComboBox>

                        <!-- Emulator 1 -->
                        <Expander x:Name="Emulator1Expander" Grid.Row="10" Grid.Column="0" Grid.ColumnSpan="3" Margin="10" Header="{DynamicResource Emulator1}" IsExpanded="True" ToolTip="{DynamicResource TooltipEmulator1Expander}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Label
                                    Margin="10"
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Content="{DynamicResource Emulator1NameRequired}" ToolTip="{DynamicResource TooltipEmulator1NameLabel}">
                                </Label>
                                <TextBox
                                    Margin="0,10,10,10"
                                    x:Name="Emulator1NameTextBox"
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    IsReadOnly="True"
                                    IsEnabled="False"
                                    ToolTip="{DynamicResource TooltipEmulatorName}" />
                                <Label
                                    Margin="10,0,10,10"
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Content="{DynamicResource Emulator1Path}" ToolTip="{DynamicResource TooltipEmulator1PathLabel}" />
                                <TextBox
                                    Margin="0,0,10,10"
                                    x:Name="Emulator1PathTextBox"
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    IsReadOnly="True"
                                    IsEnabled="False"
                                    HorizontalAlignment="Stretch"
                                    ToolTip="{DynamicResource TooltipChooseEmulatorPath}" />
                                <Button
                                    Margin="0,0,10,10"
                                    x:Name="ChooseEmulator1PathButton"
                                    Grid.Row="1"
                                    Grid.Column="2"
                                    Click="ChooseEmulator1Path"
                                    Content="{DynamicResource SetEmulator1Path}"
                                    IsEnabled="False"
                                    HorizontalAlignment="Left"
                                    ToolTip="{DynamicResource TooltipChooseEmulator1Path}" />
                                <Label
                                    Margin="10,0,10,10"
                                    Grid.Row="2"
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Content="{DynamicResource Emulator1Parameters}" ToolTip="{DynamicResource TooltipEmulator1ParametersLabel}" />
                                <TextBox
                                    Margin="0,0,10,10"
                                    x:Name="Emulator1ParametersTextBox"
                                    Grid.Row="2"
                                    Grid.Column="1"
                                    IsReadOnly="True"
                                    IsEnabled="False"
                                    ToolTip="{DynamicResource TooltipEmulatorParameters}" />
                                <Button
                                    Margin="0,0,10,10"
                                    x:Name="SuggestEmulator1ParametersButton"
                                    Grid.Row="2"
                                    Grid.Column="2"
                                    Click="SuggestEmulator1Parameters_ClickAsync"
                                    Content="{DynamicResource SuggestParameters}"
                                    IsEnabled="False"
                                    HorizontalAlignment="Left"
                                    ToolTip="{DynamicResource TooltipSuggestParameters}" />

                                <Label
                                    Margin="10,0,10,10"
                                    Grid.Row="3"
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Content="{DynamicResource ReceiveANotificationOnEmulatorError}" ToolTip="{DynamicResource TooltipEmulator1NotificationLabel}" />
                                <ComboBox
                                    Margin="0,0,10,10"
                                    x:Name="ReceiveANotificationOnEmulatorError1"
                                    Grid.Row="3"
                                    Grid.Column="1"
                                    IsReadOnly="True"
                                    IsEnabled="False"
                                    ToolTip="{DynamicResource TooltipNotificationOnEmulatorError2}">
                                    <ComboBoxItem>true</ComboBoxItem>
                                    <ComboBoxItem>false</ComboBoxItem>
                                </ComboBox>

                            </Grid>
                        </Expander>

                        <!-- Emulator 2 -->
                        <Expander x:Name="Emulator2Expander" Grid.Row="11" Grid.Column="0" Grid.ColumnSpan="3" Margin="10" Header="{DynamicResource Emulator2}" IsExpanded="True" ToolTip="{DynamicResource TooltipEmulator2Expander}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Label
                                    Margin="10"
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Content="{DynamicResource Emulator2NameMaybeRequired}" ToolTip="{DynamicResource TooltipEmulator2NameLabel}">
                                </Label>
                                <TextBox
                                    Margin="0,10,10,10"
                                    x:Name="Emulator2NameTextBox"
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    IsReadOnly="True"
                                    IsEnabled="False"
                                    ToolTip="{DynamicResource TooltipEmulatorName}" />
                                <Label
                                    Margin="10,0,10,10"
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Content="{DynamicResource Emulator2Path}" ToolTip="{DynamicResource TooltipEmulator2PathLabel}" />
                                <TextBox
                                    Margin="0,0,10,10"
                                    x:Name="Emulator2PathTextBox"
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    IsReadOnly="True"
                                    IsEnabled="False"
                                    HorizontalAlignment="Stretch"
                                    ToolTip="{DynamicResource TooltipChooseEmulatorPath}" />
                                <Button
                                    Margin="0,0,10,10"
                                    x:Name="ChooseEmulator2PathButton"
                                    Grid.Row="1"
                                    Grid.Column="2"
                                    Click="ChooseEmulator2Path"
                                    Content="{DynamicResource SetEmulator2Path}"
                                    IsEnabled="False"
                                    HorizontalAlignment="Left"
                                    ToolTip="{DynamicResource TooltipChooseEmulator2Path}" />
                                <Label
                                    Margin="10,0,10,10"
                                    Grid.Row="2"
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Content="{DynamicResource Emulator2Parameters}" ToolTip="{DynamicResource TooltipEmulator2ParametersLabel}" />
                                <TextBox
                                    Margin="0,0,10,10"
                                    x:Name="Emulator2ParametersTextBox"
                                    Grid.Row="2"
                                    Grid.Column="1"
                                    IsReadOnly="True"
                                    IsEnabled="False"
                                    ToolTip="{DynamicResource TooltipEmulatorParameters}" />
                                <Button
                                    Margin="0,0,10,10"
                                    x:Name="SuggestEmulator2ParametersButton"
                                    Grid.Row="2"
                                    Grid.Column="2"
                                    Click="SuggestEmulator2Parameters_ClickAsync"
                                    Content="{DynamicResource SuggestParameters}"
                                    IsEnabled="False"
                                    HorizontalAlignment="Left"
                                    ToolTip="{DynamicResource TooltipSuggestParameters}" />

                                <Label
                                    Margin="10,0,10,10"
                                    Grid.Row="3"
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Content="{DynamicResource ReceiveANotificationOnEmulatorError}" ToolTip="{DynamicResource TooltipEmulator2NotificationLabel}" />
                                <ComboBox
                                    Margin="0,0,10,10"
                                    x:Name="ReceiveANotificationOnEmulatorError2"
                                    Grid.Row="3"
                                    Grid.Column="1"
                                    IsReadOnly="True"
                                    IsEnabled="False"
                                    ToolTip="{DynamicResource TooltipNotificationOnEmulatorError2}">
                                    <ComboBoxItem>true</ComboBoxItem>
                                    <ComboBoxItem>false</ComboBoxItem>
                                </ComboBox>
                            </Grid>
                        </Expander>

                        <!-- Emulator 3 -->
                        <Expander x:Name="Emulator3Expander" Grid.Row="12" Grid.Column="0" Grid.ColumnSpan="3" Margin="10" Header="{DynamicResource Emulator3}" IsExpanded="True" ToolTip="{DynamicResource TooltipEmulator3Expander}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Label
                                    Margin="10"
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Content="{DynamicResource Emulator3NameMaybeRequired}" ToolTip="{DynamicResource TooltipEmulator3NameLabel}">
                                </Label>
                                <TextBox
                                    Margin="0,10,10,10"
                                    x:Name="Emulator3NameTextBox"
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    IsReadOnly="True"
                                    IsEnabled="False"
                                    ToolTip="{DynamicResource TooltipEmulatorName}" />
                                <Label
                                    Margin="10,0,10,10"
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Content="{DynamicResource Emulator3Path}" ToolTip="{DynamicResource TooltipEmulator3PathLabel}" />
                                <TextBox
                                    Margin="0,0,10,10"
                                    x:Name="Emulator3PathTextBox"
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    IsReadOnly="True"
                                    IsEnabled="False"
                                    HorizontalAlignment="Stretch"
                                    ToolTip="{DynamicResource TooltipChooseEmulatorPath}" />
                                <Button
                                    Margin="0,0,10,10"
                                    x:Name="ChooseEmulator3PathButton"
                                    Grid.Row="1"
                                    Grid.Column="2"
                                    Click="ChooseEmulator3Path"
                                    Content="{DynamicResource SetEmulator3Path}"
                                    IsEnabled="False"
                                    HorizontalAlignment="Left"
                                    ToolTip="{DynamicResource TooltipChooseEmulator3Path}" />
                                <Label
                                    Margin="10,0,10,10"
                                    Grid.Row="2"
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Content="{DynamicResource Emulator3Parameters}" ToolTip="{DynamicResource TooltipEmulator3ParametersLabel}" />
                                <TextBox
                                    Margin="0,0,10,10"
                                    x:Name="Emulator3ParametersTextBox"
                                    Grid.Row="2"
                                    Grid.Column="1"
                                    IsReadOnly="True"
                                    IsEnabled="False"
                                    ToolTip="{DynamicResource TooltipEmulatorParameters}" />
                                <Button
                                    Margin="0,0,10,10"
                                    x:Name="SuggestEmulator3ParametersButton"
                                    Grid.Row="2"
                                    Grid.Column="2"
                                    Click="SuggestEmulator3Parameters_ClickAsync"
                                    Content="{DynamicResource SuggestParameters}"
                                    IsEnabled="False"
                                    HorizontalAlignment="Left"
                                    ToolTip="{DynamicResource TooltipSuggestParameters}" />

                                <Label
                                    Margin="10,0,10,10"
                                    Grid.Row="3"
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Content="{DynamicResource ReceiveANotificationOnEmulatorError}" ToolTip="{DynamicResource TooltipEmulator3NotificationLabel}" />
                                <ComboBox
                                    Margin="0,0,10,10"
                                    x:Name="ReceiveANotificationOnEmulatorError3"
                                    Grid.Row="3"
                                    Grid.Column="1"
                                    IsReadOnly="True"
                                    IsEnabled="False"
                                    ToolTip="{DynamicResource TooltipNotificationOnEmulatorError2}">
                                    <ComboBoxItem>true</ComboBoxItem>
                                    <ComboBoxItem>false</ComboBoxItem>
                                </ComboBox>
                            </Grid>
                        </Expander>

                        <!-- Emulator 4 -->
                        <Expander x:Name="Emulator4Expander" Grid.Row="13" Grid.Column="0" Grid.ColumnSpan="3" Margin="10" Header="{DynamicResource Emulator4}" IsExpanded="True" ToolTip="{DynamicResource TooltipEmulator4Expander}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Label
                                    Margin="10"
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Content="{DynamicResource Emulator4NameMaybeRequired}" ToolTip="{DynamicResource TooltipEmulator4NameLabel}">
                                </Label>
                                <TextBox
                                    Margin="0,10,10,10"
                                    x:Name="Emulator4NameTextBox"
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    IsReadOnly="True"
                                    IsEnabled="False"
                                    ToolTip="{DynamicResource TooltipEmulatorName}" />
                                <Label
                                    Margin="10,0,10,10"
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Content="{DynamicResource Emulator4Path}" ToolTip="{DynamicResource TooltipEmulator4PathLabel}" />
                                <TextBox
                                    Margin="0,0,10,10"
                                    x:Name="Emulator4PathTextBox"
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    IsReadOnly="True"
                                    IsEnabled="False"
                                    HorizontalAlignment="Stretch"
                                    ToolTip="{DynamicResource TooltipChooseEmulatorPath}" />
                                <Button
                                    Margin="0,0,10,10"
                                    x:Name="ChooseEmulator4PathButton"
                                    Grid.Row="1"
                                    Grid.Column="2"
                                    Click="ChooseEmulator4Path"
                                    Content="{DynamicResource SetEmulator4Path}"
                                    IsEnabled="False"
                                    HorizontalAlignment="Left"
                                    ToolTip="{DynamicResource TooltipChooseEmulator4Path}" />
                                <Label
                                    Margin="10,0,10,10"
                                    Grid.Row="2"
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Content="{DynamicResource Emulator4Parameters}" ToolTip="{DynamicResource TooltipEmulator4ParametersLabel}" />
                                <TextBox
                                    Margin="0,0,10,10"
                                    x:Name="Emulator4ParametersTextBox"
                                    Grid.Row="2"
                                    Grid.Column="1"
                                    IsReadOnly="True"
                                    IsEnabled="False"
                                    ToolTip="{DynamicResource TooltipEmulatorParameters}" />
                                <Button
                                    Margin="0,0,10,10"
                                    x:Name="SuggestEmulator4ParametersButton"
                                    Grid.Row="2"
                                    Grid.Column="2"
                                    Click="SuggestEmulator4Parameters_ClickAsync"
                                    Content="{DynamicResource SuggestParameters}"
                                    IsEnabled="False"
                                    HorizontalAlignment="Left"
                                    ToolTip="{DynamicResource TooltipSuggestParameters}" />

                                <Label
                                    Margin="10,0,10,10"
                                    Grid.Row="3"
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Content="{DynamicResource ReceiveANotificationOnEmulatorError}" ToolTip="{DynamicResource TooltipEmulator4NotificationLabel}" />
                                <ComboBox
                                    Margin="0,0,10,10"
                                    x:Name="ReceiveANotificationOnEmulatorError4"
                                    Grid.Row="3"
                                    Grid.Column="1"
                                    IsReadOnly="True"
                                    IsEnabled="False"
                                    ToolTip="{DynamicResource TooltipNotificationOnEmulatorError2}">
                                    <ComboBoxItem>true</ComboBoxItem>
                                    <ComboBoxItem>false</ComboBoxItem>
                                </ComboBox>
                            </Grid>
                        </Expander>

                        <!-- Emulator 5 -->
                        <Expander x:Name="Emulator5Expander" Grid.Row="14" Grid.Column="0" Grid.ColumnSpan="3" Margin="10" Header="{DynamicResource Emulator5}" IsExpanded="True" ToolTip="{DynamicResource TooltipEmulator5Expander}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Label
                                    Margin="10"
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Content="{DynamicResource Emulator5NameMaybeRequired}" ToolTip="{DynamicResource TooltipEmulator5NameLabel}">
                                </Label>
                                <TextBox
                                    Margin="0,10,10,10"
                                    x:Name="Emulator5NameTextBox"
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    IsReadOnly="True"
                                    IsEnabled="False"
                                    ToolTip="{DynamicResource TooltipEmulatorName}" />
                                <Label
                                    Margin="10,0,10,10"
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Content="{DynamicResource Emulator5Path}" ToolTip="{DynamicResource TooltipEmulator5PathLabel}" />
                                <TextBox
                                    Margin="0,0,10,10"
                                    x:Name="Emulator5PathTextBox"
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    IsReadOnly="True"
                                    IsEnabled="False"
                                    HorizontalAlignment="Stretch"
                                    ToolTip="{DynamicResource TooltipChooseEmulatorPath}" />
                                <Button
                                    Margin="0,0,10,10"
                                    x:Name="ChooseEmulator5PathButton"
                                    Grid.Row="1"
                                    Grid.Column="2"
                                    Click="ChooseEmulator5Path"
                                    Content="{DynamicResource SetEmulator5Path}"
                                    IsEnabled="False"
                                    HorizontalAlignment="Left"
                                    ToolTip="{DynamicResource TooltipChooseEmulator5Path}" />
                                <Label
                                    Margin="10,0,10,10"
                                    Grid.Row="2"
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Content="{DynamicResource Emulator5Parameters}" ToolTip="{DynamicResource TooltipEmulator5ParametersLabel}" />
                                <TextBox
                                    Margin="0,0,10,10"
                                    x:Name="Emulator5ParametersTextBox"
                                    Grid.Row="2"
                                    Grid.Column="1"
                                    IsReadOnly="True"
                                    IsEnabled="False"
                                    ToolTip="{DynamicResource TooltipEmulatorParameters}" />
                                <Button
                                    Margin="0,0,10,10"
                                    x:Name="SuggestEmulator5ParametersButton"
                                    Grid.Row="2"
                                    Grid.Column="2"
                                    Click="SuggestEmulator5Parameters_ClickAsync"
                                    Content="{DynamicResource SuggestParameters}"
                                    IsEnabled="False"
                                    HorizontalAlignment="Left"
                                    ToolTip="{DynamicResource TooltipSuggestParameters}" />

                                <Label
                                    Margin="10,0,10,10"
                                    Grid.Row="3"
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Content="{DynamicResource ReceiveANotificationOnEmulatorError}" ToolTip="{DynamicResource TooltipEmulator5NotificationLabel}" />
                                <ComboBox
                                    Margin="0,0,10,10"
                                    x:Name="ReceiveANotificationOnEmulatorError5"
                                    Grid.Row="3"
                                    Grid.Column="1"
                                    IsReadOnly="True"
                                    IsEnabled="False"
                                    ToolTip="{DynamicResource TooltipNotificationOnEmulatorError2}">
                                    <ComboBoxItem>true</ComboBoxItem>
                                    <ComboBoxItem>false</ComboBoxItem>
                                </ComboBox>
                            </Grid>
                        </Expander>

                    </Grid>
                </ScrollViewer>
            </Grid>

            <!-- GridSplitter between columns 0 and 2 -->
            <GridSplitter Grid.Column="1"
                          ResizeDirection="Columns"
                          Style="{StaticResource EnhancedGridSplitterStyle}"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          ShowsPreview="True"
                          ResizeBehavior="PreviousAndNext"
                          Cursor="SizeWE" ToolTip="{DynamicResource TooltipGridSplitter}" />

            <!-- Right column -->
            <Grid Grid.Column="2" Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Label
                    Margin="10"
                    Grid.Row="0"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    FontWeight="Bold"
                    Content="{DynamicResource DeveloperSuggestion}" ToolTip="{DynamicResource TooltipDeveloperSuggestionLabel}" />
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <RichTextBox
                        x:Name="HelpUserTextBlock"
                        Margin="0,0,10,10"
                        VerticalAlignment="Stretch"
                        HorizontalAlignment="Stretch"
                        IsReadOnly="True"
                        IsDocumentEnabled="True"
                        VerticalScrollBarVisibility="Auto"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="0"
                        Focusable="True">
                        <FlowDocument>
                            <Paragraph />
                        </FlowDocument>
                    </RichTextBox>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- Global Loading Overlay -->
        <ContentControl x:Name="LoadingOverlay"
                        Template="{StaticResource LoadingOverlayTemplate}"
                        Visibility="Collapsed"
                        Grid.ColumnSpan="3" />

    </Grid>
</controls:MetroWindow>