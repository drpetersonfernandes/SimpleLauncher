<controls:MetroWindow x:Class="SimpleLauncher.UpdateHistoryWindow"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
                      xmlns:md="clr-namespace:MdXaml;assembly=MdXaml"
                      Title="{DynamicResource UpdateHistory}"
                      Width="800"
                      Height="700"
                      MinWidth="700"
                      MinHeight="550"
                      WindowStartupLocation="CenterScreen">
    <Grid>
        <md:MarkdownScrollViewer x:Name="HistoryMarkdownViewer"
                                 Margin="10"
                                 VerticalAlignment="Top"
                                 HorizontalAlignment="Stretch"
                                 Markdown="{Binding MarkdownContent}"
                                 MarkdownStyle="{StaticResource ThemeAwareMarkdownStyle}" />
    </Grid>
</controls:MetroWindow>
