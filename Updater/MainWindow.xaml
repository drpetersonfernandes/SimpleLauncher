<Window x:Class="Updater.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Updating..."
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource UpdaterWindowStyle}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBox x:Name="LogTextBox"
                 Grid.Row="0"
                 Style="{StaticResource LogTextBoxStyle}" />

        <ProgressBar x:Name="DownloadProgressBar"
                     Grid.Row="1"
                     Style="{StaticResource DownloadProgressBarStyle}" />

        <TextBlock x:Name="ProgressStatusText"
                   Grid.Row="2"
                   Style="{StaticResource StatusTextBlockStyle}"
                   Text="Waiting to start..." />

        <Button x:Name="CancelButton"
                Grid.Row="3"
                Style="{StaticResource CancelButtonStyle}"
                Content="Cancel"
                Click="CancelButton_Click" />
    </Grid>
</Window>