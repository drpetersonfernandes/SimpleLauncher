<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <!-- ============================================ -->
    <!-- COLORS                                       -->
    <!-- ============================================ -->

    <!-- Background Colors -->
    <Color x:Key="WindowBackgroundColor">#FF1E1E1E</Color>
    <Color x:Key="TextBoxBackgroundColor">Black</Color>
    <Color x:Key="ProgressBarBackgroundColor">#FF333333</Color>

    <!-- Foreground Colors -->
    <Color x:Key="LogTextForegroundColor">Lime</Color>
    <Color x:Key="StatusTextForegroundColor">White</Color>
    <Color x:Key="ProgressBarForegroundColor">LimeGreen</Color>

    <!-- ============================================ -->
    <!-- BRUSHES                                      -->
    <!-- ============================================ -->

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource WindowBackgroundColor}" />
    <SolidColorBrush x:Key="TextBoxBackgroundBrush" Color="{StaticResource TextBoxBackgroundColor}" />
    <SolidColorBrush x:Key="TextBoxForegroundBrush" Color="{StaticResource LogTextForegroundColor}" />
    <SolidColorBrush x:Key="TextBoxCaretBrush" Color="{StaticResource LogTextForegroundColor}" />
    <SolidColorBrush x:Key="ProgressBarBackgroundBrush" Color="{StaticResource ProgressBarBackgroundColor}" />
    <SolidColorBrush x:Key="ProgressBarForegroundBrush" Color="{StaticResource ProgressBarForegroundColor}" />
    <SolidColorBrush x:Key="StatusTextForegroundBrush" Color="{StaticResource StatusTextForegroundColor}" />

    <!-- ============================================ -->
    <!-- FONT DEFINITIONS                             -->
    <!-- ============================================ -->

    <FontFamily x:Key="MonospaceFontFamily">Consolas</FontFamily>
    <FontFamily x:Key="StatusFontFamily">Consolas</FontFamily>

    <system:Double x:Key="LogTextFontSize">13</system:Double>
    <system:Double x:Key="StatusTextFontSize">12</system:Double>

    <!-- ============================================ -->
    <!-- DIMENSIONS                                   -->
    <!-- ============================================ -->

    <system:Double x:Key="WindowWidth">600</system:Double>
    <system:Double x:Key="WindowHeight">450</system:Double>
    <system:Double x:Key="ProgressBarHeight">20</system:Double>
    <Thickness x:Key="DefaultMargin">10</Thickness>
    <Thickness x:Key="TextBoxPadding">10</Thickness>
    <Thickness x:Key="ProgressBarMargin">10,10,10,5</Thickness>
    <Thickness x:Key="StatusTextMargin">10,0,10,10</Thickness>
    <Thickness x:Key="CancelButtonMargin">10,5,10,10</Thickness>

    <!-- ============================================ -->
    <!-- STYLES                                       -->
    <!-- ============================================ -->

    <!-- Window Style -->
    <Style x:Key="UpdaterWindowStyle" TargetType="Window">
        <Setter Property="Background" Value="{StaticResource WindowBackgroundBrush}" />
        <Setter Property="Height" Value="{StaticResource WindowHeight}" />
        <Setter Property="Width" Value="{StaticResource WindowWidth}" />
        <Setter Property="Topmost" Value="True" />
    </Style>

    <!-- Log TextBox Style -->
    <Style x:Key="LogTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource TextBoxBackgroundBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextBoxForegroundBrush}" />
        <Setter Property="FontFamily" Value="{StaticResource MonospaceFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource LogTextFontSize}" />
        <Setter Property="IsReadOnly" Value="True" />
        <Setter Property="IsUndoEnabled" Value="False" />
        <Setter Property="AcceptsReturn" Value="True" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="{StaticResource TextBoxPadding}" />
        <Setter Property="CaretBrush" Value="{StaticResource TextBoxCaretBrush}" />
    </Style>

    <!-- ProgressBar Style -->
    <Style x:Key="DownloadProgressBarStyle" TargetType="ProgressBar">
        <Setter Property="Height" Value="{StaticResource ProgressBarHeight}" />
        <Setter Property="Margin" Value="{StaticResource ProgressBarMargin}" />
        <Setter Property="Minimum" Value="0" />
        <Setter Property="Maximum" Value="100" />
        <Setter Property="Value" Value="0" />
        <Setter Property="Background" Value="{StaticResource ProgressBarBackgroundBrush}" />
        <Setter Property="Foreground" Value="{StaticResource ProgressBarForegroundBrush}" />
    </Style>

    <!-- Status TextBlock Style -->
    <Style x:Key="StatusTextBlockStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="{StaticResource StatusTextMargin}" />
        <Setter Property="Foreground" Value="{StaticResource StatusTextForegroundBrush}" />
        <Setter Property="FontFamily" Value="{StaticResource StatusFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource StatusTextFontSize}" />
        <Setter Property="TextAlignment" Value="Center" />
    </Style>

    <!-- Cancel Button Style -->
    <Style x:Key="CancelButtonStyle" TargetType="Button">
        <Setter Property="Margin" Value="{StaticResource CancelButtonMargin}" />
        <Setter Property="Padding" Value="20,5" />
        <Setter Property="Background" Value="#FF4444" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontSize" Value="{StaticResource StatusTextFontSize}" />
        <Setter Property="FontFamily" Value="{StaticResource StatusFontFamily}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="3"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#FF6666" />
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>