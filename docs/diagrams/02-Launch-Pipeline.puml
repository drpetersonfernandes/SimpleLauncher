' =============================================
' MOUNT SERVICES
' =============================================
package "Mount Services" #FDEDEC {
    class MountZipFiles {
        +MountAsync(zipPath) : Task<string>
    }
    class MountChdFiles {
        +MountAsync(chdPath) : Task<string>
    }
    class MountIsoFiles {
