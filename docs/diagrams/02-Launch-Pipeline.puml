' =============================================
' RELATIONSHIPS
' =============================================

' GameLauncher implements ILauncherService
GameLauncher ..|> ILauncherService

' GameLauncher depends on
GameLauncher o-- "many" ILaunchStrategy : strategies
GameLauncher o-- "many" IEmulatorConfigHandler : handlers
GameLauncher o-- IExtractionService
GameLauncher o-- IMountZipFiles
GameLauncher o-- ILogErrors
GameLauncher o-- IUpdateStatusBar
GameLauncher ..> LaunchContext : creates

' Strategy implementations
DefaultLaunchStrategy ..|> ILaunchStrategy
ChdMountStrategy ..|> ILaunchStrategy
ChdToCueStrategy ..|> ILaunchStrategy
ZipMountStrategy ..|> ILaunchStrategy
XisoMountStrategy ..|> ILaunchStrategy
PbpToCueStrategy ..|> ILaunchStrategy
DosBoxLaunchStrategy ..|> ILaunchStrategy
CommanderGeniusLaunchStrategy ..|> ILaunchStrategy

' Handler implementations
AresConfigHandler ..|> IEmulatorConfigHandler
AzaharConfigHandler ..|> IEmulatorConfigHandler
BlastemConfigHandler ..|> IEmulatorConfigHandler
CemuConfigHandler ..|> IEmulatorConfigHandler
DaphneConfigHandler ..|> IEmulatorConfigHandler
DolphinConfigHandler ..|> IEmulatorConfigHandler
DuckStationConfigHandler ..|> IEmulatorConfigHandler
FlycastConfigHandler ..|> IEmulatorConfigHandler
MameConfigHandler ..|> IEmulatorConfigHandler
MednafenConfigHandler ..|> IEmulatorConfigHandler
MesenConfigHandler ..|> IEmulatorConfigHandler
Pcsx2ConfigHandler ..|> IEmulatorConfigHandler
RaineConfigHandler ..|> IEmulatorConfigHandler
RedreamConfigHandler ..|> IEmulatorConfigHandler
RetroArchConfigHandler ..|> IEmulatorConfigHandler
Rpcs3ConfigHandler ..|> IEmulatorConfigHandler
SegaModel2ConfigHandler ..|> IEmulatorConfigHandler
StellaConfigHandler ..|> IEmulatorConfigHandler
SupermodelConfigHandler ..|> IEmulatorConfigHandler
XeniaConfigHandler ..|> IEmulatorConfigHandler
YumirConfigHandler ..|> IEmulatorConfigHandler

' Mount service implementations
MountZipFiles ..|> IMountZipFiles
MountChdFiles ..|> IMountChdFiles
MountIsoFiles ..|> IMountIsoFiles
MountXisoFiles ..|> IMountXisoFiles

' LaunchContext aggregation
LaunchContext o-- SystemManager
LaunchContext o-- Emulator

' Converters use mount services
ChdToIsoConverter ..> MountIsoFiles : produces ISO
ChdToCueBinConverter ..> MountChdFiles : reads CHD
PbpToCueBinConverter ..> MountChdFiles : similar

@enduml
