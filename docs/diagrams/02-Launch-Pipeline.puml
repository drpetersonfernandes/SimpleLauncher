@startuml 02-Launch-Pipeline

title Simple Launcher — Launch Pipeline
skinparam packageStyle rectangle
skinparam classAttributeIconSize 0
skinparam linetype ortho
skinparam nodesep 50
skinparam ranksep 30
skinparam padding 3
skinparam defaultFontSize 11

' =============================================
' LAUNCH PIPELINE INTERFACES
' =============================================
package "Interfaces" #F2F3F4 {
    interface ILauncherService {
        +HandleButtonClickAsync()
    }
    interface ILaunchStrategy {
        +Priority : int
        +CanLaunch(context : LaunchContext) : bool
        +LaunchAsync(context : LaunchContext) : Task
    }
    interface IEmulatorConfigHandler {
        +CanHandle(emulator : Emulator) : bool
        +HandleAsync(context : LaunchContext) : Task
    }
    interface IExtractionService {
        +ExtractAsync(filePath : string, outputDir : string) : Task
    }
    interface IMountZipFiles {
        +MountAsync(zipPath : string) : Task<string>
    }
    interface IMountChdFiles {
        +MountAsync(chdPath : string) : Task<string>
    }
    interface IMountIsoFiles {
        +MountAsync(isoPath : string) : Task<string>
    }
    interface IMountXisoFiles {
        +MountAsync(xisoPath : string) : Task<string>
    }
    interface ILogErrors {
        +LogExceptionAsync(ex : Exception, context : string)
    }
    interface IUpdateStatusBar {
        +UpdateStatus(text : string)
    }
}

' =============================================
' MODELS
' =============================================
package "Models" #FDEBD0 {
    class LaunchContext {
        +FilePath : string
        +ResolvedFilePath : string
        +EmulatorName : string
        +SystemName : string
        +SystemManager : ISystemManager
        +EmulatorManager : Emulator
        +Parameters : string
        +Settings : SettingsManager
        +WindowContext : IWindowContext
        +LoadingState : ILoadingState
    }

    class Emulator {
        +EmulatorName : string
        +EmulatorLocation : string
        +EmulatorParameters : string
        +ConfigHandler : string
    }

    class SystemManager {
        +SystemName : string
        +SystemFolder : string
        +Emulators : List<Emulator>
    }
}

' =============================================
' GAME LAUNCHER
' =============================================
package "Game Launcher" #FADBD8 {
    class GameLauncher <<Singleton>> {
        -_strategies : IEnumerable<ILaunchStrategy>
        -_handlers : IEnumerable<IEmulatorConfigHandler>
        -_extraction : IExtractionService
        -_mountZip : IMountZipFiles
        -_history : PlayHistoryManager
        -_statusBar : IUpdateStatusBar
        -_errors : ILogErrors
        +HandleButtonClickAsync(context : LaunchContext)
    }
}

' =============================================
' LAUNCH STRATEGIES
' =============================================
package "Launch Strategies (8)" #FFF3E0 {
    class DefaultLaunchStrategy {
        +Priority : int = 0
        +CanLaunch(context) : bool
        +LaunchAsync(context) : Task
    }
    class ChdMountStrategy {
        +Priority : int = 10
        +CanLaunch(context) : bool
        +LaunchAsync(context) : Task
    }
    class ChdToCueStrategy {
        +Priority : int = 20
        +CanLaunch(context) : bool
        +LaunchAsync(context) : Task
    }
    class ZipMountStrategy {
        +Priority : int = 30
        +CanLaunch(context) : bool
        +LaunchAsync(context) : Task
    }
    class XisoMountStrategy {
        +Priority : int = 40
        +CanLaunch(context) : bool
        +LaunchAsync(context) : Task
    }
    class PbpToCueStrategy {
        +Priority : int = 50
        +CanLaunch(context) : bool
        +LaunchAsync(context) : Task
    }
    class DosBoxLaunchStrategy {
        +Priority : int = 60
        +CanLaunch(context) : bool
        +LaunchAsync(context) : Task
    }
    class CommanderGeniusLaunchStrategy {
        +Priority : int = 70
        +CanLaunch(context) : bool
        +LaunchAsync(context) : Task
    }
}

