' =============================================
' RELATIONSHIPS
' =============================================

' --- App creates MainWindow ---
App ..> MainWindow : creates
App ..> SettingsManager : resolves
App ..> PlayHistoryManager : resolves

' --- MainWindow aggregates services via DI ---
MainWindow o-- SettingsManager : injects
MainWindow o-- PlayHistoryManager : injects
MainWindow o-- ILaunchTools : injects
MainWindow o-- ILogErrors : injects
MainWindow o-- IUpdateStatusBar : injects
MainWindow o-- IUiResetService : injects
MainWindow o-- ISystemConfigurationService : injects
MainWindow o-- IUiOrchestrator : injects
MainWindow o-- IGameBrowserService : injects
MainWindow o-- IMenuOrchestrator : injects
MainWindow o-- IApplicationLifecycleService : injects
MainWindow o-- IAudioInputService : injects

' --- MainWindow implements host interfaces ---
MainWindow ..|> IUiOrchestratorHost
MainWindow ..|> IGameFileLoadingHost
MainWindow ..|> ISystemSelectionHost
MainWindow ..|> IGameItemRenderHost
MainWindow ..|> IMenuActionHost
MainWindow ..|> IMenuCheckMarkHost
MainWindow ..|> IUiResetHost
MainWindow ..|> IStatusBarHost
MainWindow ..|> IThemeMenuHost
MainWindow ..|> ILanguageMenuHost
MainWindow ..|> ILoadingState
MainWindow ..|> IStartupInitializationHost

' --- MainWindow hosts Pages ---
MainWindow o-- FavoritesPage
MainWindow o-- GlobalSearchPage
MainWindow o-- PlayHistoryPage

' --- Orchestrators ---
MainWindow ..> UiOrchestrator : delegates UI state
MainWindow ..> GameBrowserService : delegates browsing
MainWindow ..> MenuOrchestrator : delegates menus
MainWindow ..> ApplicationLifecycleService : delegates lifecycle

UiOrchestrator o-- LoadingOverlayService
UiOrchestrator o-- GameListUiService
UiOrchestrator o-- IPaginationService
UiOrchestrator o-- IUiResetService
UiOrchestrator o-- IUpdateStatusBar
UiOrchestrator o-- PlaySoundEffects
UiOrchestrator o-- SettingsManager

GameBrowserService o-- IGameFileLoadingOrchestrator
GameBrowserService o-- ISystemSelectionOrchestrator
GameBrowserService o-- IGameItemRenderService
GameBrowserService o-- IGameCacheService
GameBrowserService o-- IMameDataService
GameBrowserService o-- GameScannerService
GameBrowserService o-- ISearchOrchestratorService

MenuOrchestrator o-- MenuActionHandler
MenuOrchestrator o-- MenuCheckMarkService
MenuOrchestrator o-- ThemeMenuService
MenuOrchestrator o-- LanguageMenuService

ApplicationLifecycleService o-- UpdateCheckerService
ApplicationLifecycleService o-- UsageStatsService
