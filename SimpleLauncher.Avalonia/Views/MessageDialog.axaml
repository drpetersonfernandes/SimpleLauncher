<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:SimpleLauncher.Avalonia.Views"
        x:Class="SimpleLauncher.Avalonia.Views.MessageDialog"
        x:DataType="views:MessageDialog"
        Title="SimpleLauncher"
        Width="420" Height="200"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
    
    <Border Background="#1e1e2e" Padding="20">
        <DockPanel>
            <!-- Buttons -->
            <StackPanel DockPanel.Dock="Bottom" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Center" 
                        Spacing="10"
                        Margin="0,15,0,0">
                <Button Content="Yes" 
                        Width="80"
                        IsDefault="True"
                        Click="OnYesClick"
                        IsVisible="{Binding ShowYesNo}"/>
                <Button Content="No" 
                        Width="80"
                        IsCancel="True"
                        Click="OnNoClick"
                        IsVisible="{Binding ShowYesNo}"/>
                <Button Content="OK" 
                        Width="80"
                        IsDefault="True"
                        Click="OnOkClick"
                        IsVisible="{Binding ShowOkCancel}"/>
                <Button Content="Cancel" 
                        Width="80"
                        IsCancel="True"
                        Click="OnCancelClick"
                        IsVisible="{Binding ShowOkCancel}"/>
            </StackPanel>
            
            <!-- Icon + Message -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center" 
                        VerticalAlignment="Center" 
                        Spacing="15">
                <TextBlock Text="{Binding IconGlyph}" 
                           FontSize="28"
                           VerticalAlignment="Center"
                           IsVisible="{Binding ShowIcon}"/>
                <TextBlock Text="{Binding Message}" 
                           FontSize="14" 
                           Foreground="#cdd6f4"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           VerticalAlignment="Center"
                           MaxWidth="300"/>
            </StackPanel>
        </DockPanel>
    </Border>
</Window>
