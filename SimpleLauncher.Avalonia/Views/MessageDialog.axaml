<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:SimpleLauncher.Avalonia.Views"
        x:Class="SimpleLauncher.Avalonia.Views.MessageDialog"
        x:DataType="views:MessageDialog"
        Title="SimpleLauncher"
        Width="400" Height="200"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
    
    <Border Background="#1e1e2e" Padding="20">
        <DockPanel>
            <!-- Buttons -->
            <StackPanel DockPanel.Dock="Bottom" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Center" 
                        Spacing="10"
                        Margin="0,15,0,0">
                <Button Content="OK" 
                        Width="80"
                        IsDefault="True"
                        Click="OnOkClick"/>
                <Button Content="Cancel" 
                        Width="80"
                        IsCancel="True"
                        Click="OnCancelClick"
                        IsVisible="{Binding ShowCancel}"/>
            </StackPanel>
            
            <!-- Message -->
            <StackPanel HorizontalAlignment="Center" 
                        VerticalAlignment="Center" 
                        Spacing="10">
                <TextBlock Text="{Binding Message}" 
                           FontSize="14" 
                           Foreground="#cdd6f4"
                           TextWrapping="Wrap"
                           TextAlignment="Center"/>
            </StackPanel>
        </DockPanel>
    </Border>
</Window>
