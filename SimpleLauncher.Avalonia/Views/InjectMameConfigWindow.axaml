<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SimpleLauncher.Avalonia.ViewModels"
        x:Class="SimpleLauncher.Avalonia.Views.InjectMameConfigWindow"
        x:DataType="vm:AvaloniaInjectMameConfigViewModel"
        Title="MAME Configuration"
        Width="700" Height="700"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10" RowDefinitions="*,Auto">
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="10">
                <!-- Video Section -->
                <Border BorderThickness="1" CornerRadius="4" Padding="10">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Video" FontWeight="Bold" FontSize="14" />

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="Video:" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding VideoOptions}"
                                      SelectedItem="{Binding Video}"
                                      ToolTip.Tip="Select the video output method" />
                        </Grid>

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="Bgfx Backend:" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding BgfxBackendOptions}"
                                      SelectedItem="{Binding BgfxBackend}"
                                      ToolTip.Tip="Select the bgfx backend" />
                        </Grid>

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="Bgfx Screen Chains:" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding BgfxChainsOptions}"
                                      SelectedItem="{Binding BgfxScreenChains}"
                                      ToolTip.Tip="Select the bgfx screen chain effect" />
                        </Grid>

                        <CheckBox IsChecked="{Binding Filter}"
                                  Content="Filter"
                                  ToolTip.Tip="Enable bilinear filtering" />

                        <CheckBox IsChecked="{Binding Autoframeskip}"
                                  Content="Autoframeskip"
                                  ToolTip.Tip="Enable automatic frameskip" />
                    </StackPanel>
                </Border>

                <!-- Gameplay Section -->
                <Border BorderThickness="1" CornerRadius="4" Padding="10">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Gameplay" FontWeight="Bold" FontSize="14" />

                        <CheckBox IsChecked="{Binding Cheat}"
                                  Content="Cheat"
                                  ToolTip.Tip="Enable cheat system" />

                        <CheckBox IsChecked="{Binding Rewind}"
                                  Content="Rewind"
                                  ToolTip.Tip="Enable rewind support" />

                        <CheckBox IsChecked="{Binding NvramSave}"
                                  Content="NVRAM Save"
                                  ToolTip.Tip="Save NVRAM data on exit" />

                        <CheckBox IsChecked="{Binding Window}"
                                  Content="Window"
                                  ToolTip.Tip="Run in windowed mode" />

                        <CheckBox IsChecked="{Binding Maximize}"
                                  Content="Maximize"
                                  ToolTip.Tip="Maximize the window" />

                        <CheckBox IsChecked="{Binding KeepAspect}"
                                  Content="Keep Aspect Ratio"
                                  ToolTip.Tip="Maintain correct aspect ratio" />

                        <CheckBox IsChecked="{Binding SkipGameInfo}"
                                  Content="Skip Game Info"
                                  ToolTip.Tip="Skip the game information screen" />

                        <CheckBox IsChecked="{Binding Autosave}"
                                  Content="Autosave"
                                  ToolTip.Tip="Enable automatic save states" />

                        <CheckBox IsChecked="{Binding ConfirmQuit}"
                                  Content="Confirm Quit"
                                  ToolTip.Tip="Show confirmation when quitting" />

                        <CheckBox IsChecked="{Binding Joystick}"
                                  Content="Joystick"
                                  ToolTip.Tip="Enable joystick input" />
                    </StackPanel>
                </Border>

                <!-- Important Setting -->
                <Border BorderThickness="1" CornerRadius="4" Padding="10" BorderBrush="#FFCC00">
                    <StackPanel Spacing="8">
                        <TextBlock Text="IMPORTANT SETTING" FontWeight="Bold" FontSize="14" Foreground="#FFCC00" />
                        <CheckBox IsChecked="{Binding ShowSettingsBeforeLaunch}"
                                  Content="Show settings before launch"
                                  ToolTip.Tip="Show the emulator settings window before launching a game" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0" Spacing="10">
            <Button Content="Save"
                    Command="{Binding SaveCommand}"
                    Width="100"
                    ToolTip.Tip="Save configuration" />
            <Button Content="Run"
                    Command="{Binding RunCommand}"
                    IsVisible="{Binding IsLauncherMode}"
                    IsDefault="True"
                    Width="100"
                    ToolTip.Tip="Save and run" />
            <Button Content="Cancel"
                    Command="{Binding CancelCommand}"
                    IsCancel="True"
                    Width="100"
                    ToolTip.Tip="Cancel" />
        </StackPanel>
    </Grid>
</Window>
