<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SimpleLauncher.Avalonia.ViewModels"
        x:Class="SimpleLauncher.Avalonia.Views.RetroAchievementsSettingsWindow"
        x:DataType="vm:AvaloniaRetroAchievementsSettingsViewModel"
        Title="RetroAchievements Settings"
        Width="550" Height="500"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="15" RowDefinitions="Auto,Auto,Auto,*,Auto" ColumnDefinitions="Auto,*">
        <!-- Username -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Username:" VerticalAlignment="Center" Margin="0,0,10,10" />
        <TextBox Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" Margin="0,0,0,10"
                 Text="{Binding Username}" ToolTip.Tip="Your RetroAchievements username" />

        <!-- API Key -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="API Key:" VerticalAlignment="Center" Margin="0,0,10,10" />
        <TextBox Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" Margin="0,0,0,10"
                 Text="{Binding ApiKey}" ToolTip.Tip="Your RetroAchievements API key" />

        <!-- RA Password -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="RA Password:" VerticalAlignment="Center" Margin="0,0,10,10" />
        <TextBox Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" Margin="0,0,0,10"
                 Text="{Binding Password}" PasswordChar="*" ToolTip.Tip="Your RetroAchievements password" />

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Save"
                    Command="{Binding SaveCommand}"
                    IsDefault="True"
                    Width="80" Margin="0,0,10,0" />
            <Button Content="Cancel"
                    Command="{Binding CancelCommand}"
                    IsCancel="True"
                    Width="80" />
        </StackPanel>
    </Grid>
</Window>
