<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SimpleLauncher.Avalonia.ViewModels"
        x:Class="SimpleLauncher.Avalonia.Views.InjectRaineConfigWindow"
        x:DataType="vm:AvaloniaInjectRaineConfigViewModel"
        Title="Raine Configuration"
        Width="700" Height="700"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10" RowDefinitions="*,Auto">
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="10">
                <!-- Video Section -->
                <Border BorderThickness="1" CornerRadius="4" Padding="10">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Video" FontWeight="Bold" FontSize="14" />

                        <CheckBox IsChecked="{Binding RaineFullscreen}"
                                  Content="Fullscreen"
                                  ToolTip.Tip="Run in fullscreen mode" />

                        <CheckBox IsChecked="{Binding RaineFixAspectRatio}"
                                  Content="Fix Aspect Ratio"
                                  ToolTip.Tip="Fix the aspect ratio to the original" />

                        <CheckBox IsChecked="{Binding RaineVsync}"
                                  Content="VSync"
                                  ToolTip.Tip="Enable vertical sync" />

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="Resolution X:" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding RaineResX}"
                                     ToolTip.Tip="Enter horizontal resolution" />
                        </Grid>

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="Resolution Y:" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding RaineResY}"
                                     ToolTip.Tip="Enter vertical resolution" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Audio Section -->
                <Border BorderThickness="1" CornerRadius="4" Padding="10">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Audio" FontWeight="Bold" FontSize="14" />

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="Sound Driver:" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding SoundDriverOptions}"
                                      SelectedItem="{Binding RaineSoundDriver}"
                                      ToolTip.Tip="Select the sound driver" />
                        </Grid>

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="Sample Rate:" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding SampleRateOptions}"
                                      SelectedItem="{Binding RaineSampleRate}"
                                      ToolTip.Tip="Select the sample rate" />
                        </Grid>

                        <CheckBox IsChecked="{Binding RaineMuteSfx}"
                                  Content="Mute Sound Effects"
                                  ToolTip.Tip="Mute sound effects" />

                        <CheckBox IsChecked="{Binding RaineMuteMusic}"
                                  Content="Mute Music"
                                  ToolTip.Tip="Mute background music" />

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="Music Volume:" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                <Slider Minimum="0" Maximum="100"
                                        Value="{Binding RaineMusicVolume}"
                                        Width="200"
                                        ToolTip.Tip="Adjust music volume" />
                                <TextBlock Text="{Binding RaineMusicVolume}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="SFX Volume:" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                <Slider Minimum="0" Maximum="100"
                                        Value="{Binding RaineSfxVolume}"
                                        Width="200"
                                        ToolTip.Tip="Adjust sound effects volume" />
                                <TextBlock Text="{Binding RaineSfxVolume}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- General Section -->
                <Border BorderThickness="1" CornerRadius="4" Padding="10">
                    <StackPanel Spacing="8">
                        <TextBlock Text="General" FontWeight="Bold" FontSize="14" />

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="Frame Skip:" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding FrameSkipOptions}"
                                      SelectedItem="{Binding RaineFrameSkip}"
                                      ToolTip.Tip="Select the frameskip setting" />
                        </Grid>

                        <CheckBox IsChecked="{Binding RaineShowFps}"
                                  Content="Show FPS"
                                  ToolTip.Tip="Display frames per second counter" />

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="Neo Geo CD BIOS:" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding RaineNeoCdBios}"
                                     ToolTip.Tip="Enter the path to the Neo Geo CD BIOS file" />
                        </Grid>

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="ROM Directory:" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding RaineRomDirectory}"
                                     ToolTip.Tip="Enter the path to the ROM directory" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Important Setting -->
                <Border BorderThickness="1" CornerRadius="4" Padding="10" BorderBrush="#FFCC00">
                    <StackPanel Spacing="8">
                        <TextBlock Text="IMPORTANT SETTING" FontWeight="Bold" FontSize="14" Foreground="#FFCC00" />
                        <CheckBox IsChecked="{Binding RaineShowSettingsBeforeLaunch}"
                                  Content="Show settings before launch"
                                  ToolTip.Tip="Show the emulator settings window before launching a game" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0" Spacing="10">
            <Button Content="Save"
                    Command="{Binding SaveCommand}"
                    Width="100"
                    ToolTip.Tip="Save configuration" />
            <Button Content="Run"
                    Command="{Binding RunCommand}"
                    IsVisible="{Binding IsLauncherMode}"
                    IsDefault="True"
                    Width="100"
                    ToolTip.Tip="Save and run" />
            <Button Content="Cancel"
                    Command="{Binding CancelCommand}"
                    IsCancel="True"
                    Width="100"
                    ToolTip.Tip="Cancel" />
        </StackPanel>
    </Grid>
</Window>
