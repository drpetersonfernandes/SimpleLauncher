<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SimpleLauncher.Avalonia.ViewModels"
        x:Class="SimpleLauncher.Avalonia.Views.InjectCemuConfigWindow"
        x:DataType="vm:AvaloniaInjectCemuConfigViewModel"
        Title="Cemu Configuration"
        Width="700" Height="500"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10" RowDefinitions="*,Auto">
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="10">
                <!-- Graphics Section -->
                <Border BorderThickness="1" CornerRadius="4" Padding="10">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Graphics" FontWeight="Bold" FontSize="14" />

                        <CheckBox IsChecked="{Binding Fullscreen}"
                                  Content="Fullscreen"
                                  ToolTip.Tip="Launch in fullscreen mode" />

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="Graphics API:" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding GraphicApi}"
                                     PlaceholderText="e.g. Vulkan"
                                     ToolTip.Tip="Enter the graphics API" />
                        </Grid>

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="VSync:" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding Vsync}"
                                     PlaceholderText="e.g. True"
                                     ToolTip.Tip="Enter VSync setting" />
                        </Grid>

                        <CheckBox IsChecked="{Binding AsyncCompile}"
                                  Content="Async Compile"
                                  ToolTip.Tip="Enable asynchronous shader compilation" />
                    </StackPanel>
                </Border>

                <!-- Audio Section -->
                <Border BorderThickness="1" CornerRadius="4" Padding="10">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Audio" FontWeight="Bold" FontSize="14" />

                        <StackPanel Spacing="4">
                            <TextBlock Text="Volume:" />
                            <Slider Minimum="0" Maximum="100"
                                    Value="{Binding Volume}"
                                    ToolTip.Tip="Adjust volume (0 to 100)" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- General Section -->
                <Border BorderThickness="1" CornerRadius="4" Padding="10">
                    <StackPanel Spacing="8">
                        <TextBlock Text="General" FontWeight="Bold" FontSize="14" />

                        <CheckBox IsChecked="{Binding Discord}"
                                  Content="Discord"
                                  ToolTip.Tip="Enable Discord Rich Presence" />

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="Language:" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding Language}"
                                     PlaceholderText="e.g. en"
                                     ToolTip.Tip="Enter the language code" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Important Setting -->
                <Border BorderThickness="1" CornerRadius="4" Padding="10" BorderBrush="#FFCC00">
                    <StackPanel Spacing="8">
                        <TextBlock Text="IMPORTANT SETTING" FontWeight="Bold" FontSize="14" Foreground="#FFCC00" />
                        <CheckBox IsChecked="{Binding ShowBeforeLaunch}"
                                  Content="Show settings before launch"
                                  ToolTip.Tip="Show the emulator settings window before launching a game" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0" Spacing="10">
            <Button Content="Save"
                    Command="{Binding SaveCommand}"
                    Width="100"
                    ToolTip.Tip="Save configuration" />
            <Button Content="Run"
                    Command="{Binding RunCommand}"
                    IsVisible="{Binding IsLauncherMode}"
                    IsDefault="True"
                    Width="100"
                    ToolTip.Tip="Save and run" />
            <Button Content="Cancel"
                    Command="{Binding CancelCommand}"
                    IsCancel="True"
                    Width="100"
                    ToolTip.Tip="Cancel" />
        </StackPanel>
    </Grid>
</Window>
