<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SimpleLauncher.Avalonia.ViewModels"
        x:Class="SimpleLauncher.Avalonia.Views.InjectRpcs3ConfigWindow"
        x:DataType="vm:AvaloniaInjectRpcs3ConfigViewModel"
        Title="RPCS3 Configuration"
        Width="700" Height="700"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10" RowDefinitions="*,Auto">
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="10">
                <!-- Video Section -->
                <Border BorderThickness="1" CornerRadius="4" Padding="10">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Video" FontWeight="Bold" FontSize="14" />

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="Renderer:" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding RendererOptions}"
                                      SelectedItem="{Binding Rpcs3Renderer}"
                                      ToolTip.Tip="Select the graphics renderer" />
                        </Grid>

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="Resolution:" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding ResolutionOptions}"
                                      SelectedItem="{Binding Rpcs3Resolution}"
                                      ToolTip.Tip="Select the output resolution" />
                        </Grid>

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="Aspect Ratio:" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AspectRatioOptions}"
                                      SelectedItem="{Binding Rpcs3AspectRatio}"
                                      ToolTip.Tip="Select the aspect ratio" />
                        </Grid>

                        <CheckBox IsChecked="{Binding Rpcs3Vsync}"
                                  Content="VSync"
                                  ToolTip.Tip="Enable vertical sync" />

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="Resolution Scale:" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding ResolutionScaleOptions}"
                                      SelectedItem="{Binding Rpcs3ResolutionScale}"
                                      ToolTip.Tip="Select the resolution scale percentage" />
                        </Grid>

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="Anisotropic Filter:" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AnisotropicFilterOptions}"
                                      SelectedItem="{Binding Rpcs3AnisotropicFilter}"
                                      ToolTip.Tip="Select the anisotropic filtering level" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- CPU Section -->
                <Border BorderThickness="1" CornerRadius="4" Padding="10">
                    <StackPanel Spacing="8">
                        <TextBlock Text="CPU" FontWeight="Bold" FontSize="14" />

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="PPU Decoder:" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding PpuDecoderOptions}"
                                      SelectedItem="{Binding Rpcs3PpuDecoder}"
                                      ToolTip.Tip="Select the PPU decoder" />
                        </Grid>

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="SPU Decoder:" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding SpuDecoderOptions}"
                                      SelectedItem="{Binding Rpcs3SpuDecoder}"
                                      ToolTip.Tip="Select the SPU decoder" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Audio Section -->
                <Border BorderThickness="1" CornerRadius="4" Padding="10">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Audio" FontWeight="Bold" FontSize="14" />

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="Audio Renderer:" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AudioRendererOptions}"
                                      SelectedItem="{Binding Rpcs3AudioRenderer}"
                                      ToolTip.Tip="Select the audio renderer" />
                        </Grid>

                        <CheckBox IsChecked="{Binding Rpcs3AudioBuffering}"
                                  Content="Audio Buffering"
                                  ToolTip.Tip="Enable audio buffering" />
                    </StackPanel>
                </Border>

                <!-- General Section -->
                <Border BorderThickness="1" CornerRadius="4" Padding="10">
                    <StackPanel Spacing="8">
                        <TextBlock Text="General" FontWeight="Bold" FontSize="14" />

                        <CheckBox IsChecked="{Binding Rpcs3StartFullscreen}"
                                  Content="Start in Fullscreen"
                                  ToolTip.Tip="Start the emulator in fullscreen mode" />
                    </StackPanel>
                </Border>

                <!-- Important Setting -->
                <Border BorderThickness="1" CornerRadius="4" Padding="10" BorderBrush="#FFCC00">
                    <StackPanel Spacing="8">
                        <TextBlock Text="IMPORTANT SETTING" FontWeight="Bold" FontSize="14" Foreground="#FFCC00" />
                        <CheckBox IsChecked="{Binding Rpcs3ShowSettingsBeforeLaunch}"
                                  Content="Show settings before launch"
                                  ToolTip.Tip="Show the emulator settings window before launching a game" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0" Spacing="10">
            <Button Content="Save"
                    Command="{Binding SaveCommand}"
                    Width="100"
                    ToolTip.Tip="Save configuration" />
            <Button Content="Run"
                    Command="{Binding RunCommand}"
                    IsVisible="{Binding IsLauncherMode}"
                    IsDefault="True"
                    Width="100"
                    ToolTip.Tip="Save and run" />
            <Button Content="Cancel"
                    Command="{Binding CancelCommand}"
                    IsCancel="True"
                    Width="100"
                    ToolTip.Tip="Cancel" />
        </StackPanel>
    </Grid>
</Window>
