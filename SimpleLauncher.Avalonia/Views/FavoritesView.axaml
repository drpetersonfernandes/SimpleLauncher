<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="SimpleLauncher.Avalonia.Views.FavoritesView"
             x:DataType="x:String">
    
    <Border Background="#313244" Padding="15">
        <DockPanel>
            <!-- Header -->
            <Border DockPanel.Dock="Top" Background="#45475a" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                <StackPanel Spacing="10">
                    <TextBlock Text="Favorites" 
                               FontSize="20" FontWeight="Bold" 
                               Foreground="#cdd6f4"/>
                    <TextBlock Text="Your favorite games" 
                               Foreground="#a6adc8"/>
                </StackPanel>
            </Border>
            
            <!-- Content -->
            <ScrollViewer>
                <StackPanel Spacing="10">
                    <Border Background="#45475a" CornerRadius="8" Padding="15">
                        <StackPanel Spacing="10">
                            <TextBlock Text="No favorites yet" 
                                       Foreground="#6c7086"
                                       HorizontalAlignment="Center"
                                       FontSize="14"/>
                            <TextBlock Text="Add games to your favorites to see them here" 
                                       Foreground="#45475a"
                                       HorizontalAlignment="Center"
                                       FontSize="12"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</UserControl>
