<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SimpleLauncher.Avalonia"
             xmlns:models="using:SimpleLauncher.Core.Models"
             x:Class="SimpleLauncher.Avalonia.Views.FavoritesView"
             x:DataType="vm:FavoritesViewModel">
    
    <Border Background="#313244" Padding="15">
        <DockPanel>
            <!-- Header -->
            <Border DockPanel.Dock="Top" Background="#45475a" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="5">
                        <TextBlock Text="Favorites" 
                                   FontSize="20" FontWeight="Bold" 
                                   Foreground="#cdd6f4"/>
                        <TextBlock Text="Your favorite games" 
                                   Foreground="#a6adc8"/>
                    </StackPanel>
                    
                    <!-- Action Buttons -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <Button Content="Launch" 
                                Command="{Binding LaunchGameCommand}"
                                IsEnabled="{Binding SelectedFavorite, Converter={x:Static ObjectConverters.IsNotNull}}"
                                Padding="10,5"/>
                        <Button Content="Remove" 
                                Command="{Binding RemoveFavoriteCommand}"
                                IsEnabled="{Binding SelectedFavorite, Converter={x:Static ObjectConverters.IsNotNull}}"
                                Padding="10,5"
                                Background="#f38ba8"/>
                    </StackPanel>
                </Grid>
            </Border>
            
            <!-- Content -->
            <Panel>
                <!-- Loading Overlay -->
                <Border IsVisible="{Binding IsLoading}" 
                        Background="#80000000" 
                        ZIndex="100">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
                        <ProgressBar IsIndeterminate="True" Width="200"/>
                        <TextBlock Text="{Binding LoadingMessage}" Foreground="#cdd6f4" FontSize="14"/>
                    </StackPanel>
                </Border>
                
                <!-- Empty State -->
                <Border IsVisible="{Binding IsEmpty}" 
                        Background="#45475a" CornerRadius="8" Padding="30"
                        VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel Spacing="10" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE734;" FontFamily="Segoe Fluent Icons" 
                                   FontSize="48" Foreground="#6c7086"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="No favorites yet" 
                                   Foreground="#6c7086"
                                   HorizontalAlignment="Center"
                                   FontSize="16"/>
                        <TextBlock Text="Add games to your favorites to see them here" 
                                   Foreground="#45475a"
                                   HorizontalAlignment="Center"
                                   FontSize="12"/>
                    </StackPanel>
                </Border>
                
                <!-- Favorites List -->
                <ListBox ItemsSource="{Binding Favorites}"
                         SelectedItem="{Binding SelectedFavorite}"
                         IsVisible="{Binding !IsEmpty}"
                         Background="Transparent"
                         BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:Favorite">
                            <Border Background="#45475a" 
                                    CornerRadius="8" 
                                    Padding="15" 
                                    Margin="0,2">
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <!-- Cover Image -->
                                    <Border Background="#585b70" 
                                            CornerRadius="4" 
                                            Width="60" Height="60">
                                        <Image Source="{Binding CoverImage}" 
                                               Stretch="Uniform"/>
                                    </Border>
                                    
                                    <!-- Info -->
                                    <StackPanel Grid.Column="1" Margin="15,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding FileName}" 
                                                   Foreground="#cdd6f4" 
                                                   FontSize="14"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding SystemName}" 
                                                   Foreground="#a6adc8" 
                                                   FontSize="12"
                                                   Margin="0,5,0,0"/>
                                        <TextBlock Text="{Binding DefaultEmulator}" 
                                                   Foreground="#6c7086" 
                                                   FontSize="11"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                    
                                    <!-- Favorite Icon -->
                                    <TextBlock Grid.Column="2" 
                                               Text="&#xE734;" FontFamily="Segoe Fluent Icons"
                                               Foreground="#f9e2af"
                                               FontSize="20"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Panel>
        </DockPanel>
    </Border>
</UserControl>
