<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SimpleLauncher.Core.ViewModels"
        x:Class="SimpleLauncher.Avalonia.Views.SystemSelectionWindow"
        x:DataType="vm:SystemSelectionViewModel"
        Title="Select a System"
        Height="220" Width="400"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Select the system that this game belongs to."
                       TextWrapping="Wrap"
                       Margin="0,0,0,10" />

            <TextBlock Text="System:"
                       FontWeight="Bold"
                       Margin="0,0,0,5" />

            <ComboBox ItemsSource="{Binding Systems}"
                      SelectedItem="{Binding SelectedSystem}"
                      Margin="0,0,0,30" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Confirm"
                        Command="{Binding ConfirmCommand}"
                        Margin="0,0,10,0"
                        Width="120" />

                <Button Content="Cancel"
                        Command="{Binding CancelCommand}"
                        Width="80" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
