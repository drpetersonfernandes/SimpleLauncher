<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SimpleLauncher.Avalonia.ViewModels"
        x:Class="SimpleLauncher.Avalonia.Views.InjectXeniaConfigWindow"
        x:DataType="vm:AvaloniaInjectXeniaConfigViewModel"
        Title="Xenia Configuration"
        Width="700" Height="700"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10" RowDefinitions="*,Auto">
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="10">
                <!-- GPU Section -->
                <Border BorderThickness="1" CornerRadius="4" Padding="10">
                    <StackPanel Spacing="8">
                        <TextBlock Text="GPU" FontWeight="Bold" FontSize="14" />

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="GPU:" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding GpuOptions}"
                                      SelectedItem="{Binding XeniaGpu}"
                                      ToolTip.Tip="Select the GPU backend" />
                        </Grid>

                        <CheckBox IsChecked="{Binding XeniaVsync}"
                                  Content="VSync"
                                  ToolTip.Tip="Enable vertical sync" />

                        <CheckBox IsChecked="{Binding XeniaFullscreen}"
                                  Content="Fullscreen"
                                  ToolTip.Tip="Run in fullscreen mode" />

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="Resolution Scale X:" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding XeniaResScaleX}"
                                     ToolTip.Tip="Horizontal resolution scale factor" />
                        </Grid>

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="Resolution Scale Y:" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding XeniaResScaleY}"
                                     ToolTip.Tip="Vertical resolution scale factor" />
                        </Grid>

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="Anti-Aliasing:" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AaOptions}"
                                      SelectedValue="{Binding XeniaAa}"
                                      SelectedValueBinding="{Binding Tag}"
                                      ToolTip.Tip="Select the anti-aliasing mode">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Display}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </Grid>

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="Scaling:" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding ScalingOptions}"
                                      SelectedItem="{Binding XeniaScaling}"
                                      ToolTip.Tip="Select the scaling method" />
                        </Grid>

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="Readback Resolve:" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding ReadbackOptions}"
                                      SelectedItem="{Binding XeniaReadbackResolve}"
                                      ToolTip.Tip="Select the readback resolve mode" />
                        </Grid>

                        <CheckBox IsChecked="{Binding XeniaGammaSrgb}"
                                  Content="Gamma sRGB"
                                  ToolTip.Tip="Enable gamma sRGB correction" />
                    </StackPanel>
                </Border>

                <!-- Audio Section -->
                <Border BorderThickness="1" CornerRadius="4" Padding="10">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Audio" FontWeight="Bold" FontSize="14" />

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="APU:" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding ApuOptions}"
                                      SelectedItem="{Binding XeniaApu}"
                                      ToolTip.Tip="Select the audio processing unit backend" />
                        </Grid>

                        <CheckBox IsChecked="{Binding XeniaMute}"
                                  Content="Mute"
                                  ToolTip.Tip="Mute audio output" />
                    </StackPanel>
                </Border>

                <!-- General Section -->
                <Border BorderThickness="1" CornerRadius="4" Padding="10">
                    <StackPanel Spacing="8">
                        <TextBlock Text="General" FontWeight="Bold" FontSize="14" />

                        <CheckBox IsChecked="{Binding XeniaMountCache}"
                                  Content="Mount Cache"
                                  ToolTip.Tip="Mount the cache filesystem" />

                        <CheckBox IsChecked="{Binding XeniaVibration}"
                                  Content="Vibration"
                                  ToolTip.Tip="Enable controller vibration" />

                        <CheckBox IsChecked="{Binding XeniaApplyPatches}"
                                  Content="Apply Patches"
                                  ToolTip.Tip="Apply game patches" />

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="HID:" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding HidOptions}"
                                      SelectedItem="{Binding XeniaHid}"
                                      ToolTip.Tip="Select the HID input system" />
                        </Grid>

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="User Language:" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding LangOptions}"
                                      SelectedValue="{Binding XeniaUserLanguage}"
                                      SelectedValueBinding="{Binding Tag}"
                                      ToolTip.Tip="Select the user language">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Display}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Important Setting -->
                <Border BorderThickness="1" CornerRadius="4" Padding="10" BorderBrush="#FFCC00">
                    <StackPanel Spacing="8">
                        <TextBlock Text="IMPORTANT SETTING" FontWeight="Bold" FontSize="14" Foreground="#FFCC00" />
                        <CheckBox IsChecked="{Binding XeniaShowSettingsBeforeLaunch}"
                                  Content="Show settings before launch"
                                  ToolTip.Tip="Show the emulator settings window before launching a game" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0" Spacing="10">
            <Button Content="Save"
                    Command="{Binding SaveCommand}"
                    Width="100"
                    ToolTip.Tip="Save configuration" />
            <Button Content="Run"
                    Command="{Binding RunCommand}"
                    IsVisible="{Binding IsLauncherMode}"
                    IsDefault="True"
                    Width="100"
                    ToolTip.Tip="Save and run" />
            <Button Content="Cancel"
                    Command="{Binding CancelCommand}"
                    IsCancel="True"
                    Width="100"
                    ToolTip.Tip="Cancel" />
        </StackPanel>
    </Grid>
</Window>
