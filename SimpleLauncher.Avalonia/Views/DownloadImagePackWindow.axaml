<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SimpleLauncher.Avalonia.ViewModels"
        xmlns:models="using:SimpleLauncher.Core.Services.DownloadService.Models"
        x:Class="SimpleLauncher.Avalonia.Views.DownloadImagePackWindow"
        x:Name="DownloadImagePackWindowRoot"
        x:DataType="vm:AvaloniaDownloadImagePackViewModel"
        Title="Download Image Pack"
        Width="650" Height="600"
        MinWidth="550" MinHeight="500"
        WindowStartupLocation="CenterScreen">

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="20,20,20,10">
            <TextBlock Text="Download Image Pack" FontSize="24" FontWeight="Light" Margin="0,0,0,10" />
            <TextBlock Text="Download high-quality artwork for your game systems" TextWrapping="Wrap" FontSize="12" Opacity="0.6" />
        </StackPanel>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="20,10,20,10"
              IsEnabled="{Binding IsMainContentEnabled}"
              ColumnDefinitions="*,20,*">
            <!-- Left Column: Selection & Info -->
            <StackPanel Grid.Column="0" Spacing="10">
                <TextBlock Text="Select an Image Pack:" FontWeight="SemiBold" />
                <ComboBox HorizontalAlignment="Stretch"
                          ItemsSource="{Binding SystemNames}"
                          SelectedItem="{Binding SelectedSystemName}"
                          IsEnabled="{Binding IsSystemDropdownEnabled}"
                          PlaceholderText="Select a system" />

                <StackPanel Margin="0,20,0,0" Spacing="5">
                    <TextBlock Text="Resources" FontWeight="SemiBold" />
                    <TextBlock Text="In case the Image Pack is not available below, you can try these resources:"
                               TextWrapping="Wrap" FontSize="12" Opacity="0.6" />

                    <Button Content="Libretro Thumbnails (GitHub)"
                            HorizontalAlignment="Left"
                            Command="{Binding HyperlinkNavigateCommand}"
                            CommandParameter="https://github.com/libretro-thumbnails/libretro-thumbnails" />

                    <Button Content="EmuMovies Files"
                            HorizontalAlignment="Left"
                            Command="{Binding HyperlinkNavigateCommand}"
                            CommandParameter="https://emumovies.com/files/" />
                </StackPanel>
            </StackPanel>

            <!-- Right Column: Download Actions -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="10">
                    <TextBlock Text="Install Image Pack" FontWeight="SemiBold" />

                    <Border BorderThickness="1" CornerRadius="3" Padding="10">
                        <ItemsControl ItemsSource="{Binding ImagePacksToDisplay}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:ImagePackDownloadItem">
                                    <Button Content="{Binding DisplayName}"
                                            Height="40"
                                            Margin="5"
                                            Command="{ReflectionBinding #DownloadImagePackWindowRoot.DataContext.DownloadImagePackCommand, TargetNullValue={x:Null}}"
                                            CommandParameter="{Binding}"
                                            IsEnabled="{Binding CanStartDownload}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <TextBlock Text="Select a system from the dropdown, then click an image pack to download."
                               TextWrapping="Wrap" FontSize="11" Opacity="0.6" FontStyle="Italic" />
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Footer: Progress -->
        <Border Grid.Row="2" BorderThickness="0,1,0,0" Padding="20">
            <Grid ColumnDefinitions="*,Auto">
                <Grid Grid.Column="0" Margin="0,0,20,0" RowDefinitions="Auto,Auto">
                    <Grid>
                        <ProgressBar Value="{Binding ProgressPercentage}" Height="20" />
                        <TextBlock Text="Download Progress"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontSize="10" />
                    </Grid>

                    <TextBlock Grid.Row="1" Margin="0,5,0,0"
                               Text="{Binding StatusMessage}"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold" />
                </Grid>

                <Button Grid.Column="1"
                        Content="Stop Download"
                        Command="{Binding StopDownloadCommand}"
                        IsEnabled="{Binding IsStopEnabled}"
                        Padding="20,10" />
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                IsVisible="{Binding IsLoading}"
                Background="#80000000"
                ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10">
                <ProgressBar IsIndeterminate="True" Width="200" />
                <TextBlock Text="{Binding LoadingMessage}" HorizontalAlignment="Center" FontSize="14" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
