<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SimpleLauncher.Avalonia.ViewModels"
        x:Class="SimpleLauncher.Avalonia.Views.SetLinksWindow"
        x:DataType="vm:AvaloniaSetLinksViewModel"
        Title="Edit Links"
        Width="600" Height="270"
        WindowStartupLocation="CenterScreen"
        CanResize="False">

    <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="Auto,*">
        <!-- Explanation -->
        <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                   Margin="10,20,10,10"
                   Text="You can define custom URLs for video and info links. Use {0} as a placeholder for the game name."
                   TextWrapping="Wrap"
                   HorizontalAlignment="Left"
                   TextAlignment="Justify" />

        <!-- Video Link -->
        <TextBlock Grid.Row="1" Grid.Column="0"
                   Margin="10"
                   VerticalAlignment="Center"
                   Text="Video Link:" />
        <TextBox Grid.Row="1" Grid.Column="1"
                 Margin="10"
                 HorizontalAlignment="Stretch"
                 Text="{Binding VideoUrl}"
                 Watermark="https://www.youtube.com/results?search_query=" />

        <!-- Info Link -->
        <TextBlock Grid.Row="2" Grid.Column="0"
                   Margin="10"
                   VerticalAlignment="Center"
                   Text="Info Link:" />
        <TextBox Grid.Row="2" Grid.Column="1"
                 Margin="10"
                 Text="{Binding InfoUrl}"
                 Watermark="https://www.igdb.com/search?q=" />

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="10">
            <Button Content="Save Links"
                    Command="{Binding SaveCommand}"
                    IsDefault="True"
                    Width="120" Margin="0,0,10,0" />
            <Button Content="Revert to Defaults"
                    Command="{Binding RevertCommand}"
                    Width="120" />
        </StackPanel>
    </Grid>
</Window>
