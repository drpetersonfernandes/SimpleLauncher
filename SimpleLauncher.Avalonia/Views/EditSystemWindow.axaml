<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SimpleLauncher.Avalonia"
        x:Class="SimpleLauncher.Avalonia.Views.EditSystemWindow"
        x:DataType="vm:EditSystemViewModel"
        Title="Edit System"
        Width="700" Height="600"
        WindowStartupLocation="CenterOwner">
    
    <Design.DataContext>
        <x:Type TypeName="vm:EditSystemViewModel"/>
    </Design.DataContext>
    
    <Border Background="#1e1e2e" Padding="20">
        <DockPanel>
            <!-- Header -->
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,15">
                <TextBlock Text="{Binding IsNewSystem, StringFormat='{}{0}'}" 
                           FontSize="20" FontWeight="Bold" 
                           Foreground="#cdd6f4"/>
                <TextBlock Text="Configure system settings and emulators" 
                           Foreground="#a6adc8"
                           Margin="0,5,0,0"/>
            </StackPanel>
            
            <!-- Buttons -->
            <StackPanel DockPanel.Dock="Bottom" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Right" 
                        Spacing="10"
                        Margin="0,15,0,0">
                <Button Content="Save" 
                        Width="80"
                        Command="{Binding SaveCommand}"/>
                <Button Content="Cancel" 
                        Width="80"
                        Command="{Binding CancelCommand}"/>
            </StackPanel>
            
            <!-- Content -->
            <Panel>
                <!-- Loading Overlay -->
                <Border IsVisible="{Binding IsLoading}" 
                        Background="#80000000" 
                        ZIndex="100">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
                        <ProgressBar IsIndeterminate="True" Width="200"/>
                        <TextBlock Text="{Binding LoadingMessage}" Foreground="#cdd6f4" FontSize="14"/>
                    </StackPanel>
                </Border>
                
                <!-- Main Content -->
                <ScrollViewer>
                    <StackPanel Spacing="15">
                        <!-- System Name -->
                        <Border Background="#45475a" CornerRadius="8" Padding="15">
                            <StackPanel Spacing="10">
                                <TextBlock Text="System Name" 
                                           FontSize="14" FontWeight="Bold" 
                                           Foreground="#cdd6f4"/>
                                
                                <TextBox Text="{Binding SystemName}" 
                                         PlaceholderText="Enter system name..."/>
                            </StackPanel>
                        </Border>
                        
                        <!-- System Folders -->
                        <Border Background="#45475a" CornerRadius="8" Padding="15">
                            <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Text="System Folders" 
                                               FontSize="14" FontWeight="Bold" 
                                               Foreground="#cdd6f4"/>
                                    <Button Grid.Column="1" 
                                            Content="Add Folder" 
                                            Command="{Binding AddSystemFolderCommand}"
                                            Padding="10,5"/>
                                </Grid>
                                
                                <ListBox ItemsSource="{Binding SystemFolders}"
                                         MinHeight="100"
                                         MaxHeight="150">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBlock Text="{Binding}" 
                                                           Foreground="#cdd6f4"
                                                           VerticalAlignment="Center"/>
                                                <Button Grid.Column="1" 
                                                        Content="Remove"
                                                        Padding="8,3"
                                                        Background="#f38ba8"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>
                        
                        <!-- Image Folder -->
                        <Border Background="#45475a" CornerRadius="8" Padding="15">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Image Folder" 
                                           FontSize="14" FontWeight="Bold" 
                                           Foreground="#cdd6f4"/>
                                
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBox Text="{Binding SystemImageFolder}" 
                                             PlaceholderText="Select folder..."
                                             IsReadOnly="True"/>
                                    <Button Grid.Column="1" 
                                            Content="Browse" 
                                            Command="{Binding ChooseImageFolderCommand}"
                                            Margin="10,0,0,0"
                                            Padding="15,5"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                        
                        <!-- File Formats -->
                        <Border Background="#45475a" CornerRadius="8" Padding="15">
                            <StackPanel Spacing="10">
                                <TextBlock Text="File Formats" 
                                           FontSize="14" FontWeight="Bold" 
                                           Foreground="#cdd6f4"/>
                                
                                <CheckBox Content="Extract file before launch" 
                                          IsChecked="{Binding ExtractFileBeforeLaunch}"
                                          Foreground="#a6adc8"/>
                                
                                <CheckBox Content="Group by folder" 
                                          IsChecked="{Binding GroupByFolder}"
                                          Foreground="#a6adc8"/>
                                
                                <CheckBox Content="Disable recursive search" 
                                          IsChecked="{Binding DisableRecursiveSearch}"
                                          Foreground="#a6adc8"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Emulators -->
                        <Border Background="#45475a" CornerRadius="8" Padding="15">
                            <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="*,Auto,Auto">
                                    <TextBlock Text="Emulators" 
                                               FontSize="14" FontWeight="Bold" 
                                               Foreground="#cdd6f4"/>
                                    <Button Grid.Column="1" 
                                            Content="Add" 
                                            Command="{Binding AddEmulatorCommand}"
                                            Margin="10,0"
                                            Padding="10,5"/>
                                    <Button Grid.Column="2" 
                                            Content="Remove" 
                                            Command="{Binding RemoveEmulatorCommand}"
                                            IsEnabled="{Binding SelectedEmulator, Converter={x:Static ObjectConverters.IsNotNull}}"
                                            Padding="10,5"
                                            Background="#f38ba8"/>
                                </Grid>
                                
                                <ListBox ItemsSource="{Binding Emulators}"
                                         SelectedItem="{Binding SelectedEmulator}"
                                         MinHeight="100"
                                         MaxHeight="200">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:EmulatorItem">
                                            <StackPanel Spacing="5">
                                                <TextBlock Text="{Binding Name}" 
                                                           Foreground="#cdd6f4"
                                                           FontWeight="Bold"/>
                                                <TextBlock Text="{Binding Location}" 
                                                           Foreground="#a6adc8"
                                                           FontSize="11"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Panel>
        </DockPanel>
    </Border>
</Window>
