<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SimpleLauncher.Avalonia.ViewModels"
        x:Class="SimpleLauncher.Avalonia.Views.InjectStellaConfigWindow"
        x:DataType="vm:AvaloniaInjectStellaConfigViewModel"
        Title="Stella Configuration"
        Width="700" Height="600"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10" RowDefinitions="*,Auto">
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="10">
                <!-- Video Section -->
                <Border BorderThickness="1" CornerRadius="4" Padding="10">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Video" FontWeight="Bold" FontSize="14" />

                        <CheckBox IsChecked="{Binding Fullscreen}"
                                  Content="Fullscreen"
                                  ToolTip.Tip="Start in fullscreen mode" />

                        <CheckBox IsChecked="{Binding Vsync}"
                                  Content="VSync"
                                  ToolTip.Tip="Enable vertical sync" />

                        <CheckBox IsChecked="{Binding CorrectAspect}"
                                  Content="Correct Aspect Ratio"
                                  ToolTip.Tip="Maintain correct aspect ratio" />

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="Video Driver:" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding VideoDriverOptions}"
                                      SelectedItem="{Binding VideoDriver}"
                                      ToolTip.Tip="Select the video driver" />
                        </Grid>

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="TV Filter:" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding TvFilterOptions}"
                                      SelectedItem="{Binding TvFilter}"
                                      ToolTip.Tip="Select the TV filter effect" />
                        </Grid>

                        <Grid ColumnDefinitions="Auto,*">
                            <TextBlock Text="Scanlines:" VerticalAlignment="Center" />
                            <Slider Grid.Column="1"
                                    Value="{Binding Scanlines}"
                                    Minimum="0" Maximum="100"
                                    TickFrequency="10" IsSnapToTickEnabled="True"
                                    ToolTip.Tip="Set the scanline intensity" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Audio Section -->
                <Border BorderThickness="1" CornerRadius="4" Padding="10">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Audio" FontWeight="Bold" FontSize="14" />

                        <CheckBox IsChecked="{Binding AudioEnabled}"
                                  Content="Audio Enabled"
                                  ToolTip.Tip="Enable audio output" />

                        <Grid ColumnDefinitions="Auto,*">
                            <TextBlock Text="Volume:" VerticalAlignment="Center" />
                            <Slider Grid.Column="1"
                                    Value="{Binding AudioVolume}"
                                    Minimum="0" Maximum="100"
                                    TickFrequency="10" IsSnapToTickEnabled="True"
                                    ToolTip.Tip="Set the audio volume" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- General Section -->
                <Border BorderThickness="1" CornerRadius="4" Padding="10">
                    <StackPanel Spacing="8">
                        <TextBlock Text="General" FontWeight="Bold" FontSize="14" />

                        <CheckBox IsChecked="{Binding TimeMachine}"
                                  Content="Time Machine"
                                  ToolTip.Tip="Enable Time Machine rewind feature" />

                        <CheckBox IsChecked="{Binding ConfirmExit}"
                                  Content="Confirm Exit"
                                  ToolTip.Tip="Show confirmation dialog when exiting" />
                    </StackPanel>
                </Border>

                <!-- Important Setting -->
                <Border BorderThickness="1" CornerRadius="4" Padding="10" BorderBrush="#FFCC00">
                    <StackPanel Spacing="8">
                        <TextBlock Text="IMPORTANT SETTING" FontWeight="Bold" FontSize="14" Foreground="#FFCC00" />
                        <CheckBox IsChecked="{Binding ShowBeforeLaunch}"
                                  Content="Show settings before launch"
                                  ToolTip.Tip="Show the emulator settings window before launching a game" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0" Spacing="10">
            <Button Content="Save"
                    Command="{Binding SaveCommand}"
                    Width="100"
                    ToolTip.Tip="Save configuration" />
            <Button Content="Run"
                    Command="{Binding RunCommand}"
                    IsVisible="{Binding IsLauncherMode}"
                    IsDefault="True"
                    Width="100"
                    ToolTip.Tip="Save and run" />
            <Button Content="Cancel"
                    Command="{Binding CancelCommand}"
                    IsCancel="True"
                    Width="100"
                    ToolTip.Tip="Cancel" />
        </StackPanel>
    </Grid>
</Window>
