<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SimpleLauncher.Avalonia.ViewModels"
        x:Class="SimpleLauncher.Avalonia.Views.InjectRetroArchConfigWindow"
        x:DataType="vm:AvaloniaInjectRetroArchConfigViewModel"
        Title="RetroArch Configuration"
        Width="700" Height="800"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10" RowDefinitions="*,Auto">
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="10">
                <!-- Video Section -->
                <Border BorderThickness="1" CornerRadius="4" Padding="10">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Video" FontWeight="Bold" FontSize="14" />

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="Video Driver:" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding VideoDriverOptions}"
                                      SelectedItem="{Binding VideoDriver}"
                                      ToolTip.Tip="Select the video driver" />
                        </Grid>

                        <CheckBox IsChecked="{Binding Fullscreen}"
                                  Content="Fullscreen"
                                  ToolTip.Tip="Start in fullscreen mode" />

                        <CheckBox IsChecked="{Binding Vsync}"
                                  Content="VSync"
                                  ToolTip.Tip="Enable vertical sync" />

                        <CheckBox IsChecked="{Binding ThreadedVideo}"
                                  Content="Threaded Video"
                                  ToolTip.Tip="Enable threaded video" />

                        <CheckBox IsChecked="{Binding Bilinear}"
                                  Content="Bilinear Filtering"
                                  ToolTip.Tip="Enable bilinear filtering" />

                        <CheckBox IsChecked="{Binding ScaleInteger}"
                                  Content="Integer Scale"
                                  ToolTip.Tip="Enable integer scaling" />

                        <CheckBox IsChecked="{Binding ShaderEnable}"
                                  Content="Enable Shaders"
                                  ToolTip.Tip="Enable shader effects" />

                        <CheckBox IsChecked="{Binding HardSync}"
                                  Content="Hard GPU Sync"
                                  ToolTip.Tip="Enable hard GPU sync" />

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="Aspect Ratio:" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AspectRatioIndexDisplayOptions}"
                                      SelectedItem="{Binding AspectRatioIndexDisplay}"
                                      ToolTip.Tip="Select the aspect ratio" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Audio Section -->
                <Border BorderThickness="1" CornerRadius="4" Padding="10">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Audio" FontWeight="Bold" FontSize="14" />

                        <CheckBox IsChecked="{Binding AudioEnable}"
                                  Content="Audio Enable"
                                  ToolTip.Tip="Enable audio output" />

                        <CheckBox IsChecked="{Binding AudioMute}"
                                  Content="Audio Mute"
                                  ToolTip.Tip="Mute audio output" />
                    </StackPanel>
                </Border>

                <!-- Automation Section -->
                <Border BorderThickness="1" CornerRadius="4" Padding="10">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Automation" FontWeight="Bold" FontSize="14" />

                        <CheckBox IsChecked="{Binding PauseNonActive}"
                                  Content="Pause When Inactive"
                                  ToolTip.Tip="Pause emulation when window is not focused" />

                        <CheckBox IsChecked="{Binding SaveOnExit}"
                                  Content="Save on Exit"
                                  ToolTip.Tip="Save state when exiting" />

                        <CheckBox IsChecked="{Binding AutoSaveState}"
                                  Content="Auto Save State"
                                  ToolTip.Tip="Automatically save state" />

                        <CheckBox IsChecked="{Binding AutoLoadState}"
                                  Content="Auto Load State"
                                  ToolTip.Tip="Automatically load saved state" />

                        <CheckBox IsChecked="{Binding Rewind}"
                                  Content="Rewind"
                                  ToolTip.Tip="Enable rewind support" />

                        <CheckBox IsChecked="{Binding RunAhead}"
                                  Content="Run-Ahead"
                                  ToolTip.Tip="Enable run-ahead for reduced latency" />
                    </StackPanel>
                </Border>

                <!-- UI Section -->
                <Border BorderThickness="1" CornerRadius="4" Padding="10">
                    <StackPanel Spacing="8">
                        <TextBlock Text="UI" FontWeight="Bold" FontSize="14" />

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="Menu Driver:" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding MenuDriverOptions}"
                                      SelectedItem="{Binding MenuDriver}"
                                      ToolTip.Tip="Select the menu driver" />
                        </Grid>

                        <CheckBox IsChecked="{Binding ShowAdvancedSettings}"
                                  Content="Show Advanced Settings"
                                  ToolTip.Tip="Show advanced settings in the RetroArch menu" />
                    </StackPanel>
                </Border>

                <!-- RetroAchievements Section -->
                <Border BorderThickness="1" CornerRadius="4" Padding="10">
                    <StackPanel Spacing="8">
                        <TextBlock Text="RetroAchievements" FontWeight="Bold" FontSize="14" />

                        <CheckBox IsChecked="{Binding CheevosEnable}"
                                  Content="Enable RetroAchievements"
                                  ToolTip.Tip="Enable RetroAchievements support" />

                        <CheckBox IsChecked="{Binding CheevosHardcore}"
                                  Content="Hardcore Mode"
                                  ToolTip.Tip="Enable RetroAchievements hardcore mode" />

                        <CheckBox IsChecked="{Binding DiscordAllow}"
                                  Content="Discord Rich Presence"
                                  ToolTip.Tip="Allow Discord rich presence integration" />
                    </StackPanel>
                </Border>

                <!-- Important Setting -->
                <Border BorderThickness="1" CornerRadius="4" Padding="10" BorderBrush="#FFCC00">
                    <StackPanel Spacing="8">
                        <TextBlock Text="IMPORTANT SETTING" FontWeight="Bold" FontSize="14" Foreground="#FFCC00" />
                        <CheckBox IsChecked="{Binding ShowBeforeLaunch}"
                                  Content="Show settings before launch"
                                  ToolTip.Tip="Show the emulator settings window before launching a game" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0" Spacing="10">
            <Button Content="Save"
                    Command="{Binding SaveCommand}"
                    Width="100"
                    ToolTip.Tip="Save configuration" />
            <Button Content="Run"
                    Command="{Binding RunCommand}"
                    IsVisible="{Binding IsLauncherMode}"
                    IsDefault="True"
                    Width="100"
                    ToolTip.Tip="Save and run" />
            <Button Content="Cancel"
                    Command="{Binding CancelCommand}"
                    IsCancel="True"
                    Width="100"
                    ToolTip.Tip="Cancel" />
        </StackPanel>
    </Grid>
</Window>
