<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SimpleLauncher.Avalonia.ViewModels"
        x:Class="SimpleLauncher.Avalonia.Views.InjectYumirConfigWindow"
        x:DataType="vm:AvaloniaInjectYumirConfigViewModel"
        Title="Yumir Configuration"
        Width="700" Height="500"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10" RowDefinitions="*,Auto">
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="10">
                <!-- Video Section -->
                <Border BorderThickness="1" CornerRadius="4" Padding="10">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Video" FontWeight="Bold" FontSize="14" />

                        <CheckBox IsChecked="{Binding YumirFullscreen}"
                                  Content="Fullscreen"
                                  ToolTip.Tip="Run in fullscreen mode" />

                        <CheckBox IsChecked="{Binding YumirForceAspectRatio}"
                                  Content="Force Aspect Ratio"
                                  ToolTip.Tip="Force a specific aspect ratio" />

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="Video Standard:" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding VideoStandardOptions}"
                                      SelectedItem="{Binding YumirVideoStandard}"
                                      ToolTip.Tip="Select the video standard" />
                        </Grid>

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="Forced Aspect:" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding ForcedAspectOptions}"
                                      SelectedIndex="0"
                                      ToolTip.Tip="Select the forced aspect ratio" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Audio Section -->
                <Border BorderThickness="1" CornerRadius="4" Padding="10">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Audio" FontWeight="Bold" FontSize="14" />

                        <CheckBox IsChecked="{Binding YumirMute}"
                                  Content="Mute"
                                  ToolTip.Tip="Mute audio output" />

                        <StackPanel Spacing="4">
                            <TextBlock Text="Volume:" />
                            <Slider Minimum="0" Maximum="2"
                                    Value="{Binding YumirVolume}"
                                    TickFrequency="0.1" IsSnapToTickEnabled="False"
                                    ToolTip.Tip="Adjust volume (0.0 to 2.0)" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- General Section -->
                <Border BorderThickness="1" CornerRadius="4" Padding="10">
                    <StackPanel Spacing="8">
                        <TextBlock Text="General" FontWeight="Bold" FontSize="14" />

                        <CheckBox IsChecked="{Binding YumirReduceLatency}"
                                  Content="Reduce Latency"
                                  ToolTip.Tip="Enable latency reduction" />

                        <CheckBox IsChecked="{Binding YumirAutoDetectRegion}"
                                  Content="Auto Detect Region"
                                  ToolTip.Tip="Automatically detect the game region" />

                        <CheckBox IsChecked="{Binding YumirPauseWhenUnfocused}"
                                  Content="Pause When Unfocused"
                                  ToolTip.Tip="Pause emulation when the window loses focus" />
                    </StackPanel>
                </Border>

                <!-- Important Setting -->
                <Border BorderThickness="1" CornerRadius="4" Padding="10" BorderBrush="#FFCC00">
                    <StackPanel Spacing="8">
                        <TextBlock Text="IMPORTANT SETTING" FontWeight="Bold" FontSize="14" Foreground="#FFCC00" />
                        <CheckBox IsChecked="{Binding YumirShowSettingsBeforeLaunch}"
                                  Content="Show settings before launch"
                                  ToolTip.Tip="Show the emulator settings window before launching a game" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0" Spacing="10">
            <Button Content="Save"
                    Command="{Binding SaveCommand}"
                    Width="100"
                    ToolTip.Tip="Save configuration" />
            <Button Content="Run"
                    Command="{Binding RunCommand}"
                    IsVisible="{Binding IsLauncherMode}"
                    IsDefault="True"
                    Width="100"
                    ToolTip.Tip="Save and run" />
            <Button Content="Cancel"
                    Command="{Binding CancelCommand}"
                    IsCancel="True"
                    Width="100"
                    ToolTip.Tip="Cancel" />
        </StackPanel>
    </Grid>
</Window>
