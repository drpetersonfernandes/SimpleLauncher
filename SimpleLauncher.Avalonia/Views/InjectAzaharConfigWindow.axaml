<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SimpleLauncher.Avalonia.ViewModels"
        x:Class="SimpleLauncher.Avalonia.Views.InjectAzaharConfigWindow"
        x:DataType="vm:AvaloniaInjectAzaharConfigViewModel"
        Title="Azahar Configuration"
        Width="700" Height="600"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10" RowDefinitions="*,Auto">
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="10">
                <!-- Graphics Section -->
                <Border BorderThickness="1" CornerRadius="4" Padding="10">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Graphics" FontWeight="Bold" FontSize="14" />

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="Graphics API:" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding GraphicsApi}"
                                     PlaceholderText="e.g. OpenGL"
                                     ToolTip.Tip="Enter the graphics API" />
                        </Grid>

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="Resolution:" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding Resolution}"
                                     PlaceholderText="e.g. 1x"
                                     ToolTip.Tip="Enter the internal resolution" />
                        </Grid>

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="Layout:" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding Layout}"
                                     PlaceholderText="e.g. Default"
                                     ToolTip.Tip="Enter the screen layout" />
                        </Grid>

                        <CheckBox IsChecked="{Binding Fullscreen}"
                                  Content="Fullscreen"
                                  ToolTip.Tip="Launch in fullscreen mode" />

                        <CheckBox IsChecked="{Binding Vsync}"
                                  Content="VSync"
                                  ToolTip.Tip="Enable vertical sync" />

                        <CheckBox IsChecked="{Binding AsyncShader}"
                                  Content="Async Shader"
                                  ToolTip.Tip="Enable asynchronous shader compilation" />

                        <CheckBox IsChecked="{Binding IsNew3Ds}"
                                  Content="New 3DS"
                                  ToolTip.Tip="Emulate New 3DS hardware" />

                        <CheckBox IsChecked="{Binding AudioStretching}"
                                  Content="Audio Stretching"
                                  ToolTip.Tip="Enable audio stretching" />
                    </StackPanel>
                </Border>

                <!-- Audio Section -->
                <Border BorderThickness="1" CornerRadius="4" Padding="10">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Audio" FontWeight="Bold" FontSize="14" />

                        <StackPanel Spacing="4">
                            <TextBlock Text="Volume:" />
                            <Slider Minimum="0" Maximum="200"
                                    Value="{Binding Volume}"
                                    ToolTip.Tip="Adjust volume (0 to 200)" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Important Setting -->
                <Border BorderThickness="1" CornerRadius="4" Padding="10" BorderBrush="#FFCC00">
                    <StackPanel Spacing="8">
                        <TextBlock Text="IMPORTANT SETTING" FontWeight="Bold" FontSize="14" Foreground="#FFCC00" />
                        <CheckBox IsChecked="{Binding ShowBeforeLaunch}"
                                  Content="Show settings before launch"
                                  ToolTip.Tip="Show the emulator settings window before launching a game" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0" Spacing="10">
            <Button Content="Save"
                    Command="{Binding SaveCommand}"
                    Width="100"
                    ToolTip.Tip="Save configuration" />
            <Button Content="Run"
                    Command="{Binding RunCommand}"
                    IsVisible="{Binding IsLauncherMode}"
                    IsDefault="True"
                    Width="100"
                    ToolTip.Tip="Save and run" />
            <Button Content="Cancel"
                    Command="{Binding CancelCommand}"
                    IsCancel="True"
                    Width="100"
                    ToolTip.Tip="Cancel" />
        </StackPanel>
    </Grid>
</Window>
