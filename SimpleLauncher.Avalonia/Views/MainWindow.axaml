<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SimpleLauncher.Avalonia"
        x:Class="SimpleLauncher.Avalonia.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding Title}"
        MinWidth="1050" MinHeight="650"
        Width="1200" Height="800"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource ThemeBackgroundBrush}">
    
    <Design.DataContext>
        <x:Type TypeName="vm:MainWindowViewModel"/>
    </Design.DataContext>
    
    <DockPanel>
        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Options">
                <MenuItem Header="Language">
                    <MenuItem Header="English" />
                    <MenuItem Header="Español" />
                    <MenuItem Header="Deutsch" />
                    <MenuItem Header="Français" />
                    <MenuItem Header="Português" />
                    <MenuItem Header="日本語" />
                    <MenuItem Header="한국어" />
                    <MenuItem Header="中文" />
                </MenuItem>
                <MenuItem Header="Theme">
                    <MenuItem Header="Light" Command="{Binding SetThemeCommand}" CommandParameter="Light"/>
                    <MenuItem Header="Dark" Command="{Binding SetThemeCommand}" CommandParameter="Dark"/>
                    <MenuItem Header="Midnight" Command="{Binding SetThemeCommand}" CommandParameter="Midnight"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Settings" Command="{Binding OpenSettingsCommand}"/>
                <Separator/>
                <MenuItem Header="Exit" Command="{Binding ExitApplicationCommand}"/>
            </MenuItem>
            <MenuItem Header="View">
                <MenuItem Header="Grid View" Command="{Binding ToggleViewModeCommand}" />
                <MenuItem Header="List View" Command="{Binding ToggleViewModeCommand}" />
            </MenuItem>
            <MenuItem Header="Tools">
                <MenuItem Header="Easy Mode" Command="{Binding OpenEasyModeCommand}"/>
                <MenuItem Header="Edit System" Command="{Binding OpenEditSystemCommand}"/>
                <Separator/>
                <MenuItem Header="Global Search" Command="{Binding GoToGlobalSearchCommand}" />
                <MenuItem Header="Play History" Command="{Binding GoToPlayHistoryCommand}" />
                <MenuItem Header="Favorites" Command="{Binding GoToFavoritesCommand}" />
            </MenuItem>
            <MenuItem Header="Help">
                <MenuItem Header="About" Command="{Binding OpenAboutCommand}"/>
                <MenuItem Header="Check for Updates" />
            </MenuItem>
        </Menu>
        
        <!-- Left Navigation Panel -->
        <Border DockPanel.Dock="Left" 
                Background="{DynamicResource ThemeNavBackgroundBrush}" 
                Width="60" Padding="5">
            <StackPanel Spacing="5" VerticalAlignment="Top">
                <!-- Home -->
                <Button Content="&#xE80F;" FontFamily="Segoe Fluent Icons" 
                        Classes="navbutton"
                        Command="{Binding NavigateHomeCommand}"
                        ToolTip.Tip="Home"/>
                <!-- Favorites -->
                <Button Content="&#xE734;" FontFamily="Segoe Fluent Icons" 
                        Classes="navbutton"
                        Command="{Binding GoToFavoritesCommand}"
                        ToolTip.Tip="Favorites"/>
                <!-- Global Search -->
                <Button Content="&#xE721;" FontFamily="Segoe Fluent Icons" 
                        Classes="navbutton"
                        Command="{Binding GoToGlobalSearchCommand}"
                        ToolTip.Tip="Global Search"/>
                <!-- Play History -->
                <Button Content="&#xE81C;" FontFamily="Segoe Fluent Icons" 
                        Classes="navbutton"
                        Command="{Binding GoToPlayHistoryCommand}"
                        ToolTip.Tip="Play History"/>
                <Separator Margin="5"/>
                <!-- Toggle View -->
                <Button Content="&#xE8A9;" FontFamily="Segoe Fluent Icons" 
                        Classes="navbutton"
                        Command="{Binding ToggleViewModeCommand}"
                        ToolTip.Tip="Toggle View"/>
                <!-- Zoom In -->
                <Button Content="&#xE710;" FontFamily="Segoe Fluent Icons" 
                        Classes="navbutton"
                        Command="{Binding ZoomInCommand}"
                        ToolTip.Tip="Zoom In"/>
                <!-- Zoom Out -->
                <Button Content="&#xE711;" FontFamily="Segoe Fluent Icons" 
                        Classes="navbutton"
                        Command="{Binding ZoomOutCommand}"
                        ToolTip.Tip="Zoom Out"/>
            </StackPanel>
        </Border>
        
        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom" 
                Background="{DynamicResource ThemeStatusBarBackgroundBrush}" 
                Padding="10,5">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                <!-- Status Text -->
                <TextBlock Grid.Column="0" Text="{Binding StatusText}" 
                           Foreground="{DynamicResource ThemeForegroundSecondaryBrush}" 
                           FontSize="12" VerticalAlignment="Center"/>
                
                <!-- Pagination -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <Button Content="&#xE76B;" FontFamily="Segoe Fluent Icons"
                            Command="{Binding PreviousPageCommand}"
                            IsEnabled="{Binding HasPreviousPage}"
                            Width="30" Height="30"/>
                    <TextBlock Text="{Binding CurrentPage, StringFormat='Page {0}'}" 
                               Foreground="{DynamicResource ThemeForegroundSecondaryBrush}" 
                               FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalPages, StringFormat='of {0}'}" 
                               Foreground="{DynamicResource ThemeForegroundSecondaryBrush}" 
                               FontSize="12" VerticalAlignment="Center"/>
                    <Button Content="&#xE76C;" FontFamily="Segoe Fluent Icons"
                            Command="{Binding NextPageCommand}"
                            IsEnabled="{Binding HasNextPage}"
                            Width="30" Height="30"/>
                </StackPanel>
                
                <!-- Total Games -->
                <TextBlock Grid.Column="3" Text="{Binding TotalGames, StringFormat='{}{0} games'}" 
                           Foreground="{DynamicResource ThemeForegroundSecondaryBrush}" 
                           FontSize="12" VerticalAlignment="Center" Margin="10,0"/>
            </Grid>
        </Border>
        
        <!-- Main Content Area -->
        <DockPanel>
            <!-- System Selection Area -->
            <Border DockPanel.Dock="Top" 
                    Background="{DynamicResource ThemeSurfaceBrush}" 
                    Padding="10">
                <StackPanel Spacing="10">
                    <!-- System and Emulator Selection -->
                    <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,Auto,Auto" RowDefinitions="Auto">
                        <!-- System Label -->
                        <TextBlock Grid.Column="0" Text="System:" 
                                   Foreground="{DynamicResource ThemeForegroundBrush}" 
                                   FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        
                        <!-- System ComboBox -->
                        <ComboBox Grid.Column="1" 
                                  ItemsSource="{Binding Systems}"
                                  SelectedItem="{Binding SelectedSystem}"
                                  MinWidth="200"
                                  PlaceholderText="Select a system"/>
                        
                        <!-- Emulator Label -->
                        <TextBlock Grid.Column="2" Text="Emulator:" 
                                   Foreground="{DynamicResource ThemeForegroundBrush}" 
                                   FontSize="14" VerticalAlignment="Center" Margin="10,0,10,0"/>
                        
                        <!-- Emulator ComboBox -->
                        <ComboBox Grid.Column="3" 
                                  ItemsSource="{Binding Emulators}"
                                  SelectedItem="{Binding SelectedEmulator}"
                                  MinWidth="200"
                                  PlaceholderText="Select an emulator"/>
                        
                        <!-- Search Box -->
                        <TextBox Grid.Column="4" 
                                 Text="{Binding SearchText}"
                                 PlaceholderText="Search games..."
                                 Width="200" Margin="10,0"/>
                        
                        <!-- Search Button -->
                        <Button Grid.Column="5" Content="&#xE721;" FontFamily="Segoe Fluent Icons"
                                Command="{Binding SearchCommand}"
                                Width="35" Height="35" Margin="0,0,10,0"/>
                        
                        <!-- Feeling Lucky Button -->
                        <Button Grid.Column="6" Content="&#xE734;" FontFamily="Segoe Fluent Icons"
                                Command="{Binding FeelingLuckyCommand}"
                                Width="35" Height="35"
                                ToolTip.Tip="Feeling Lucky"/>
                    </Grid>
                    
                    <!-- Letter/Number Filter -->
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" MaxHeight="40">
                        <ItemsControl ItemsSource="{Binding LetterFilters}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="2"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <Button Content="{Binding}"
                                            Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).SelectLetterFilterCommand}"
                                            CommandParameter="{Binding}"
                                            MinWidth="28" Height="28"
                                            Padding="4,2"
                                            FontSize="11"
                                            FontWeight="SemiBold"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>
            
            <!-- Game Content Area -->
            <Panel>
                <!-- Main Game View -->
                <ScrollViewer IsVisible="{Binding !IsSubPageActive}">
                    <Panel>
                        <!-- Loading Overlay -->
                        <Border IsVisible="{Binding IsLoading}" 
                                Background="{DynamicResource ThemeOverlayBrush}" 
                                ZIndex="100">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
                                <ProgressBar IsIndeterminate="True" Width="200"/>
                                <TextBlock Text="Loading games..." 
                                           Foreground="{DynamicResource ThemeForegroundBrush}" 
                                           FontSize="14"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Game Grid View -->
                        <ItemsControl ItemsSource="{Binding Games}" 
                                      IsVisible="{Binding IsGridView}"
                                      Margin="10">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:GameItemViewModel">
                                    <Button Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).LaunchGameCommand}"
                                            CommandParameter="{Binding}"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="0"
                                            Cursor="Hand"
                                            Margin="5">
                                        <Button.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Launch" Command="{Binding $parent[Button].((vm:MainWindowViewModel)DataContext).LaunchGameCommand}" CommandParameter="{Binding}"/>
                                                    <Separator/>
                                                    <MenuItem Header="Add to Favorites" Command="{Binding $parent[Button].((vm:MainWindowViewModel)DataContext).AddFavoriteCommand}" CommandParameter="{Binding}"/>
                                                    <MenuItem Header="Remove from Favorites" Command="{Binding $parent[Button].((vm:MainWindowViewModel)DataContext).RemoveFavoriteCommand}" CommandParameter="{Binding}"/>
                                                    <Separator/>
                                                    <MenuItem Header="Open Folder" Command="{Binding $parent[Button].((vm:MainWindowViewModel)DataContext).OpenGameFolderCommand}" CommandParameter="{Binding}"/>
                                                </ContextMenu>
                                            </Button.ContextMenu>
                                        <Border Background="{DynamicResource ThemeCardBackgroundBrush}" 
                                                CornerRadius="8" 
                                                Padding="10" 
                                                Width="200">
                                            <StackPanel Spacing="5">
                                                <!-- Cover Image -->
                                                <Border Background="{DynamicResource ThemeSurfaceHoverBrush}" 
                                                        CornerRadius="4" 
                                                        Height="150">
                                                    <Image Source="{Binding CoverImagePath, Converter={StaticResource ImageUrlConverter}, TargetNullValue={x:Null}}" 
                                                           Stretch="Uniform"/>
                                                </Border>
                                                <!-- Game Name -->
                                                <TextBlock Text="{Binding MachineName}" 
                                                           Foreground="{DynamicResource ThemeForegroundBrush}" 
                                                           FontSize="12"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxLines="2"/>
                                                <!-- Favorite Indicator -->
                                                <TextBlock Text="&#xE734;" FontFamily="Segoe Fluent Icons"
                                                           Foreground="{DynamicResource ThemeWarningBrush}"
                                                           IsVisible="{Binding IsFavorite}"
                                                           FontSize="14"/>
                                            </StackPanel>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        
                        <!-- Game List View -->
                        <DataGrid ItemsSource="{Binding Games}"
                                  IsVisible="{Binding IsListView}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="0"
                                  Background="{DynamicResource ThemeSurfaceBrush}"
                                  Foreground="{DynamicResource ThemeForegroundBrush}"
                                  Margin="10"
                                  DoubleTapped="OnGameGridDoubleTapped">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="File Name" Binding="{Binding FileName}" Width="*"/>
                                <DataGridTextColumn Header="Machine" Binding="{Binding MachineName}" Width="200"/>
                                <DataGridTextColumn Header="Folder" Binding="{Binding FolderPath}" Width="250"/>
                                <DataGridTextColumn Header="Times Played" Binding="{Binding TimesPlayed}" Width="100"/>
                                <DataGridTextColumn Header="Play Time" Binding="{Binding PlayTime}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Panel>
                </ScrollViewer>
                
                <!-- Sub-page View -->
                <ContentControl Content="{Binding CurrentSubPage}"
                                IsVisible="{Binding IsSubPageActive}"
                                Margin="10"/>
            </Panel>
        </DockPanel>
    </DockPanel>
</Window>
