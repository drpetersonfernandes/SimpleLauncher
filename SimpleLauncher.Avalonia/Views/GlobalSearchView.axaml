<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SimpleLauncher.Avalonia"
             xmlns:converters="using:SimpleLauncher.Avalonia.Converters"
             x:Class="SimpleLauncher.Avalonia.Views.GlobalSearchView"
             x:DataType="vm:GlobalSearchViewModel">
    
    <Border Background="#313244" Padding="15">
        <DockPanel>
            <!-- Header -->
            <Border DockPanel.Dock="Top" Background="#45475a" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                <StackPanel Spacing="5">
                    <TextBlock Text="Global Search" 
                               FontSize="20" FontWeight="Bold" 
                               Foreground="#cdd6f4"/>
                    <TextBlock Text="Search for games across all systems" 
                               Foreground="#a6adc8"/>
                </StackPanel>
            </Border>
            
            <!-- Search Box -->
            <Border DockPanel.Dock="Top" Margin="0,0,0,15">
                <Grid ColumnDefinitions="*,Auto,Auto">
                    <TextBox Text="{Binding SearchText}" 
                             PlaceholderText="Search for games..." 
                             FontSize="14"
                             CornerRadius="8"
                             KeyDown="OnSearchKeyDown"/>
                    <Button Grid.Column="1" 
                            Content="Search" 
                            Command="{Binding SearchCommand}"
                            Margin="10,0"
                            Padding="15,8"
                            IsEnabled="{Binding !IsSearching}"/>
                    <Button Grid.Column="2" 
                            Content="Cancel" 
                            Command="{Binding CancelSearchCommand}"
                            IsVisible="{Binding IsSearching}"
                            Padding="15,8"
                            Background="#f38ba8"/>
                </Grid>
            </Border>
            
            <!-- Search Status -->
            <Border DockPanel.Dock="Top" Margin="0,0,0,10" IsVisible="{Binding IsSearching}">
                <TextBlock Text="{Binding SearchStatus}" 
                           Foreground="#a6adc8" 
                           FontSize="12"/>
            </Border>
            
            <!-- Content -->
            <Panel>
                <!-- Loading Overlay -->
                <Border IsVisible="{Binding IsSearching}" 
                        Background="#80000000" 
                        ZIndex="100">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
                        <ProgressBar IsIndeterminate="True" Width="200"/>
                        <TextBlock Text="Searching..." Foreground="#cdd6f4" FontSize="14"/>
                    </StackPanel>
                </Border>
                
                <!-- Empty State -->
                <Border IsVisible="{Binding NoResults}" 
                        Background="#45475a" CornerRadius="8" Padding="30"
                        VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel Spacing="10" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE721;" FontFamily="Segoe Fluent Icons" 
                                   FontSize="48" Foreground="#6c7086"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="No results found" 
                                   Foreground="#6c7086"
                                   HorizontalAlignment="Center"
                                   FontSize="16"/>
                    </StackPanel>
                </Border>
                
                <!-- Initial State -->
                <Border IsVisible="{Binding !HasResults}" 
                        Background="#45475a" CornerRadius="8" Padding="30"
                        VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel Spacing="10" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE721;" FontFamily="Segoe Fluent Icons" 
                                   FontSize="48" Foreground="#6c7086"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Enter a search term to find games" 
                                   Foreground="#6c7086"
                                   HorizontalAlignment="Center"
                                   FontSize="14"/>
                    </StackPanel>
                </Border>
                
                <!-- Search Results -->
                <ListBox ItemsSource="{Binding SearchResults}"
                         SelectedItem="{Binding SelectedResult}"
                         IsVisible="{Binding HasResults}"
                         Background="Transparent"
                         BorderThickness="0"
                         DoubleTapped="OnSearchResultDoubleTapped">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:SearchResultItem">
                            <Border Background="#45475a" 
                                    CornerRadius="8" 
                                    Padding="15" 
                                    Margin="0,2">
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <!-- Cover Image -->
                                    <Border Background="#585b70" 
                                            CornerRadius="4" 
                                            Width="60" Height="60">
                                        <Image Source="{Binding CoverImage, Converter={StaticResource ImageUrlConverter}}" 
                                               Stretch="Uniform"/>
                                    </Border>
                                    
                                    <!-- Info -->
                                    <StackPanel Grid.Column="1" Margin="15,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding MachineName}" 
                                                   Foreground="#cdd6f4" 
                                                   FontSize="14"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding FileName}" 
                                                   Foreground="#a6adc8" 
                                                   FontSize="12"
                                                   Margin="0,5,0,0"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding SystemName}" 
                                                   Foreground="#6c7086" 
                                                   FontSize="11"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                    
                                    <!-- Score -->
                                    <TextBlock Grid.Column="2" 
                                               Text="{Binding Score}" 
                                               Foreground="#a6adc8"
                                               FontSize="12"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Panel>
        </DockPanel>
    </Border>
</UserControl>
