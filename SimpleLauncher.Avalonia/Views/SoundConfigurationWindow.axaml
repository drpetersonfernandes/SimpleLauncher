<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SimpleLauncher.Avalonia.ViewModels"
        x:Class="SimpleLauncher.Avalonia.Views.SoundConfigurationWindow"
        x:DataType="vm:AvaloniaSoundConfigurationViewModel"
        Title="Sound Configuration"
        Width="500" Height="300"
        WindowStartupLocation="CenterScreen"
        CanResize="False">

    <Grid Margin="15" RowDefinitions="Auto,Auto,Auto,*,Auto" ColumnDefinitions="Auto,*,Auto">
        <!-- Enable Sound Checkbox -->
        <CheckBox Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                  Content="Enable Notification Sound"
                  ToolTip.Tip="Enable or disable notification sounds"
                  Margin="0,0,0,10"
                  IsChecked="{Binding EnableNotificationSound}" />

        <!-- Sound File Selection -->
        <TextBlock Grid.Row="1" Grid.Column="0"
                   Text="Sound File:"
                   VerticalAlignment="Center" />
        <TextBox Grid.Row="1" Grid.Column="1"
                 IsReadOnly="True"
                 Text="{Binding NotificationSoundFile}"
                  ToolTip.Tip="Choose a sound file for notifications"
                 Margin="5,0,5,0"
                 VerticalAlignment="Center"
                 IsEnabled="{Binding IsSoundControlsEnabled}" />
        <Button Grid.Row="1" Grid.Column="2"
                Content="Choose File"
                ToolTip.Tip="Choose a sound file"
                Command="{Binding ChooseSoundFileCommand}"
                VerticalAlignment="Center"
                Width="100"
                IsEnabled="{Binding IsSoundControlsEnabled}" />

        <!-- Play Button -->
        <Button Grid.Row="2" Grid.Column="1"
                Content="Play Current Sound"
                ToolTip.Tip="Play the current notification sound"
                Command="{Binding PlayCurrentSoundCommand}"
                Margin="5,10,5,0"
                HorizontalAlignment="Left"
                Width="150"
                IsEnabled="{Binding IsSoundControlsEnabled}" />

        <!-- Reset Button -->
        <Button Grid.Row="3" Grid.Column="1"
                Content="Reset to Default"
                ToolTip.Tip="Reset sound settings to default"
                Command="{Binding ResetToDefaultCommand}"
                Margin="5,10,5,0"
                HorizontalAlignment="Left"
                Width="150"
                IsEnabled="{Binding IsSoundControlsEnabled}" />

        <!-- Save/Cancel Buttons -->
        <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Save"
                    ToolTip.Tip="Save sound settings"
                    Command="{Binding SaveCommand}"
                    IsDefault="True"
                    Width="100" Margin="0,0,10,0" />
            <Button Content="Cancel"
                    ToolTip.Tip="Cancel and close"
                    Command="{Binding CancelCommand}"
                    IsCancel="True"
                    Width="100" />
        </StackPanel>
    </Grid>
</Window>
