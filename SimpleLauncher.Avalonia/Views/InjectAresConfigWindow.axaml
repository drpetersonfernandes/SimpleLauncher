<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SimpleLauncher.Avalonia.ViewModels"
        x:Class="SimpleLauncher.Avalonia.Views.InjectAresConfigWindow"
        x:DataType="vm:AvaloniaInjectAresConfigViewModel"
        Title="Ares Configuration"
        Width="700" Height="700"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10" RowDefinitions="*,Auto">
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="10">
                <!-- Video Section -->
                <Border BorderThickness="1" CornerRadius="4" Padding="10">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Video" FontWeight="Bold" FontSize="14" />

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="Video Driver:" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding VideoDriverOptions}"
                                      SelectedItem="{Binding VideoDriver}"
                                      ToolTip.Tip="Select the video driver" />
                        </Grid>

                        <CheckBox IsChecked="{Binding Exclusive}"
                                  Content="Exclusive"
                                  ToolTip.Tip="Enable exclusive fullscreen mode" />

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="Shader:" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding ShaderOptions}"
                                      SelectedItem="{Binding Shader}"
                                      ToolTip.Tip="Select the shader" />
                        </Grid>

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="Multiplier:" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding MultiplierOptions}"
                                      SelectedItem="{Binding Multiplier}"
                                      ToolTip.Tip="Select the resolution multiplier" />
                        </Grid>

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="Aspect Correction:" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AspectCorrectionOptions}"
                                      SelectedItem="{Binding AspectCorrection}"
                                      ToolTip.Tip="Select the aspect correction mode" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Audio Section -->
                <Border BorderThickness="1" CornerRadius="4" Padding="10">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Audio" FontWeight="Bold" FontSize="14" />

                        <CheckBox IsChecked="{Binding Mute}"
                                  Content="Mute"
                                  ToolTip.Tip="Mute audio output" />

                        <StackPanel Spacing="4">
                            <TextBlock Text="Volume:" />
                            <Slider Minimum="0" Maximum="2"
                                    Value="{Binding Volume}"
                                    TickFrequency="0.1" IsSnapToTickEnabled="False"
                                    ToolTip.Tip="Adjust volume (0.0 to 2.0)" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- General Section -->
                <Border BorderThickness="1" CornerRadius="4" Padding="10">
                    <StackPanel Spacing="8">
                        <TextBlock Text="General" FontWeight="Bold" FontSize="14" />

                        <CheckBox IsChecked="{Binding FastBoot}"
                                  Content="Fast Boot"
                                  ToolTip.Tip="Skip BIOS boot sequence" />

                        <CheckBox IsChecked="{Binding Rewind}"
                                  Content="Rewind"
                                  ToolTip.Tip="Enable rewind support" />

                        <CheckBox IsChecked="{Binding RunAhead}"
                                  Content="Run Ahead"
                                  ToolTip.Tip="Enable run-ahead for reduced input lag" />

                        <CheckBox IsChecked="{Binding AutoSaveMemory}"
                                  Content="Auto Save Memory"
                                  ToolTip.Tip="Automatically save memory cards" />
                    </StackPanel>
                </Border>

                <!-- Important Setting -->
                <Border BorderThickness="1" CornerRadius="4" Padding="10" BorderBrush="#FFCC00">
                    <StackPanel Spacing="8">
                        <TextBlock Text="IMPORTANT SETTING" FontWeight="Bold" FontSize="14" Foreground="#FFCC00" />
                        <CheckBox IsChecked="{Binding ShowBeforeLaunch}"
                                  Content="Show settings before launch"
                                  ToolTip.Tip="Show the emulator settings window before launching a game" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0" Spacing="10">
            <Button Content="Save"
                    Command="{Binding SaveCommand}"
                    Width="100"
                    ToolTip.Tip="Save configuration" />
            <Button Content="Run"
                    Command="{Binding RunCommand}"
                    IsVisible="{Binding IsLauncherMode}"
                    IsDefault="True"
                    Width="100"
                    ToolTip.Tip="Save and run" />
            <Button Content="Cancel"
                    Command="{Binding CancelCommand}"
                    IsCancel="True"
                    Width="100"
                    ToolTip.Tip="Cancel" />
        </StackPanel>
    </Grid>
</Window>
