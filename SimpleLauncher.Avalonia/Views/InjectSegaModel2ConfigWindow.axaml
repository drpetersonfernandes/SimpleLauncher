<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SimpleLauncher.Avalonia.ViewModels"
        x:Class="SimpleLauncher.Avalonia.Views.InjectSegaModel2ConfigWindow"
        x:DataType="vm:AvaloniaInjectSegaModel2ConfigViewModel"
        Title="SEGA Model 2 Configuration"
        Width="700" Height="600"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10" RowDefinitions="*,Auto">
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="10">
                <!-- Video Section -->
                <Border BorderThickness="1" CornerRadius="4" Padding="10">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Video" FontWeight="Bold" FontSize="14" />

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="Resolution X:" VerticalAlignment="Center" />
                            <NumericUpDown Grid.Column="1"
                                           Value="{Binding ResX}"
                                           Minimum="320" Maximum="7680"
                                           ToolTip.Tip="Set the horizontal resolution" />
                        </Grid>

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="Resolution Y:" VerticalAlignment="Center" />
                            <NumericUpDown Grid.Column="1"
                                           Value="{Binding ResY}"
                                           Minimum="240" Maximum="4320"
                                           ToolTip.Tip="Set the vertical resolution" />
                        </Grid>

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="Widescreen:" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding WideScreenOptions}"
                                      SelectedItem="{Binding WideScreen}"
                                      ToolTip.Tip="Select the widescreen mode" />
                        </Grid>

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="FSAA:" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding FsaaOptions}"
                                      SelectedItem="{Binding Fsaa}"
                                      ToolTip.Tip="Select the full-screen anti-aliasing level" />
                        </Grid>

                        <CheckBox IsChecked="{Binding Bilinear}"
                                  Content="Bilinear Filtering"
                                  ToolTip.Tip="Enable bilinear filtering" />

                        <CheckBox IsChecked="{Binding Trilinear}"
                                  Content="Trilinear Filtering"
                                  ToolTip.Tip="Enable trilinear filtering" />

                        <CheckBox IsChecked="{Binding FilterTilemaps}"
                                  Content="Filter Tilemaps"
                                  ToolTip.Tip="Enable tilemap filtering" />

                        <CheckBox IsChecked="{Binding DrawCross}"
                                  Content="Draw Crosshair"
                                  ToolTip.Tip="Draw crosshair on screen" />
                    </StackPanel>
                </Border>

                <!-- Input Section -->
                <Border BorderThickness="1" CornerRadius="4" Padding="10">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Input" FontWeight="Bold" FontSize="14" />

                        <CheckBox IsChecked="{Binding XInput}"
                                  Content="XInput"
                                  ToolTip.Tip="Enable XInput controller support" />

                        <CheckBox IsChecked="{Binding UseRawInput}"
                                  Content="Use Raw Input"
                                  ToolTip.Tip="Use raw input for controls" />
                    </StackPanel>
                </Border>

                <!-- General Section -->
                <Border BorderThickness="1" CornerRadius="4" Padding="10">
                    <StackPanel Spacing="8">
                        <TextBlock Text="General" FontWeight="Bold" FontSize="14" />

                        <CheckBox IsChecked="{Binding EnableFf}"
                                  Content="Enable Force Feedback"
                                  ToolTip.Tip="Enable force feedback" />

                        <CheckBox IsChecked="{Binding HoldGears}"
                                  Content="Hold Gears"
                                  ToolTip.Tip="Enable hold gears for steering wheel" />
                    </StackPanel>
                </Border>

                <!-- Important Setting -->
                <Border BorderThickness="1" CornerRadius="4" Padding="10" BorderBrush="#FFCC00">
                    <StackPanel Spacing="8">
                        <TextBlock Text="IMPORTANT SETTING" FontWeight="Bold" FontSize="14" Foreground="#FFCC00" />
                        <CheckBox IsChecked="{Binding ShowBeforeLaunch}"
                                  Content="Show settings before launch"
                                  ToolTip.Tip="Show the emulator settings window before launching a game" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0" Spacing="10">
            <Button Content="Save"
                    Command="{Binding SaveCommand}"
                    Width="100"
                    ToolTip.Tip="Save configuration" />
            <Button Content="Run"
                    Command="{Binding RunCommand}"
                    IsVisible="{Binding IsLauncherMode}"
                    IsDefault="True"
                    Width="100"
                    ToolTip.Tip="Save and run" />
            <Button Content="Cancel"
                    Command="{Binding CancelCommand}"
                    IsCancel="True"
                    Width="100"
                    ToolTip.Tip="Cancel" />
        </StackPanel>
    </Grid>
</Window>
