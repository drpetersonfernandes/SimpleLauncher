<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SimpleLauncher.Avalonia.ViewModels"
        x:Class="SimpleLauncher.Avalonia.Views.InjectPcsx2ConfigWindow"
        x:DataType="vm:AvaloniaInjectPcsx2ConfigViewModel"
        Title="PCSX2 Configuration"
        Width="700" Height="600"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10" RowDefinitions="*,Auto">
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="10">
                <!-- Video Section -->
                <Border BorderThickness="1" CornerRadius="4" Padding="10">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Video" FontWeight="Bold" FontSize="14" />

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="Renderer:" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding RendererDisplayNames}"
                                      SelectedItem="{Binding Pcsx2Renderer}"
                                      ToolTip.Tip="Select the graphics renderer" />
                        </Grid>

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="Upscale Multiplier:" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding UpscaleDisplayNames}"
                                      SelectedItem="{Binding Pcsx2UpscaleMultiplier}"
                                      ToolTip.Tip="Select the internal resolution upscale multiplier" />
                        </Grid>

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="Aspect Ratio:" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AspectOptions}"
                                      SelectedItem="{Binding Pcsx2AspectRatio}"
                                      ToolTip.Tip="Select the aspect ratio" />
                        </Grid>

                        <CheckBox IsChecked="{Binding Pcsx2Vsync}"
                                  Content="VSync"
                                  ToolTip.Tip="Enable vertical sync" />

                        <CheckBox IsChecked="{Binding Pcsx2EnableWidescreenPatches}"
                                  Content="Enable Widescreen Patches"
                                  ToolTip.Tip="Apply widescreen patches to games" />

                        <CheckBox IsChecked="{Binding Pcsx2StartFullscreen}"
                                  Content="Start Fullscreen"
                                  ToolTip.Tip="Start the emulator in fullscreen mode" />
                    </StackPanel>
                </Border>

                <!-- Gameplay Section -->
                <Border BorderThickness="1" CornerRadius="4" Padding="10">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Gameplay" FontWeight="Bold" FontSize="14" />

                        <CheckBox IsChecked="{Binding Pcsx2EnableCheats}"
                                  Content="Enable Cheats"
                                  ToolTip.Tip="Enable cheat support" />

                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Text="Volume:" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                <Slider Minimum="0" Maximum="100"
                                        Value="{Binding Pcsx2Volume}"
                                        Width="200"
                                        ToolTip.Tip="Adjust audio volume" />
                                <TextBlock Text="{Binding Pcsx2Volume}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- RetroAchievements Section -->
                <Border BorderThickness="1" CornerRadius="4" Padding="10">
                    <StackPanel Spacing="8">
                        <TextBlock Text="RetroAchievements" FontWeight="Bold" FontSize="14" />

                        <CheckBox IsChecked="{Binding Pcsx2AchievementsEnabled}"
                                  Content="Enable Achievements"
                                  ToolTip.Tip="Enable RetroAchievements integration" />

                        <CheckBox IsChecked="{Binding Pcsx2AchievementsHardcore}"
                                  Content="Hardcore Mode"
                                  ToolTip.Tip="Enable RetroAchievements hardcore mode (no cheats, save states, etc.)" />
                    </StackPanel>
                </Border>

                <!-- Important Setting -->
                <Border BorderThickness="1" CornerRadius="4" Padding="10" BorderBrush="#FFCC00">
                    <StackPanel Spacing="8">
                        <TextBlock Text="IMPORTANT SETTING" FontWeight="Bold" FontSize="14" Foreground="#FFCC00" />
                        <CheckBox IsChecked="{Binding Pcsx2ShowSettingsBeforeLaunch}"
                                  Content="Show settings before launch"
                                  ToolTip.Tip="Show the emulator settings window before launching a game" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0" Spacing="10">
            <Button Content="Save"
                    Command="{Binding SaveCommand}"
                    Width="100"
                    ToolTip.Tip="Save configuration" />
            <Button Content="Run"
                    Command="{Binding RunCommand}"
                    IsVisible="{Binding IsLauncherMode}"
                    IsDefault="True"
                    Width="100"
                    ToolTip.Tip="Save and run" />
            <Button Content="Cancel"
                    Command="{Binding CancelCommand}"
                    IsCancel="True"
                    Width="100"
                    ToolTip.Tip="Cancel" />
        </StackPanel>
    </Grid>
</Window>
