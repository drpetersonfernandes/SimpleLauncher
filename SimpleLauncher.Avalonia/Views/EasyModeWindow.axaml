<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SimpleLauncher.Avalonia"
        x:Class="SimpleLauncher.Avalonia.Views.EasyModeWindow"
        x:DataType="vm:EasyModeViewModel"
        Title="Add New System - Easy Mode"
        Width="700" Height="600"
        WindowStartupLocation="CenterOwner">
    
    <Design.DataContext>
        <x:Type TypeName="vm:EasyModeViewModel"/>
    </Design.DataContext>
    
    <Border Background="#1e1e2e" Padding="20">
        <DockPanel>
            <!-- Header -->
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,15">
                <TextBlock Text="Add New System" 
                           FontSize="20" FontWeight="Bold" 
                           Foreground="#cdd6f4"/>
                <TextBlock Text="Select a system and download the required components" 
                           Foreground="#a6adc8"
                           Margin="0,5,0,0"/>
            </StackPanel>
            
            <!-- Footer -->
            <Border DockPanel.Dock="Bottom" Margin="0,15,0,0">
                <StackPanel Spacing="10">
                    <!-- Progress Bar -->
                    <ProgressBar IsVisible="{Binding IsOperationInProgress}" 
                                 IsIndeterminate="True" 
                                 Height="4"/>
                    
                    <!-- Status -->
                    <TextBlock Text="{Binding DownloadStatus}" 
                               Foreground="#a6adc8" 
                               FontSize="12"/>
                    
                    <!-- Add System Button -->
                    <Button Content="Add System" 
                            HorizontalAlignment="Right"
                            Width="120" Height="35"
                            Command="{Binding AddSystemCommand}"
                            IsEnabled="{Binding IsAddSystemEnabled}"
                            Background="#a6e3a1"
                            Foreground="#1e1e2e"/>
                </StackPanel>
            </Border>
            
            <!-- Content -->
            <Panel>
                <!-- Loading Overlay -->
                <Border IsVisible="{Binding IsLoading}" 
                        Background="#80000000" 
                        ZIndex="100">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
                        <ProgressBar IsIndeterminate="True" Width="200"/>
                        <TextBlock Text="{Binding LoadingMessage}" Foreground="#cdd6f4" FontSize="14"/>
                    </StackPanel>
                </Border>
                
                <!-- Main Content -->
                <ScrollViewer>
                    <WrapPanel Orientation="Horizontal">
                        <!-- Left Column -->
                        <StackPanel Width="300" Spacing="15" Margin="0,0,15,0">
                            <!-- System Selection -->
                            <Border Background="#45475a" CornerRadius="8" Padding="15">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="System" 
                                               FontSize="14" FontWeight="Bold" 
                                               Foreground="#cdd6f4"/>
                                    
                                    <ComboBox ItemsSource="{Binding SystemNames}"
                                              SelectedIndex="{Binding SelectedSystemIndex}"
                                              PlaceholderText="Select a system"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- ROM Folder -->
                            <Border Background="#45475a" CornerRadius="8" Padding="15">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="ROM Folder" 
                                               FontSize="14" FontWeight="Bold" 
                                               Foreground="#cdd6f4"/>
                                    
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBox Text="{Binding SystemFolder}" 
                                                 PlaceholderText="Select folder..."
                                                 IsReadOnly="True"/>
                                        <Button Grid.Column="1" 
                                                Content="Browse" 
                                                Command="{Binding ChooseFolderCommand}"
                                                Margin="10,0,0,0"
                                                Padding="15,5"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        
                        <!-- Right Column -->
                        <StackPanel Width="300" Spacing="15">
                            <!-- Emulator -->
                            <Border Background="#45475a" CornerRadius="8" Padding="15">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Emulator" 
                                               FontSize="14" FontWeight="Bold" 
                                               Foreground="#cdd6f4"/>
                                    
                                    <Button Content="Download Emulator" 
                                            Command="{Binding DownloadEmulatorCommand}"
                                            IsEnabled="{Binding !IsEmulatorDownloaded}"
                                            Padding="10,8"/>
                                    
                                    <TextBlock Text="✓ Emulator downloaded" 
                                               Foreground="#a6e3a1"
                                               FontSize="12"
                                               IsVisible="{Binding IsEmulatorDownloaded}"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- Core -->
                            <Border Background="#45475a" CornerRadius="8" Padding="15">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Core" 
                                               FontSize="14" FontWeight="Bold" 
                                               Foreground="#cdd6f4"/>
                                    
                                    <Button Content="Download Core" 
                                            Command="{Binding DownloadCoreCommand}"
                                            IsEnabled="{Binding !IsCoreDownloaded}"
                                            Padding="10,8"/>
                                    
                                    <TextBlock Text="✓ Core downloaded" 
                                               Foreground="#a6e3a1"
                                               FontSize="12"
                                               IsVisible="{Binding IsCoreDownloaded}"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- Image Packs -->
                            <Border Background="#45475a" CornerRadius="8" Padding="15">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Image Packs (Optional)" 
                                               FontSize="14" FontWeight="Bold" 
                                               Foreground="#cdd6f4"/>
                                    
                                    <Button Content="Download Image Pack 1" 
                                            Command="{Binding DownloadImagePack1Command}"
                                            IsEnabled="{Binding !IsImagePack1Downloaded}"
                                            Padding="10,5"/>
                                    
                                    <Button Content="Download Image Pack 2" 
                                            Command="{Binding DownloadImagePack2Command}"
                                            IsEnabled="{Binding !IsImagePack2Downloaded}"
                                            Padding="10,5"/>
                                    
                                    <Button Content="Download Image Pack 3" 
                                            Command="{Binding DownloadImagePack3Command}"
                                            IsEnabled="{Binding !IsImagePack3Downloaded}"
                                            Padding="10,5"/>
                                    
                                    <Button Content="Download Image Pack 4" 
                                            Command="{Binding DownloadImagePack4Command}"
                                            IsEnabled="{Binding !IsImagePack4Downloaded}"
                                            Padding="10,5"/>
                                    
                                    <Button Content="Download Image Pack 5" 
                                            Command="{Binding DownloadImagePack5Command}"
                                            IsEnabled="{Binding !IsImagePack5Downloaded}"
                                            Padding="10,5"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </WrapPanel>
                </ScrollViewer>
            </Panel>
        </DockPanel>
    </Border>
</Window>
