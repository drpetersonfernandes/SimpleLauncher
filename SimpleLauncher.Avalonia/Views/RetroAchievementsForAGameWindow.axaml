<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SimpleLauncher.Avalonia.ViewModels"
        x:Class="SimpleLauncher.Avalonia.Views.RetroAchievementsForAGameWindow"
        x:DataType="vm:AvaloniaRetroAchievementsForAGameViewModel"
        Title="RetroAchievements"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen">
    <Design.DataContext>
        <x:Type TypeName="vm:AvaloniaRetroAchievementsForAGameViewModel"/>
    </Design.DataContext>

    <Border Background="#1e1e2e">
        <Grid RowDefinitions="Auto,*">

            <!-- Header: Game Cover, Title, Console -->
            <Border Grid.Row="0" Margin="10" Padding="15" BorderBrush="#585b70" BorderThickness="1" CornerRadius="5">
                <StackPanel Orientation="Horizontal">
                    <Image x:Name="GameCoverImage" Width="80" Height="80" Stretch="Uniform" Margin="0,0,15,0" />
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding GameTitle}" FontSize="24" FontWeight="Bold" Foreground="#cdd6f4" />
                        <TextBlock Text="{Binding ConsoleName}" FontSize="16" Margin="0,5,0,0" Foreground="#a6adc8" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <TabControl Grid.Row="1" Margin="10,0,10,10" x:Name="TabControl" SelectionChanged="TabControl_SelectionChanged">

                <!-- Tab 1: Achievements -->
                <TabItem Header="Achievements" Tag="Achievements">
                    <Grid RowDefinitions="Auto,*">

                        <!-- Progress Summary -->
                        <Border Grid.Row="0" Margin="10,10,10,0" Padding="15" BorderBrush="#585b70" BorderThickness="1" CornerRadius="5">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                                    <TextBlock Text="{Binding GameTitle}" FontSize="20" FontWeight="Bold" Margin="0,0,10,0" Foreground="#cdd6f4" />
                                    <TextBlock Text="{Binding ConsoleName}" FontStyle="Italic" VerticalAlignment="Bottom" FontSize="16" Foreground="#a6adc8" />
                                </StackPanel>

                                <!-- Progress Bars -->
                                <Grid Margin="0,15,0,10" ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Casual Progress" FontWeight="Bold" Margin="0,0,0,5" Foreground="#cdd6f4" />
                                    <ProgressBar Grid.Row="1" Grid.Column="0" Value="{Binding CasualCompletion}" Maximum="100" Height="20" Margin="0,0,10,0" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CasualProgressText}" VerticalAlignment="Center" FontWeight="Bold" Width="60" TextAlignment="Right" Foreground="#cdd6f4" />
                                </Grid>
                                <Grid Margin="0,0,0,10" ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Hardcore Progress" FontWeight="Bold" Margin="0,0,0,5" Foreground="#cdd6f4" />
                                    <ProgressBar Grid.Row="1" Grid.Column="0" Value="{Binding HardcoreCompletion}" Maximum="100" Height="20" Margin="0,0,10,0" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding HardcoreProgressText}" VerticalAlignment="Center" FontWeight="Bold" Width="60" TextAlignment="Right" Foreground="#cdd6f4" />
                                </Grid>

                                <!-- Achievement Stats -->
                                <Grid Margin="0,10,0,0" ColumnDefinitions="*,*,*,*">
                                    <Border Grid.Column="0" BorderBrush="#45475a" BorderThickness="1" Padding="10" Margin="0,0,5,0" CornerRadius="3">
                                        <StackPanel>
                                            <TextBlock Text="{Binding EarnedAchievements}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#a6e3a1" />
                                            <TextBlock Text="Earned" HorizontalAlignment="Center" Foreground="#cdd6f4" FontSize="12" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" BorderBrush="#45475a" BorderThickness="1" Padding="10" Margin="5,0,5,0" CornerRadius="3">
                                        <StackPanel>
                                            <TextBlock Text="{Binding TotalAchievements}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#a6e3a1" />
                                            <TextBlock Text="Total" HorizontalAlignment="Center" Foreground="#cdd6f4" FontSize="12" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2" BorderBrush="#45475a" BorderThickness="1" Padding="10" Margin="5,0,5,0" CornerRadius="3">
                                        <StackPanel>
                                            <TextBlock Text="{Binding TotalPointsEarned}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#a6e3a1" />
                                            <TextBlock Text="Points" HorizontalAlignment="Center" Foreground="#cdd6f4" FontSize="12" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="3" BorderBrush="#45475a" BorderThickness="1" Padding="10" Margin="5,0,0,0" CornerRadius="3">
                                        <StackPanel>
                                            <TextBlock Text="{Binding TruePointsEarned}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#a6e3a1" />
                                            <TextBlock Text="True Points" HorizontalAlignment="Center" Foreground="#cdd6f4" FontSize="12" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!-- Highest Award -->
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                                    <TextBlock Text="Highest Award: " FontWeight="Bold" Foreground="#cdd6f4" FontSize="14" />
                                    <TextBlock Text="{Binding HighestAwardKind}" FontWeight="Bold" Foreground="#f9e2af" FontSize="14" />
                                    <TextBlock Text=" on " FontWeight="Bold" Margin="5,0,5,0" Foreground="#cdd6f4" FontSize="14" />
                                    <TextBlock Text="{Binding HighestAwardDate}" FontWeight="Bold" Foreground="#cdd6f4" FontSize="14" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Achievements DataGrid -->
                        <Panel Grid.Row="1" Margin="10">
                            <DataGrid ItemsSource="{Binding Achievements}" AutoGenerateColumns="False" IsReadOnly="True"
                                      HeadersVisibility="Column" GridLinesVisibility="Horizontal" RowDetailsVisibilityMode="Collapsed"
                                      Background="#1e1e2e" BorderBrush="#585b70" BorderThickness="1">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*" />
                                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="2*" />
                                    <DataGridTextColumn Header="Points" Binding="{Binding Points}" Width="Auto" />
                                    <DataGridTextColumn Header="True Ratio" Binding="{Binding TrueRatio, StringFormat='{}{0}%'}" Width="Auto" />
                                    <DataGridTextColumn Header="Unlocked" Binding="{Binding DateUnlockedDisplay}" Width="Auto" />
                                    <DataGridTextColumn Header="Mode" Binding="{Binding ModeDisplay}" Width="Auto" />
                                    <DataGridTextColumn Header="Rarity" Binding="{Binding RarityDisplay}" Width="Auto" />
                                    <DataGridTextColumn Header="Author" Binding="{Binding AuthorDisplay}" Width="Auto" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <Grid IsVisible="{Binding NoAchievementsVisible}" Background="#1e1e2e">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding NoAchievementsMessage}" FontSize="18" Foreground="#cdd6f4" TextWrapping="Wrap" TextAlignment="Center" />
                                    <Button Content="Open RA Settings" Margin="0,15,0,0" Click="OpenRaSettings_Click" Padding="10,5" />
                                </StackPanel>
                            </Grid>
                        </Panel>
                    </Grid>
                </TabItem>

                <!-- Tab 2: Game Info -->
                <TabItem Header="Game Info" Tag="GameInfo">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="10">
                        <Panel>
                            <StackPanel IsVisible="{Binding IsGameInfoLoaded}">
                                <!-- Game Images -->
                                <TextBlock Text="Game Images" FontWeight="Bold" FontSize="18" Margin="0,0,0,15" Foreground="#cdd6f4" />
                                <Grid Margin="0,0,0,25" ColumnDefinitions="*,*,*,*">
                                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                        <TextBlock Text="Icon" FontSize="14" HorizontalAlignment="Center" Foreground="#cdd6f4" />
                                        <Border BorderBrush="#45475a" BorderThickness="1" Margin="0,5,0,0" HorizontalAlignment="Center">
                                            <Image x:Name="GameInfoImageIcon" Width="150" Height="112" Stretch="Uniform" PointerPressed="GameImage_Click" />
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="10,0,10,0">
                                        <TextBlock Text="Title Screen" FontSize="14" HorizontalAlignment="Center" Foreground="#cdd6f4" />
                                        <Border BorderBrush="#45475a" BorderThickness="1" Margin="0,5,0,0" HorizontalAlignment="Center">
                                            <Image x:Name="GameInfoTitleImage" Width="150" Height="112" Stretch="Uniform" PointerPressed="GameImage_Click" />
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Margin="10,0,10,0">
                                        <TextBlock Text="In-Game" FontSize="14" HorizontalAlignment="Center" Foreground="#cdd6f4" />
                                        <Border BorderBrush="#45475a" BorderThickness="1" Margin="0,5,0,0" HorizontalAlignment="Center">
                                            <Image x:Name="GameInfoIngameImage" Width="150" Height="112" Stretch="Uniform" PointerPressed="GameImage_Click" />
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Grid.Column="3" Margin="10,0,0,0">
                                        <TextBlock Text="Box Art" FontSize="14" HorizontalAlignment="Center" Foreground="#cdd6f4" />
                                        <Border BorderBrush="#45475a" BorderThickness="1" Margin="0,5,0,0" HorizontalAlignment="Center">
                                            <Image x:Name="GameInfoBoxArtImage" Width="150" Height="112" Stretch="Uniform" PointerPressed="GameImage_Click" />
                                        </Border>
                                    </StackPanel>
                                </Grid>

                                <!-- Game Details -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                    <TextBlock Text="Game Details" FontWeight="Bold" FontSize="18" VerticalAlignment="Center" Foreground="#cdd6f4" />
                                    <Button Content="View on RetroAchievements" Click="ViewGameOnRaButton_Click" Margin="15,0,0,0" Padding="10,5" />
                                </StackPanel>
                                <Grid Margin="0,0,0,25" ColumnDefinitions="Auto,*,Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Genre" FontWeight="Bold" Margin="0,0,10,8" Foreground="#cdd6f4" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding GameGenre}" Margin="0,0,20,8" Foreground="#a6adc8" />
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Released" FontWeight="Bold" Margin="0,0,10,8" Foreground="#cdd6f4" />
                                    <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding GameReleased}" Margin="0,0,0,8" Foreground="#a6adc8" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Developer" FontWeight="Bold" Margin="0,0,10,8" Foreground="#cdd6f4" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding GameDeveloper}" Margin="0,0,20,8" Foreground="#a6adc8" />
                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="Publisher" FontWeight="Bold" Margin="0,0,10,8" Foreground="#cdd6f4" />
                                    <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding GamePublisher}" Margin="0,0,0,8" Foreground="#a6adc8" />
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Players" FontWeight="Bold" Margin="0,0,10,8" Foreground="#cdd6f4" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding GamePlayers}" Margin="0,0,20,8" Foreground="#a6adc8" />
                                    <TextBlock Grid.Row="2" Grid.Column="2" Text="Achievements" FontWeight="Bold" Margin="0,0,10,8" Foreground="#cdd6f4" />
                                    <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding GameAchievementCount}" Margin="0,0,0,8" Foreground="#a6adc8" />
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Console" FontWeight="Bold" Margin="0,0,10,8" Foreground="#cdd6f4" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding GameConsoleName}" Margin="0,0,20,8" Foreground="#a6adc8" />
                                    <TextBlock Grid.Row="3" Grid.Column="2" Text="Updated" FontWeight="Bold" Margin="0,0,10,8" Foreground="#cdd6f4" />
                                    <TextBlock Grid.Row="3" Grid.Column="3" Text="{Binding GameUpdated}" Margin="0,0,0,8" Foreground="#a6adc8" />
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Console ID" FontWeight="Bold" Margin="0,0,10,8" Foreground="#cdd6f4" />
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding GameConsoleId}" Margin="0,0,20,8" Foreground="#a6adc8" />
                                    <TextBlock Grid.Row="4" Grid.Column="2" Text="Game ID" FontWeight="Bold" Margin="0,0,10,8" Foreground="#cdd6f4" />
                                    <TextBlock Grid.Row="4" Grid.Column="3" Text="{Binding GameInfoId}" Margin="0,0,0,8" Foreground="#a6adc8" />
                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Parent Game" FontWeight="Bold" Margin="0,0,10,8" Foreground="#cdd6f4" />
                                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding GameParentGame}" Margin="0,0,20,8" Foreground="#a6adc8" />
                                    <TextBlock Grid.Row="5" Grid.Column="2" Text="Forum Topic" FontWeight="Bold" Margin="0,0,10,8" Foreground="#cdd6f4" />
                                    <TextBlock Grid.Row="5" Grid.Column="3" Text="{Binding GameForumTopic}" Margin="0,0,0,8" Foreground="#a6adc8" />
                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Release Granularity" FontWeight="Bold" Margin="0,0,10,8" Foreground="#cdd6f4" />
                                    <TextBlock Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding GameReleaseGranularity}" Margin="0,0,0,8" Foreground="#a6adc8" />
                                    <TextBlock Grid.Row="7" Grid.Column="0" Text="Guide URL" FontWeight="Bold" Margin="0,0,10,8" Foreground="#cdd6f4" />
                                    <TextBlock Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding GameGuideUrl}" Margin="0,0,0,8" Foreground="#a6adc8" />
                                </Grid>

                                <!-- Player Statistics -->
                                <TextBlock Text="Player Statistics" FontWeight="Bold" FontSize="18" Margin="0,0,0,15" Foreground="#cdd6f4" />
                                <Grid Margin="0,0,0,25" ColumnDefinitions="*,*,*">
                                    <Border Grid.Column="0" BorderBrush="#45475a" BorderThickness="1" Padding="10" Margin="0,0,5,0" CornerRadius="3">
                                        <StackPanel>
                                            <TextBlock Text="{Binding DistinctPlayers}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#a6e3a1" />
                                            <TextBlock Text="Total Players" HorizontalAlignment="Center" Foreground="#cdd6f4" FontSize="12" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" BorderBrush="#45475a" BorderThickness="1" Padding="10" Margin="5,0,5,0" CornerRadius="3">
                                        <StackPanel>
                                            <TextBlock Text="{Binding CasualPlayers}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#a6e3a1" />
                                            <TextBlock Text="Casual" HorizontalAlignment="Center" Foreground="#cdd6f4" FontSize="12" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2" BorderBrush="#45475a" BorderThickness="1" Padding="10" Margin="5,0,0,0" CornerRadius="3">
                                        <StackPanel>
                                            <TextBlock Text="{Binding HardcorePlayers}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#a6e3a1" />
                                            <TextBlock Text="Hardcore" HorizontalAlignment="Center" Foreground="#cdd6f4" FontSize="12" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!-- Claims -->
                                <TextBlock Text="Development Claims" FontWeight="Bold" FontSize="18" Margin="0,0,0,15" Foreground="#cdd6f4" />
                                <TextBlock Text="{Binding GameClaims}" TextWrapping="Wrap" Margin="0,0,0,20" Foreground="#a6adc8" />

                                <!-- Achievements List -->
                                <TextBlock Text="Achievements List" FontWeight="Bold" FontSize="18" Margin="0,25,0,15" Foreground="#cdd6f4" IsVisible="{Binding GameInfoAchievements, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                <DataGrid ItemsSource="{Binding GameInfoAchievements}" AutoGenerateColumns="False" IsReadOnly="True" Margin="0,0,0,20"
                                          HeadersVisibility="Column" GridLinesVisibility="Horizontal" RowDetailsVisibilityMode="Collapsed"
                                          Background="#1e1e2e" BorderBrush="#585b70" BorderThickness="1" MaxHeight="400">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*" />
                                        <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="2*" />
                                        <DataGridTextColumn Header="Points" Binding="{Binding Points}" Width="Auto" />
                                        <DataGridTextColumn Header="True Ratio" Binding="{Binding TrueRatio, StringFormat='{}{0}%'}" Width="Auto" />
                                        <DataGridTextColumn Header="Author" Binding="{Binding Author}" Width="Auto" />
                                        <DataGridTextColumn Header="Created" Binding="{Binding DateCreated}" Width="Auto" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>

                            <Grid IsVisible="{Binding NoGameInfoVisible}" Background="#1e1e2e">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding NoGameInfoMessage}" FontSize="18" Foreground="#cdd6f4" TextWrapping="Wrap" TextAlignment="Center" />
                                    <Button Content="Open RA Settings" Margin="0,15,0,0" Click="OpenRaSettings_Click" Padding="10,5" />
                                </StackPanel>
                            </Grid>
                        </Panel>
                    </ScrollViewer>
                </TabItem>

                <!-- Tab 3: Game Ranking -->
                <TabItem Header="Game Ranking" Tag="GameRanking">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="10">
                        <StackPanel>
                            <!-- Your Rank -->
                            <TextBlock Text="Your Rank and Score" FontWeight="Bold" FontSize="18" Margin="0,0,0,15" Foreground="#cdd6f4" />
                            <Panel>
                                <Grid Margin="0,0,0,25" ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Rank" FontWeight="Bold" Margin="0,0,10,8" Foreground="#cdd6f4" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding UserRank}" Margin="0,0,0,8" Foreground="#a6adc8" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Score" FontWeight="Bold" Margin="0,0,10,8" Foreground="#cdd6f4" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding UserScore}" Margin="0,0,0,8" Foreground="#a6adc8" />
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Last Award" FontWeight="Bold" Margin="0,0,10,8" Foreground="#cdd6f4" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding UserLastAward}" Margin="0,0,0,8" Foreground="#a6adc8" />
                                </Grid>
                                <Grid IsVisible="{Binding NoUserRankVisible}" Background="#1e1e2e" Opacity="0.9">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding NoUserRankMessage}" FontSize="16" Foreground="#cdd6f4" TextWrapping="Wrap" TextAlignment="Center" />
                                        <Button Content="Open RA Settings" Margin="0,15,0,0" Click="OpenRaSettings_Click" Padding="10,5" />
                                    </StackPanel>
                                </Grid>
                            </Panel>

                            <!-- Latest Masters -->
                            <TextBlock Text="Latest Masters" FontWeight="Bold" FontSize="18" Margin="0,0,0,15" Foreground="#cdd6f4" />
                            <Panel>
                                <DataGrid ItemsSource="{Binding LatestMasters}" AutoGenerateColumns="False" IsReadOnly="True" Margin="0,0,0,20"
                                          HeadersVisibility="Column" GridLinesVisibility="Horizontal" RowDetailsVisibilityMode="Collapsed"
                                          Background="#1e1e2e" BorderBrush="#585b70" BorderThickness="1">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Rank" Binding="{Binding Rank}" Width="Auto" />
                                        <DataGridTextColumn Header="User" Binding="{Binding User}" Width="*" />
                                        <DataGridTextColumn Header="Score" Binding="{Binding Score}" Width="Auto" />
                                        <DataGridTextColumn Header="True Ratio" Binding="{Binding TrueRatio, StringFormat='{}{0}%'}" Width="Auto" />
                                        <DataGridTextColumn Header="Achievements" Binding="{Binding NumAchievements}" Width="Auto" />
                                        <DataGridTextColumn Header="Last Award" Binding="{Binding LastAward}" Width="Auto" />
                                    </DataGrid.Columns>
                                </DataGrid>
                                <Grid IsVisible="{Binding NoLatestMastersVisible}" Background="#1e1e2e">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding NoLatestMastersMessage}" FontSize="18" Foreground="#cdd6f4" TextWrapping="Wrap" TextAlignment="Center" />
                                    </StackPanel>
                                </Grid>
                            </Panel>

                            <!-- High Scores -->
                            <TextBlock Text="High Scores" FontWeight="Bold" FontSize="18" Margin="0,20,0,15" Foreground="#cdd6f4" />
                            <Panel>
                                <DataGrid ItemsSource="{Binding HighScores}" AutoGenerateColumns="False" IsReadOnly="True" Margin="0,0,0,10"
                                          HeadersVisibility="Column" GridLinesVisibility="Horizontal" RowDetailsVisibilityMode="Collapsed"
                                          Background="#1e1e2e" BorderBrush="#585b70" BorderThickness="1">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Rank" Binding="{Binding Rank}" Width="Auto" />
                                        <DataGridTextColumn Header="User" Binding="{Binding User}" Width="*" />
                                        <DataGridTextColumn Header="Score" Binding="{Binding Score}" Width="Auto" />
                                        <DataGridTextColumn Header="True Ratio" Binding="{Binding TrueRatio, StringFormat='{}{0}%'}" Width="Auto" />
                                        <DataGridTextColumn Header="Achievements" Binding="{Binding NumAchievements}" Width="Auto" />
                                        <DataGridTextColumn Header="Last Award" Binding="{Binding LastAward}" Width="Auto" />
                                    </DataGrid.Columns>
                                </DataGrid>
                                <Grid IsVisible="{Binding NoHighScoresVisible}" Background="#1e1e2e">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding NoHighScoresMessage}" FontSize="18" Foreground="#cdd6f4" TextWrapping="Wrap" TextAlignment="Center" />
                                    </StackPanel>
                                </Grid>
                            </Panel>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Tab 4: My Profile -->
                <TabItem Header="My Profile" Tag="MyProfile">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="10">
                        <Panel>
                            <StackPanel IsVisible="{Binding !NoProfileVisible}">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                    <Border BorderBrush="#45475a" BorderThickness="1" Width="90" Height="90" CornerRadius="5">
                                        <Image x:Name="UserProfilePic2" Stretch="Uniform" />
                                    </Border>
                                    <StackPanel VerticalAlignment="Center" Margin="15,0,0,0">
                                        <TextBlock Text="{Binding ProfileUser}" FontSize="22" FontWeight="Bold" Foreground="#cdd6f4" />
                                        <TextBlock Text="{Binding ProfileMotto}" FontStyle="Italic" TextWrapping="Wrap" Margin="0,5,0,0" FontSize="14" Foreground="#a6adc8" />
                                        <Button Content="View Profile on RA" Margin="0,10,0,0" Click="ViewProfileOnRaButton_Click" Padding="10,5" />
                                    </StackPanel>
                                </StackPanel>
                                <Border Background="#585b70" Margin="0,0,0,20" Padding="15" CornerRadius="5">
                                    <StackPanel>
                                        <TextBlock Text="Currently Playing" FontWeight="Bold" Foreground="#cdd6f4" FontSize="16" />
                                        <TextBlock Text="{Binding ProfileRichPresence}" TextWrapping="Wrap" Foreground="#cdd6f4" Margin="0,5,0,0" FontSize="14" />
                                    </StackPanel>
                                </Border>
                                <Grid Margin="0,0,0,25" ColumnDefinitions="*,*,*">
                                    <Border Grid.Column="0" BorderBrush="#45475a" BorderThickness="1" Padding="10" Margin="0,0,5,0" CornerRadius="3">
                                        <StackPanel>
                                            <TextBlock Text="{Binding ProfilePoints}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#a6e3a1" />
                                            <TextBlock Text="Points" HorizontalAlignment="Center" Foreground="#cdd6f4" FontSize="12" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" BorderBrush="#45475a" BorderThickness="1" Padding="10" Margin="5,0,5,0" CornerRadius="3">
                                        <StackPanel>
                                            <TextBlock Text="{Binding ProfileTruePoints}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#a6e3a1" />
                                            <TextBlock Text="TruePoints" HorizontalAlignment="Center" Foreground="#cdd6f4" FontSize="12" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2" BorderBrush="#45475a" BorderThickness="1" Padding="10" Margin="5,0,0,0" CornerRadius="3">
                                        <StackPanel>
                                            <TextBlock Text="{Binding ProfileRank}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#a6e3a1" />
                                            <TextBlock Text="Rank" HorizontalAlignment="Center" Foreground="#cdd6f4" FontSize="12" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                                <TextBlock Text="Recently Played Games" FontWeight="Bold" Margin="0,15,0,10" FontSize="18" Foreground="#cdd6f4" />
                                <ListBox ItemsSource="{Binding RecentlyPlayedGames}" BorderThickness="1" BorderBrush="#45475a" Background="#1e1e2e" MinHeight="100">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="5,2">
                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Foreground="#cdd6f4" FontSize="14" Width="250" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding ConsoleName}" FontSize="12" Foreground="#a6adc8" Width="150" TextTrimming="CharacterEllipsis" Margin="10,0,0,0" />
                                                <TextBlock Text="{Binding LastPlayed}" FontSize="12" Foreground="#a6adc8" Margin="10,0,0,0" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                            <Grid IsVisible="{Binding NoProfileVisible}" Background="#1e1e2e">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding NoProfileMainMessage}" FontSize="18" TextWrapping="Wrap" TextAlignment="Center" Foreground="#cdd6f4" />
                                    <TextBlock Text="{Binding NoProfileSubMessage}" FontSize="14" Foreground="#a6adc8" Margin="0,10,0,0" TextWrapping="Wrap" TextAlignment="Center" />
                                    <Button Content="Open RA Settings" Margin="0,15,0,0" Click="OpenRaSettings_Click" Padding="10,5" />
                                </StackPanel>
                            </Grid>
                        </Panel>
                    </ScrollViewer>
                </TabItem>

                <!-- Tab 5: Unlocks -->
                <TabItem Header="Unlocks" Tag="Unlocks">
                    <Grid RowDefinitions="Auto,Auto,*">
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10,15,10,15">
                            <TextBlock Text="From" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="14" Foreground="#cdd6f4" />
                            <DatePicker SelectedDate="{Binding FromDate}" Width="140" />
                            <TextBlock Text="To" VerticalAlignment="Center" Margin="15,0,5,0" FontSize="14" Foreground="#cdd6f4" />
                            <DatePicker SelectedDate="{Binding ToDate}" Width="140" />
                            <Button Content="Fetch Unlocks" Command="{Binding FetchUnlocksCommand}" Margin="15,0,0,0" Padding="10,5" IsEnabled="{Binding FetchUnlocksEnabled}" />
                            <Button Content="Reset Dates" Command="{Binding ResetDatesCommand}" Margin="10,0,0,0" Padding="10,5" />
                        </StackPanel>
                        <Grid Grid.Row="1" Margin="10,0,10,15">
                            <Border Padding="15" BorderBrush="#585b70" BorderThickness="1" CornerRadius="5">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="Total Unlocks: " FontWeight="Bold" FontSize="16" Foreground="#cdd6f4" />
                                        <TextBlock Text="{Binding TotalUnlocksInRange}" FontWeight="Bold" FontSize="16" Foreground="#a6e3a1" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
                                        <TextBlock Text="Total Points: " FontWeight="Bold" FontSize="16" Foreground="#cdd6f4" />
                                        <TextBlock Text="{Binding TotalPointsEarnedInRange}" FontWeight="Bold" FontSize="16" Foreground="#a6e3a1" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                        <Panel Grid.Row="2">
                            <DataGrid ItemsSource="{Binding Unlocks}" AutoGenerateColumns="False" IsReadOnly="True" Margin="10,0,10,10"
                                      HeadersVisibility="Column" GridLinesVisibility="Horizontal" RowDetailsVisibilityMode="Collapsed"
                                      Background="#1e1e2e" BorderBrush="#585b70" BorderThickness="1">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Game Title" Binding="{Binding GameTitle}" Width="*" />
                                    <DataGridTextColumn Header="Achievement" Binding="{Binding Title}" Width="2*" />
                                    <DataGridTextColumn Header="Points" Binding="{Binding Points}" Width="Auto" />
                                    <DataGridTextColumn Header="Unlocked Date" Binding="{Binding UnlockedDateDisplay}" Width="Auto" />
                                    <DataGridTextColumn Header="Console" Binding="{Binding ConsoleName}" Width="Auto" />
                                </DataGrid.Columns>
                            </DataGrid>
                            <Grid IsVisible="{Binding NoUnlocksVisible}" Background="#1e1e2e">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding NoUnlocksMessage}" FontSize="18" Foreground="#cdd6f4" TextWrapping="Wrap" TextAlignment="Center" />
                                    <Button Content="Open RA Settings" Margin="0,15,0,0" Click="OpenRaSettings_Click" Padding="10,5" />
                                </StackPanel>
                            </Grid>
                        </Panel>
                    </Grid>
                </TabItem>

                <!-- Tab 6: User Progress -->
                <TabItem Header="User Progress" Tag="UserProgress">
                    <Panel>
                        <DataGrid ItemsSource="{Binding UserProgress}" AutoGenerateColumns="False" IsReadOnly="True" Margin="10,10,10,10"
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal" RowDetailsVisibilityMode="Collapsed"
                                  Background="#1e1e2e" BorderBrush="#585b70" BorderThickness="1">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Game Title" Binding="{Binding Title}" Width="2*" />
                                <DataGridTextColumn Header="Console" Binding="{Binding ConsoleName}" Width="*" />
                                <DataGridTextColumn Header="Casual" Binding="{Binding CompletionDisplay}" Width="Auto" />
                                <DataGridTextColumn Header="Hardcore" Binding="{Binding HardcoreCompletionDisplay}" Width="Auto" />
                                <DataGridTextColumn Header="Most Recent Award" Binding="{Binding MostRecentAwardedDateDisplay}" Width="Auto" />
                                <DataGridTextColumn Header="Highest Award" Binding="{Binding HighestAwardKindDisplay}" Width="Auto" />
                                <DataGridTextColumn Header="Highest Award Date" Binding="{Binding HighestAwardDateDisplay}" Width="Auto" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <Grid IsVisible="{Binding NoUserProgressVisible}" Background="#1e1e2e">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding NoUserProgressMainMessage}" FontSize="18" TextWrapping="Wrap" TextAlignment="Center" Foreground="#cdd6f4" />
                                <TextBlock Text="{Binding NoUserProgressSubMessage}" FontSize="14" Foreground="#a6adc8" Margin="0,10,0,0" TextWrapping="Wrap" TextAlignment="Center" />
                                <Button Content="Open RA Settings" Margin="0,15,0,0" Click="OpenRaSettings_Click" Padding="10,5" />
                            </StackPanel>
                        </Grid>
                    </Panel>
                </TabItem>
            </TabControl>

            <!-- Loading Overlay -->
            <Panel Grid.Row="0" IsVisible="{Binding IsLoading}" Background="#80000000" ZIndex="100">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10">
                    <TextBlock Text="Loading..." FontSize="18" Foreground="#cdd6f4" HorizontalAlignment="Center" />
                    <ProgressBar IsIndeterminate="True" Width="200" />
                </StackPanel>
            </Panel>
        </Grid>
    </Border>
</Window>
