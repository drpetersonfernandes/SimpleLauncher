<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SimpleLauncher.Avalonia.ViewModels"
        x:Class="SimpleLauncher.Avalonia.Views.SupportWindow"
        x:DataType="vm:AvaloniaSupportViewModel"
        Title="Support"
        Width="600" Height="450"
        WindowStartupLocation="CenterScreen"
        CanResize="False">

    <Grid>
        <Grid x:Name="MainContentGrid" RowDefinitions="Auto,Auto,Auto,*,Auto">
            <!-- Explanation -->
            <StackPanel Grid.Row="0" Margin="10,10,10,20">
                <TextBlock Text="Use the form below to get support." />
            </StackPanel>

            <!-- Name -->
            <StackPanel Grid.Row="1" Margin="10,0,10,10" Orientation="Horizontal">
                <TextBlock Text="Name:" Width="95" VerticalAlignment="Center" />
                <TextBox Width="270" Text="{Binding Name}" PlaceholderText="Your name" />
            </StackPanel>

            <!-- Email -->
            <StackPanel Grid.Row="2" Margin="10,0,10,20" Orientation="Horizontal">
                <TextBlock Text="Email:" Width="95" VerticalAlignment="Center" />
                <TextBox Width="270" Text="{Binding Email}" PlaceholderText="your@email.com" />
            </StackPanel>

            <!-- Support Request -->
            <TextBox Grid.Row="3"
                     Height="200"
                     Margin="10,0,10,20"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     Text="{Binding SupportRequest}"
                     PlaceholderText="Describe your issue..." />

            <!-- Buttons -->
            <StackPanel Grid.Row="4" Margin="10,0,10,20"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal">
                <Button IsDefault="True"
                        Command="{Binding SendSupportRequestCommand}"
                        Content="Send Support Request"
                        Width="150" />
                <Button IsCancel="True"
                        Margin="10,0,0,0"
                        Command="{Binding CloseCommand}"
                        Content="Close"
                        Width="100" />
            </StackPanel>
        </Grid>

        <!-- Loading Overlay -->
        <Border x:Name="LoadingOverlay"
                IsVisible="{Binding IsLoading}"
                Background="#80000000"
                ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10">
                <TextBlock Text="Sending..." HorizontalAlignment="Center" Foreground="White" FontSize="16" />
                <ProgressBar IsIndeterminate="True" Width="200" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
